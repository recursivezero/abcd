<a href="/games" class="back" aria-label="Go back" id="backBtn">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M19 12H5M12 5l-7 7 7 7"></path>
  </svg>
</a>

<script is:inline>
  function moveBackBtn() {
    const btn = document.getElementById("backBtn");
    const wrap = document.querySelector(".hero-search__wrap");
    if (btn && wrap && !wrap.contains(btn)) {
      wrap.insertBefore(btn, wrap.firstChild);
    }
  }
  moveBackBtn();
  document.addEventListener("astro:page-load", moveBackBtn);
</script>

<style is:global>
  .back {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    text-decoration: none;
    background: white;
    border: 1px solid #e2e8f0;
    color: #7c3aed;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.15);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .back:hover {
    background: #ede9fe;
    border-color: #7c3aed;
    transform: scale(1.06);
  }
  .back svg {
    width: 18px;
    height: 18px;
  }
</style>
