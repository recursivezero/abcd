<a href="/games" class="back-btn" aria-label="Go back">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M19 12H5M12 5l-7 7 7 7"></path>
  </svg>
</a>

<style is:global>
  .back-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    text-decoration: none;
    background: white;
    border: 0.5px solid #e2e8f0;
    color: #7c3aed;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    transition:
      background 0.15s ease,
      transform 0.2s ease;
  }

  /* ── Desktop: fixed left corner ── */
  @media (min-width: 641px) {
    .back-btn {
      position: fixed;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
    }

    .back-btn:hover {
      transform: translateY(-50%) scale(1.06);
    }
  }

  /* ── Mobile: flex row mein search ke saath ── */
  @media (max-width: 640px) {
    .back-btn {
      position: static;
    }

    .back-btn:hover {
      transform: scale(1.06);
    }
  }

  .back-btn svg {
    width: 1rem;
    height: 1rem;
    pointer-events: none;
  }

  [data-theme="dark"] .back-btn {
    background: #1e293b;
    border-color: #334155;
    color: #a78bfa;
  }

  [data-theme="dark"] .back-btn:hover {
    background: #2d1f5e;
    border-color: #7c3aed;
  }
</style>
