---
import { getLetterIndex } from "@/utils/index";

const letters = Array.from({ length: 26 }, (_, i) => String.fromCharCode(65 + i));
---

<article class="grid__container">
  <section class="grid__section" id="gridSection">
    {
      letters.map((letter) => (
        <div class="grid__item" data-letter={letter} style={`--letter-index:${getLetterIndex(letter)}`}>
          {letter}
        </div>
      ))
    }
  </section>
</article>

<style>
  :root {
    --border-radius-sm: 0.5rem;
    --shadow-sm: 0 4px 6px rgba(0, 0, 0, 0.1);
    --shadow-md: 0 8px 16px rgba(0, 0, 0, 0.15);
    --transition: all 0.3s ease;
    --text-light: #ffffff;
    --default-bg: #0b1f54;
  }

  .grid__container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    padding: 1rem;
    background: light-dark(#f8eeec, #87807c);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  /* ── Grid ── */
  .grid__section {
    display: grid;
    grid-template-columns: repeat(5, minmax(100px, 1fr));
    gap: 0.5rem;
  }

  .grid__item {
    color: light-dark(#000000, #ffffff);
    --hue: calc(360 / 26 * var(--letter-index, 0));
    --letter-color: hsl(var(--hue) 85% 60%);

    aspect-ratio: 1;
    display: grid;
    place-items: center;
    background: var(--default-bg);
    border-radius: var(--border-radius-sm);
    cursor: pointer;
    font-size: 8.5rem;
    font-weight: bold;
    color: transparent;
    border: 2px solid transparent;
    transition: var(--transition);
  }

  .grid__item.active {
    background-color: var(--letter-color);
    color: var(--text-light);
  }

  .grid__item:hover:not(.active) {
    color: light-dark(#808080, #5f5f5f);
    transform: translateY(-2px) rotateY(10deg);
    box-shadow: var(--shadow-md);
  }

  .grid__item:not(.active) {
    color: light-dark(#ffffff, #232025);
    background-color: light-dark(#ffffff, #232025);
  }

  @media (max-width: 768px) {
    .grid__section {
      grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    }

    .grid__item {
      font-size: 5rem;
    }
  }

  @media (max-width: 480px) {
    .grid__item {
      font-size: 3rem;
    }
  }
</style>

<script>
  // ─────────────────────────────────────────────
  // Modular shuffle utility — reusable anywhere
  // Takes any array, returns a new shuffled array
  // (Fisher-Yates algorithm)
  // ─────────────────────────────────────────────
  function shuffleArray<T>(arr: T[]): T[] {
    const copy = [...arr];
    for (let i = copy.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [copy[i], copy[j]] = [copy[j], copy[i]];
    }
    return copy;
  }

  // ── State ──
  const activeLetters = new Set<string>();

  // ── DOM refs ──
  const gridSection = document.getElementById("gridSection")!;
  const shuffleBtn = document.getElementById("shuffleBtn")!;
  const resetBtn = document.getElementById("resetBtn")!;

  // ── Toggle visibility of a letter tile ──
  function toggleLetterVisibility(element: HTMLElement) {
    const letter = element.getAttribute("data-letter") ?? "";
    element.classList.toggle("active");
    if (element.classList.contains("active")) {
      activeLetters.add(letter);
    } else {
      activeLetters.delete(letter);
    }
  }

  // ── Attach click handler to a single tile ──
  function attachTileListener(item: HTMLElement) {
    item.addEventListener("click", () => toggleLetterVisibility(item));
  }

  // ── Re-render grid with a given letter order ──
  function renderGrid(order: string[]) {
    // Clear active state tracking — position changed, reset makes sense
    activeLetters.clear();

    // Re-order existing DOM nodes to match new order (no re-create needed)
    order.forEach((letter) => {
      const tile = gridSection.querySelector<HTMLElement>(`.grid__item[data-letter="${letter}"]`);
      if (tile) {
        tile.classList.remove("active"); // clear visual state too
        gridSection.appendChild(tile); // move to end → builds order
      }
    });
  }

  // ── Original A–Z order ──
  const originalOrder = Array.from({ length: 26 }, (_, i) => String.fromCharCode(65 + i));

  // ── Shuffle button ──
  shuffleBtn.addEventListener("click", () => {
    const shuffled = shuffleArray(originalOrder);
    renderGrid(shuffled);
  });

  // ── Reset button ──
  resetBtn.addEventListener("click", () => {
    renderGrid(originalOrder);
  });

  // ── Initial click listeners on all tiles ──
  document.querySelectorAll<HTMLElement>(".grid__item").forEach(attachTileListener);

  // ── Keyboard support ──
  document.addEventListener("keydown", (e) => {
    if (/^[a-zA-Z]$/.test(e.key)) {
      const tile = document.querySelector<HTMLElement>(`.grid__item[data-letter="${e.key.toUpperCase()}"]`);
      if (tile) toggleLetterVisibility(tile);
    }
  });
</script>
