---
import type { Game } from "@/data/gamesData";

interface Props {
  games: Game[];
}

const { games } = Astro.props;
---

<div class="games-grid">
  {
    games.map((game) => (
      <div class="game-card">
        <div class="game-image" style={`background-image: url('${game.image}')`} />
        <div class="game-content">
          <h3>{game.title}</h3>
          <p>{game.description}</p>
          <div class="game-tags">
            {game.tags.map((tag) => (
              <span class="game-tag">{tag}</span>
            ))}
          </div>
          <a href={game.link} class="game-button">
            View Details
          </a>
        </div>
      </div>
    ))
  }
</div>

<style>
  .games-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Sirf 2 cards hain toh center karo */
  .games-grid:has(.game-card:last-child:nth-child(2)) {
    grid-template-columns: repeat(2, minmax(0, 360px));
    justify-content: center;
  }

  /* Sirf 1 card hai toh center karo */
  .games-grid:has(.game-card:last-child:nth-child(1)) {
    grid-template-columns: minmax(0, 360px);
    justify-content: center;
  }

  .game-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    border: 2px solid #e8e8f0;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }
  .game-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.13);
    border-color: #c8b8ff;
  }

  .game-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    background-color: #f0eeff;
    flex-shrink: 0;
  }

  .game-content {
    padding: 1rem 1.2rem 1.2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.4rem;
  }

  h3 {
    font-size: 1rem;
    font-weight: 800;
    color: #1a1a40;
    margin: 0;
  }

  p {
    font-size: 0.82rem;
    color: #666;
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .game-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 2px;
  }

  .game-tag {
    background: #f0eeff;
    color: #7048c0;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }

  .game-button {
    margin-top: auto;
    padding-top: 0.75rem;
    display: block;
    text-align: center;
    background: #5c6bc0;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.6rem 1.2rem;
    border-radius: 50px;
    text-decoration: none;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }
  .game-button:hover {
    background: #7048c0;
    transform: scale(1.03);
  }

  /* Dark mode */
  :global([data-theme="dark"]) .game-card {
    background: rgba(3, 26, 32, 0.72);
    border-color: rgba(34, 211, 238, 0.12);
  }
  :global([data-theme="dark"]) .game-card:hover {
    border-color: rgba(34, 211, 238, 0.3);
  }
  :global([data-theme="dark"]) h3 {
    color: #7dd3fc;
  }
  :global([data-theme="dark"]) p {
    color: #94a3b8;
  }
  :global([data-theme="dark"]) .game-tag {
    background: rgba(34, 211, 238, 0.12);
    color: #7dd3fc;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .games-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .games-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
