---
import { gamesData } from "@/data/gamesData";
---

<section class="age-section" id="categories">
  <h2 class="age-title">
    <span>🎀</span>
    Explore by Age Group
    <span>🎀</span>
  </h2>

  <div class="age-grid">
    <a href="/games/3-5" class="age-card" data-label="toddlers" style="--card-bg: #EDE9FE; --card-bg-dark: #3b1f6e;">
      <span class="age-icon">🧸</span>
      <h2 class="age-label" style="color: #7C3AED;">Toddlers</h2>
      <p class="age-range" style="color: #100c17;">1–3 Years</p>
      <span class="age-explore" style="color: #270466;">Explore →</span>
    </a>

    <a
      href="/games/3-5"
      class="age-card"
      data-label="preschoolers"
      style="--card-bg: #FEF9C3; --card-bg-dark: #4a3a00;"
    >
      <span class="age-icon">🏠</span>
      <h2 class="age-label" style="color: #D97706;">Preschoolers</h2>
      <p class="age-range" style="color: #eb1818e8;">3–5 Years</p>
      <span class="age-explore" style="color: #ad6009;">Explore →</span>
    </a>

    <a
      href="/games/6-8"
      class="age-card"
      data-label="early learners"
      style="--card-bg: #DCFCE7; --card-bg-dark: #0f3d20;"
    >
      <span class="age-icon">🎨</span>
      <h3 class="age-label" style="color: #16A34A;">Early Learners</h3>
      <p class="age-range" style="color: #9706ea;">6–8 Years</p>
      <span class="age-explore" style="color: #056c2b;">Explore →</span>
    </a>

    <a href="/games/9-12" class="age-card" data-label="kids" style="--card-bg: #DBEAFE; --card-bg-dark: #1e3a6e;">
      <span class="age-icon">💡</span>
      <h2 class="age-label" style="color: #2563EB;">Kids</h2>
      <p class="age-range" style="color: #d409d4;">9–12 Years</p>
      <span class="age-explore" style="color: #0d3da5;">Explore →</span>
    </a>

    <a href="/games/teens" class="age-card" data-label="teens" style="--card-bg: #FCE7F3; --card-bg-dark: #4a1030;">
      <span class="age-icon">🎮</span>
      <h2 class="age-label" style="color: #DB2777;">Teens</h2>
      <p class="age-range" style="color: #0a55eb;">12+ Years</p>
      <span class="age-explore" style="color: #870d44;">Explore →</span>
    </a>

    <a href="/games/adults" class="age-card" data-label="family" style="--card-bg: #FFF0E0; --card-bg-dark: #4a2a00;">
      <span class="age-icon">👨‍👩‍👧‍👦</span>
      <h2 class="age-label" style="color: #EA6C00;">Family</h2>
      <p class="age-range" style="color: #06c663;">All Ages</p>
      <span class="age-explore" style="color: #6d3606;">Explore →</span>
    </a>
  </div>
</section>

<style>
  .age-section {
    padding: 3rem 0 4rem;
    text-align: center;
    background: transparent;
  }

  :global([data-theme="dark"]) .age-section {
    background: transparent;
  }

  .age-title {
    font-size: 2.2rem;
    font-weight: 900;

    color: #1a3353;

    margin-bottom: 3rem;

    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
  }

  :global([data-theme="dark"]) .age-title {
    color: #e0f7fa;

    text-shadow: 0 0 14px rgba(34, 211, 238, 0.08);
  }

  .age-grid {
    display: grid;

    grid-template-columns: repeat(3, 1fr);

    gap: 2rem;

    justify-content: center;

    max-width: 980px;

    margin: 0 auto;

    padding: 0 2rem;
  }

  .age-card {
    background: var(--card-bg);

    border-radius: 1.6rem;

    padding: 2.2rem 1.4rem 1.8rem;

    width: 100%;

    min-height: 260px;

    text-align: center;
    text-decoration: none;

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    gap: 0.5rem;

    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;

    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.07);
  }

  :global([data-theme="dark"]) .age-card {
    background: linear-gradient(180deg, rgba(3, 26, 32, 0.72) 0%, rgba(5, 46, 56, 0.82) 100%);

    border: 1px solid rgba(34, 211, 238, 0.12);

    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);

    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .age-card:hover {
    transform: translateY(-6px);

    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.13);
  }

  :global([data-theme="dark"]) .age-card:hover {
    border-color: rgba(34, 211, 238, 0.3);

    box-shadow:
      0 12px 30px rgba(0, 0, 0, 0.45),
      0 0 22px rgba(34, 211, 238, 0.12);
  }

  .age-icon {
    font-size: 3.2rem;

    line-height: 1;

    margin-bottom: 0.8rem;
  }

  .age-label {
    font-size: 1.3rem;
    font-weight: 800;

    margin: 0;
  }

  .age-range {
    font-size: 1rem;
    font-weight: 600;

    margin: 0.2rem 0;
  }

  .age-explore {
    font-size: 1rem;
    font-weight: 700;

    margin-top: 1rem;
  }

  :global([data-theme="dark"]) .age-label,
  :global([data-theme="dark"]) .age-range,
  :global([data-theme="dark"]) .age-explore {
    color: #7dd3fc !important;
  }

  /* Tablet */

  @media (max-width: 900px) {
    .age-grid {
      grid-template-columns: repeat(2, 1fr);

      gap: 1.5rem;

      max-width: 700px;
    }
  }

  /* Mobile */

  @media (max-width: 600px) {
    .age-grid {
      grid-template-columns: 1fr;

      max-width: 100%;
    }

    .age-card {
      min-height: 220px;
    }

    .age-title {
      font-size: 1.7rem;
    }
  }
</style>
