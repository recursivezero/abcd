---
import { gamesData } from "@/data/gamesData";
---

<section class="age-section" id="categories">
  <h2 class="age-title">
    <span>🎀</span>
    Explore by Age Group
    <span>🎀</span>
  </h2>

  <div class="age-grid">
    <a href="/games/3-5" class="age-card" data-label="toddlers" style="--card-bg: #EDE9FE; --card-bg-dark: #3b1f6e;">
      <span class="age-icon">🧸</span>
      <h3 class="age-label" style="color: #7C3AED;">Toddlers</h3>
      <p class="age-range" style="color: #7C3AED;">1–3 Years</p>
      <span class="age-explore" style="color: #7C3AED;">Explore →</span>
    </a>
    <a
      href="/games/3-5"
      class="age-card"
      data-label="preschoolers"
      style="--card-bg: #FEF9C3; --card-bg-dark: #4a3a00;"
    >
      <span class="age-icon">🏠</span>
      <h3 class="age-label" style="color: #D97706;">Preschoolers</h3>
      <p class="age-range" style="color: #D97706;">3–5 Years</p>
      <span class="age-explore" style="color: #D97706;">Explore →</span>
    </a>
    <a
      href="/games/6-8"
      class="age-card"
      data-label="early learners"
      style="--card-bg: #DCFCE7; --card-bg-dark: #0f3d20;"
    >
      <span class="age-icon">🎨</span>
      <h3 class="age-label" style="color: #16A34A;">Early Learners</h3>
      <p class="age-range" style="color: #16A34A;">5–8 Years</p>
      <span class="age-explore" style="color: #16A34A;">Explore →</span>
    </a>
    <a href="/games/9-12" class="age-card" data-label="kids" style="--card-bg: #DBEAFE; --card-bg-dark: #1e3a6e;">
      <span class="age-icon">💡</span>
      <h3 class="age-label" style="color: #2563EB;">Kids</h3>
      <p class="age-range" style="color: #2563EB;">8–12 Years</p>
      <span class="age-explore" style="color: #2563EB;">Explore →</span>
    </a>
    <a href="/games/teens" class="age-card" data-label="teens" style="--card-bg: #FCE7F3; --card-bg-dark: #4a1030;">
      <span class="age-icon">🎮</span>
      <h3 class="age-label" style="color: #DB2777;">Teens</h3>
      <p class="age-range" style="color: #DB2777;">12+ Years</p>
      <span class="age-explore" style="color: #DB2777;">Explore →</span>
    </a>
    <a href="/games/adults" class="age-card" data-label="family" style="--card-bg: #FFF0E0; --card-bg-dark: #4a2a00;">
      <span class="age-icon">👨‍👩‍👧‍👦</span>
      <h3 class="age-label" style="color: #EA6C00;">Family</h3>
      <p class="age-range" style="color: #EA6C00;">All Ages</p>
      <span class="age-explore" style="color: #EA6C00;">Explore →</span>
    </a>
  </div>
</section>

<style>
  .age-section {
    padding: 3rem 2rem 4rem;

    text-align: center;

    background: transparent;
  }

  :global([data-theme="dark"]) .age-section {
    background: transparent;
  }

  .age-title {
    font-size: 1.85rem;
    font-weight: 900;

    color: #1a3353;

    margin-bottom: 2rem;

    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
  }

  :global([data-theme="dark"]) .age-title {
    color: #e0f7fa;

    text-shadow: 0 0 14px rgba(34, 211, 238, 0.08);
  }

  .age-grid {
    display: flex;

    gap: 1rem;

    justify-content: center;

    flex-wrap: nowrap;

    max-width: 1200px;

    margin: 0 auto;
  }

  .age-card {
    background: var(--card-bg);

    border-radius: 1.4rem;

    padding: 1.8rem 1rem 1.4rem;

    width: 155px;
    min-width: 130px;

    flex-shrink: 0;

    text-align: center;
    text-decoration: none;

    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;

    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;

    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.07);
  }

  :global([data-theme="dark"]) .age-card {
    background: linear-gradient(180deg, rgba(3, 26, 32, 0.72) 0%, rgba(5, 46, 56, 0.82) 100%);

    border: 1px solid rgba(34, 211, 238, 0.12);

    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);

    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .age-card:hover {
    transform: translateY(-6px);

    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.13);
  }

  :global([data-theme="dark"]) .age-card:hover {
    border-color: rgba(34, 211, 238, 0.3);

    box-shadow:
      0 12px 30px rgba(0, 0, 0, 0.45),
      0 0 22px rgba(34, 211, 238, 0.12);
  }

  .age-icon {
    font-size: 2.8rem;

    line-height: 1;

    margin-bottom: 0.4rem;
  }

  .age-label {
    font-size: 1.05rem;
    font-weight: 800;

    margin: 0;
  }

  .age-range {
    font-size: 0.88rem;
    font-weight: 600;

    margin: 0;
  }

  .age-explore {
    font-size: 0.95rem;
    font-weight: 700;

    margin-top: 0.4rem;
  }

  :global([data-theme="dark"]) .age-label,
  :global([data-theme="dark"]) .age-range,
  :global([data-theme="dark"]) .age-explore {
    color: #7dd3fc !important;
  }

  @media (max-width: 900px) {
    .age-grid {
      flex-wrap: wrap;
    }

    .age-card {
      width: 145px;
    }
  }
</style>
