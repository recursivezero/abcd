---
import Settings from "@/components/Settings.astro";
import HintIcon from "@/assets/icons/hint.svg";
---

<div class="puzzle-container">
  <Settings />
  <details open>
    <summary>Word List</summary>
    <div class="word-list" id="wordList"></div>
  </details>

  <div class="stats-container">
    <div class="stats-button">
      <span>Clicks: <span id="clickCount">0</span></span>
    </div>
    <div class="stats-button">
      <span>Found: <span id="foundCount">0</span>/<span id="totalWords"></span></span>
    </div>
    <button id="solutionBtn" class="hint-button" aria-label="Toggle hints">
      <div style="width: 28px; height: 28px;">
        <HintIcon />
      </div>
    </button>
    <button id="shuffle" class="action-btn btn-shuffle">🔀 Shuffle</button>
    <button id="new" class="action-btn btn-new">✨ New Puzzle</button>
  </div>

  <div id="grid" class="grid__puzzle"></div>

  <script type="module" is:inline>
    // ── Fallback data agar fetch fail ho ──
    const FALLBACK_DATA = [
      {
        easy: ["CAT", "DOG", "SUN", "MOON", "STAR"],
        medium: ["APPLE", "GRAPE", "ORANGE", "BERRIES"],
        hard: ["WALRUS", "GIRAFFE", "PENGUIN", "DOLPHIN"]
      },
      {
        easy: ["HAT", "CAR", "BALL", "SHOE", "LAMP"],
        medium: ["CHERRY", "COCONUT", "PLUM", "MELON", "PEACH"],
        hard: ["OCTOPUS", "JACKAL", "WALRUS", "PEACOCK"]
      },
      {
        easy: ["RED", "BLUE", "GREEN", "YELLOW", "PURPLE"],
        medium: ["BLACK", "WHITE", "BROWN", "ORANGE", "PINK"],
        hard: ["MAGENTA", "CYAN", "VIOLET", "MAROON"]
      }
    ];

    async function fetchCrosswordData() {
      try {
        const response = await fetch("/assets/json/cross.json");
        if (!response.ok) throw new Error("HTTP " + response.status);
        const data = await response.json();
        if (!Array.isArray(data) || data.length === 0) throw new Error("Empty data");
        console.log("cross.json loaded OK, sets:", data.length);
        return data;
      } catch (error) {
        console.warn("cross.json fetch failed, using fallback:", error.message);
        return FALLBACK_DATA;
      }
    }

    const colorClasses = [
      "word-color-1",
      "word-color-2",
      "word-color-3",
      "word-color-4",
      "word-color-5",
      "word-color-6",
      "word-color-7",
      "word-color-8"
    ];

    const getRandomColor = () => {
      const hue = Math.floor(Math.random() * 360);
      return `hsla(${hue}, 85%, 72%, 0.75)`;
    };

    // ── Init after DOM + fetch ──
    document.addEventListener("DOMContentLoaded", async () => {
      const wordSets = await fetchCrosswordData();
      let currentWordSetIndex = 0;

      let state = {
        difficulty: "easy",
        grid: [],
        size: 8,
        selectedCells: [],
        foundWords: [],
        isDragging: false,
        showSolution: false,
        solutions: [],
        clickCount: 0,
        matchedCells: new Map(),
        currentWordSet: wordSets[0],
        solutionColors: new Map(),
        wordColors: new Map()
      };

      // ── Grid generation ──
      function generateRandomLetter() {
        return String.fromCharCode(65 + Math.floor(Math.random() * 26));
      }

      function getWordDirection(cells) {
        const [r1, c1] = cells[0];
        const [r2, c2] = cells[cells.length - 1];
        return r1 === r2 ? "horizontal" : c1 === c2 ? "vertical" : "diagonal";
      }

      function isValidLine(cells) {
        if (cells.length < 2) return true;
        const [r1, c1] = cells[0];
        const [r2, c2] = cells[1];
        const dr = r2 - r1,
          dc = c2 - c1;
        if (Math.abs(dr) > 1 || Math.abs(dc) > 1 || (dr === 0 && dc === 0)) return false;
        for (let i = 2; i < cells.length; i++) {
          if (cells[i][0] !== r1 + dr * i || cells[i][1] !== c1 + dc * i) return false;
        }
        return true;
      }

      function canPlaceWord(grid, word, row, col, dr, dc) {
        const last_r = row + dr * (word.length - 1);
        const last_c = col + dc * (word.length - 1);
        if (last_r < 0 || last_r >= state.size || last_c < 0 || last_c >= state.size) return false;
        for (let i = 0; i < word.length; i++) {
          const cur = grid[row + dr * i][col + dc * i];
          if (cur !== "" && cur !== word[i]) return false;
        }
        return true;
      }

      function placeWord(grid, word) {
        const directions = [
          [0, 1],
          [1, 0],
          [1, 1],
          [1, -1]
        ];
        for (let attempt = 0; attempt < 200; attempt++) {
          const [dr, dc] = directions[Math.floor(Math.random() * directions.length)];
          const row = Math.floor(Math.random() * state.size);
          const col = Math.floor(Math.random() * state.size);
          if (canPlaceWord(grid, word, row, col, dr, dc)) {
            const wordCells = [];
            for (let i = 0; i < word.length; i++) {
              const r = row + dr * i,
                c = col + dc * i;
              grid[r][c] = word[i];
              wordCells.push([r, c]);
            }
            return { placed: true, cells: wordCells, direction: getWordDirection(wordCells) };
          }
        }
        return { placed: false, cells: [], direction: null };
      }

      function generatePuzzleWithCurrentWordSet() {
        state.size = 8;

        // Build empty grid
        const newGrid = [];
        for (let i = 0; i < state.size; i++) {
          newGrid.push([]);
          for (let j = 0; j < state.size; j++) {
            newGrid[i].push("");
          }
        }

        const words = state.currentWordSet[state.difficulty];
        console.log("Generating puzzle with words:", words);

        state.solutions = [];
        state.wordColors.clear();
        state.matchedCells.clear();
        state.solutionColors.clear();

        words.forEach((word) => {
          const result = placeWord(newGrid, word);
          if (result.placed) {
            state.solutions.push({ word, cells: result.cells, direction: result.direction });
            state.solutionColors.set(word, getRandomColor());
          } else {
            console.warn("Could not place word:", word);
          }
        });

        // Fill empty cells
        for (let i = 0; i < state.size; i++) {
          for (let j = 0; j < state.size; j++) {
            if (newGrid[i][j] === "") newGrid[i][j] = generateRandomLetter();
          }
        }

        state.grid = newGrid;
        state.foundWords = [];
        state.showSolution = false;
        state.selectedCells = [];
        state.clickCount = 0;

        console.log("Grid generated:", state.grid.length, "rows");
        updateDOM();
      }

      function generateNewPuzzle() {
        currentWordSetIndex = (currentWordSetIndex + 1) % wordSets.length;
        state.currentWordSet = wordSets[currentWordSetIndex];
        generatePuzzleWithCurrentWordSet();
      }

      function generateRandomColors() {
        state.solutionColors.clear();
        const palette = [
          "hsla(10,90%,75%,.75)",
          "hsla(40,90%,75%,.75)",
          "hsla(120,90%,75%,.75)",
          "hsla(180,90%,75%,.75)",
          "hsla(210,90%,75%,.75)",
          "hsla(270,90%,75%,.75)",
          "hsla(300,90%,75%,.75)",
          "hsla(330,90%,75%,.75)",
          "hsla(150,90%,75%,.75)"
        ];
        let idx = 0;
        state.solutions.forEach((s) => state.solutionColors.set(s.word, palette[idx++ % palette.length]));
      }

      function isValidNextCell(a, b) {
        return Math.abs(a[0] - b[0]) <= 1 && Math.abs(a[1] - b[1]) <= 1;
      }

      function checkForWord(selection) {
        if (selection.length < 3) return false;
        if (!isValidLine(selection)) return false;
        const word = selection.map(([r, c]) => state.grid[r][c]).join("");
        const rev = word.split("").reverse().join("");
        const list = state.currentWordSet[state.difficulty];
        let found = null;
        if (list.includes(word) && !state.foundWords.includes(word)) found = word;
        else if (list.includes(rev) && !state.foundWords.includes(rev)) found = rev;
        if (found) {
          state.foundWords.push(found);
          if (!state.wordColors.has(found))
            state.wordColors.set(found, colorClasses[state.wordColors.size % colorClasses.length]);
          state.matchedCells.set(found, [...selection]);
          return true;
        }
        return false;
      }

      function getCellCoords(el) {
        if (!el?.dataset?.coords) return null;
        return el.dataset.coords.split("-").map(Number);
      }

      // ── DOM update ──
      function updateDOM() {
        const gridEl = document.getElementById("grid");

        // Only set display — let CSS handle grid-template-columns
        // (inline gridTemplateColumns overrides the CSS custom-property-based mobile layout)
        gridEl.style.display = "grid";

        gridEl.innerHTML = "";

        state.grid.forEach((row, i) => {
          row.forEach((letter, j) => {
            const cell = document.createElement("div");
            cell.className = "cell";
            cell.textContent = letter;
            cell.dataset.coords = `${i}-${j}`;

            // Selected
            if (state.selectedCells.some(([r, c]) => r === i && c === j)) cell.classList.add("selected");

            // Matched word color
            for (const [word, cells] of state.matchedCells.entries()) {
              if (cells.some(([r, c]) => r === i && c === j)) {
                cell.classList.add("match");
                const cc = state.wordColors.get(word);
                if (cc) cell.classList.add(cc);
                break;
              }
            }

            // Solution hint
            if (state.showSolution) {
              for (const sol of state.solutions) {
                if (sol.cells.some(([r, c]) => r === i && c === j)) {
                  const sc = state.solutionColors.get(sol.word);
                  if (sc) cell.style.backgroundColor = sc;
                  break;
                }
              }
            }

            gridEl.appendChild(cell);
          });
        });

        document.getElementById("clickCount").textContent = state.clickCount;
        document.getElementById("foundCount").textContent = state.foundWords.length;
        document.getElementById("totalWords").textContent = state.currentWordSet[state.difficulty].length;

        document.getElementById("wordList").innerHTML = state.currentWordSet[state.difficulty]
          .map((word) => {
            const found = state.foundWords.includes(word);
            const cc = state.wordColors.get(word) || "";
            const sc = state.showSolution ? state.solutionColors.get(word) : null;
            const style = sc ? `style="background-color:${sc};"` : "";
            return `<span class="word ${found ? "found " + cc : ""}" ${style}>${word}</span>`;
          })
          .join("");

        document.getElementById("solutionBtn").classList.toggle("active", state.showSolution);
      }

      // ── Event handlers ──
      const gridEl = document.getElementById("grid");

      gridEl.addEventListener("mousedown", (e) => {
        const coords = getCellCoords(e.target);
        if (!coords) return;
        state.isDragging = true;
        state.selectedCells = [coords];
        state.clickCount++;
        updateDOM();
      });

      gridEl.addEventListener("mousemove", (e) => {
        if (!state.isDragging) return;
        const coords = getCellCoords(e.target);
        if (!coords) return;
        const last = state.selectedCells[state.selectedCells.length - 1];
        if (!last || !isValidNextCell(last, coords)) return;
        if (!state.selectedCells.some(([r, c]) => r === coords[0] && c === coords[1])) {
          state.selectedCells.push(coords);
          updateDOM();
        }
      });

      document.addEventListener("mouseup", () => {
        if (!state.isDragging) return;
        state.isDragging = false;
        if (!checkForWord(state.selectedCells)) state.selectedCells = [];
        updateDOM();
      });

      gridEl.addEventListener(
        "touchstart",
        (e) => {
          e.preventDefault();
          const t = e.touches[0];
          const el = document.elementFromPoint(t.clientX, t.clientY);
          const coords = getCellCoords(el);
          if (!coords) return;
          state.isDragging = true;
          state.selectedCells = [coords];
          state.clickCount++;
          updateDOM();
        },
        { passive: false }
      );

      gridEl.addEventListener(
        "touchmove",
        (e) => {
          e.preventDefault();
          if (!state.isDragging) return;
          const t = e.touches[0];
          const el = document.elementFromPoint(t.clientX, t.clientY);
          const coords = getCellCoords(el);
          if (!coords) return;
          const last = state.selectedCells[state.selectedCells.length - 1];
          if (!last || !isValidNextCell(last, coords)) return;
          if (!state.selectedCells.some(([r, c]) => r === coords[0] && c === coords[1])) {
            state.selectedCells.push(coords);
            updateDOM();
          }
        },
        { passive: false }
      );

      gridEl.addEventListener(
        "touchend",
        (e) => {
          e.preventDefault();
          if (!state.isDragging) return;
          state.isDragging = false;
          if (!checkForWord(state.selectedCells)) state.selectedCells = [];
          updateDOM();
        },
        { passive: false }
      );

      document.getElementById("level").addEventListener("change", (e) => {
        state.difficulty = e.target.value;
        generatePuzzleWithCurrentWordSet();
      });

      document.getElementById("new").addEventListener("click", generateNewPuzzle);
      document.getElementById("shuffle").addEventListener("click", generatePuzzleWithCurrentWordSet);

      document.getElementById("solutionBtn").addEventListener("click", () => {
        generateRandomColors();
        state.showSolution = !state.showSolution;
        updateDOM();
      });

      document.getElementById("clear").addEventListener("click", () => {
        state.selectedCells = [];
        state.foundWords = [];
        state.matchedCells.clear();
        state.wordColors.clear();
        state.isDragging = false;
        updateDOM();
      });

      document.getElementById("s-new")?.addEventListener("click", generateNewPuzzle);
      document.getElementById("s-shuffle")?.addEventListener("click", generatePuzzleWithCurrentWordSet);

      // ── Start ──
      generatePuzzleWithCurrentWordSet();
    });
  </script>
</div>
