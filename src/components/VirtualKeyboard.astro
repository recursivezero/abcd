---
// VirtualKeyboard.astro
// - Sirf touch device (mobile/tablet) pe show hoga, desktop pe NAHI
// - Shift toggle: lowercase ↔ UPPERCASE
// - Arrow row removed
// - Light/Dark mode auto + manual [data-theme]
// - Drag handle se resize
---

<div id="vk-container" class="vk-container" style="display:none;">
  <div class="vk-resize-handle" id="vk-resize-handle">
    <div class="vk-handle-bar"></div>
  </div>
  <div class="vk-keyboard" id="vk-keyboard">
    <div class="vk-row" id="vk-r0"></div>
    <div class="vk-row" id="vk-r1"></div>
    <div class="vk-row" id="vk-r2"></div>
    <div class="vk-row" id="vk-r3"></div>
  </div>
</div>

<script is:inline>
  (function () {
    // ── Layout: arrow row removed ──
    const VK_LAYOUT = [
      ["1", "2", "3", "4", "5", "6", "7", "8", "9", "0"],
      ["Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P"],
      ["A", "S", "D", "F", "G", "H", "J", "K", "L"],
      ["\u21e7", "Z", "X", "C", "V", "B", "N", "M", "\u232b"]
    ];

    const SHIFT_KEY = "\u21e7"; // ⇧
    const BACK_KEY = "\u232b"; // ⌫

    let isCaps = false; // shift state

    // ── Scale ──
    let vkScale = parseFloat(localStorage.getItem("vk-scale") || "1");

    function applyScale() {
      const base = Math.min((window.innerWidth - 32) / 11, 46);
      const ks = Math.round(base * vkScale);
      const gap = Math.max(4, Math.round(ks * 0.12));
      const h = Math.round(ks * 1.05);
      const fs = Math.max(11, Math.round(ks * 0.42));
      const root = document.documentElement;
      root.style.setProperty("--vk-key-w", ks + "px");
      root.style.setProperty("--vk-key-h", h + "px");
      root.style.setProperty("--vk-gap", gap + "px");
      root.style.setProperty("--vk-fz", fs + "px");
      root.style.setProperty("--vk-fz-sm", Math.max(10, fs - 2) + "px");
    }

    // ── Update all letter buttons to current case ──
    function updateCase() {
      document.querySelectorAll(".vk-key[data-letter]").forEach((btn) => {
        btn.textContent = isCaps ? btn.dataset.letter.toUpperCase() : btn.dataset.letter.toLowerCase();
      });
      // Shift button highlight
      const shiftBtn = document.querySelector(".vk-key.vk-shift");
      if (shiftBtn) shiftBtn.classList.toggle("vk-shift-on", isCaps);
    }

    function buildVK() {
      VK_LAYOUT.forEach((row, ri) => {
        const cont = document.getElementById("vk-r" + ri);
        if (!cont) return;
        cont.innerHTML = "";

        row.forEach((k) => {
          const btn = document.createElement("button");
          const isShift = k === SHIFT_KEY;
          const isBack = k === BACK_KEY;
          const isLetter = /^[A-Z]$/.test(k);
          const isNum = /^[0-9]$/.test(k);

          // Classes
          let cls = "vk-key";
          if (isShift || isBack) cls += " vk-fn";
          if (isShift) cls += " vk-shift";
          btn.className = cls;
          btn.setAttribute("type", "button");

          // Store original letter for case toggling
          if (isLetter) {
            btn.dataset.letter = k;
            btn.textContent = isCaps ? k.toUpperCase() : k.toLowerCase();
          } else {
            btn.textContent = k;
          }

          btn.addEventListener("pointerdown", (e) => {
            e.preventDefault();

            if (isShift) {
              // Toggle caps
              isCaps = !isCaps;
              updateCase();
              return;
            }

            btn.classList.add("vk-pressed");
            setTimeout(() => btn.classList.remove("vk-pressed"), 120);

            let realKey;
            if (isBack) {
              realKey = "Backspace";
            } else if (isLetter) {
              realKey = isCaps ? k.toUpperCase() : k.toLowerCase();
            } else {
              realKey = k;
            }

            document.dispatchEvent(new CustomEvent("virtualKeyPress", { detail: { key: realKey } }));
            document.dispatchEvent(new KeyboardEvent("keydown", { key: realKey, bubbles: true, cancelable: true }));
            document.dispatchEvent(new KeyboardEvent("keyup", { key: realKey, bubbles: true, cancelable: true }));
          });

          cont.appendChild(btn);
        });
      });

      applyScale();
      updateCase();
    }

    // ── Resize handle ──
    function initResize() {
      const handle = document.getElementById("vk-resize-handle");
      if (!handle) return;
      let startY = 0,
        startScale = 1;

      handle.addEventListener("pointerdown", (e) => {
        e.preventDefault();
        startY = e.clientY;
        startScale = vkScale;
        handle.setPointerCapture(e.pointerId);
      });
      handle.addEventListener("pointermove", (e) => {
        if (e.buttons === 0) return;
        const delta = startY - e.clientY;
        vkScale = Math.min(1.6, Math.max(0.6, startScale + delta / 120));
        localStorage.setItem("vk-scale", vkScale.toFixed(3));
        applyScale();
      });
    }

    let vkBuilt = false;

    // ── Should keyboard be visible right now? ──
    function shouldShowKbd() {
      const isNarrow = window.innerWidth <= 1024;
      const isMobileUA = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
      const hasCoarse = window.matchMedia("(pointer: coarse)").matches;
      return isNarrow || isMobileUA || hasCoarse;
    }

    // ── Show or hide based on current state ──
    function syncKeyboard() {
      const container = document.getElementById("vk-container");
      if (!container) return;

      if (shouldShowKbd()) {
        if (!vkBuilt) {
          buildVK();
          initResize();
          vkBuilt = true;
        }
        container.style.display = "flex";
        applyScale();
      } else {
        container.style.display = "none";
      }
    }

    // ── Listen to resize continuously ──
    window.addEventListener("resize", syncKeyboard);

    // ── First run ──
    syncKeyboard();
    document.addEventListener("astro:page-load", () => {
      vkBuilt = false; // page change pe rebuild
      syncKeyboard();
    });
  })();
</script>

<style is:global>
  /* ── JS-driven size vars (fallback) ── */
  :root {
    --vk-key-w: 38px;
    --vk-key-h: 40px;
    --vk-gap: 5px;
    --vk-fz: 16px;
    --vk-fz-sm: 13px;
    --vk-radius: 9px;
    --vk-font: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
  }

  /* ── LIGHT MODE (default) ── */
  :root {
    --vk-bg: #d1d5db;
    --vk-border-top: #b0b4bb;
    --vk-shadow-box: 0 -2px 8px rgba(0, 0, 0, 0.12);
    --vk-key-bg: #ffffff;
    --vk-key-color: #000000;
    --vk-key-shadow: #8a9099;
    --vk-fn-bg: #adb5bd;
    --vk-fn-color: #000000;
    --vk-fn-shadow: #7a8088;
    --vk-shift-on-bg: #4a9eff;
    --vk-handle-bar: rgba(0, 0, 0, 0.25);
    --vk-accent: #1a6bbf;
  }

  /* ── DARK MODE — system ── */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      --vk-bg: #1a1a1a;
      --vk-border-top: #2e2e2e;
      --vk-shadow-box: 0 -4px 20px rgba(0, 0, 0, 0.7);
      --vk-key-bg: #2c2c2e;
      --vk-key-color: #ffffff;
      --vk-key-shadow: #000000;
      --vk-fn-bg: #1c1c1e;
      --vk-fn-color: #ffffff;
      --vk-fn-shadow: #000000;
      --vk-shift-on-bg: #3a8ef6;
      --vk-handle-bar: rgba(255, 255, 255, 0.25);
      --vk-accent: #3a8ef6;
    }
  }

  /* ── DARK MODE — manual ── */
  [data-theme="dark"] {
    --vk-bg: #1a1a1a;
    --vk-border-top: #2e2e2e;
    --vk-shadow-box: 0 -4px 20px rgba(0, 0, 0, 0.7);
    --vk-key-bg: #2c2c2e;
    --vk-key-color: #ffffff;
    --vk-key-shadow: #000000;
    --vk-fn-bg: #1c1c1e;
    --vk-fn-color: #ffffff;
    --vk-fn-shadow: #000000;
    --vk-shift-on-bg: #3a8ef6;
    --vk-handle-bar: rgba(255, 255, 255, 0.25);
    --vk-accent: #3a8ef6;
  }

  /* ── CONTAINER ── */
  .vk-container {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    flex-direction: column;
    align-items: center;
    padding: 0 6px 14px;
    background: var(--vk-bg);
    border-top: 1px solid var(--vk-border-top);
    box-shadow: var(--vk-shadow-box);
    user-select: none;
    -webkit-user-select: none;
    box-sizing: border-box;
    transition: background 0.2s;
  }

  /* ── RESIZE HANDLE ── */
  .vk-resize-handle {
    width: 100%;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: ns-resize;
    touch-action: none;
    flex-shrink: 0;
  }
  .vk-handle-bar {
    width: 40px;
    height: 4px;
    border-radius: 2px;
    background: var(--vk-handle-bar);
    transition:
      background 0.2s,
      width 0.15s;
  }
  .vk-resize-handle:active .vk-handle-bar {
    width: 60px;
    background: var(--vk-accent);
  }

  /* ── KEYBOARD WRAPPER ── */
  .vk-keyboard {
    display: flex;
    flex-direction: column;
    gap: var(--vk-gap);
    width: 100%;
    max-width: 560px;
    align-items: center;
  }

  /* ── ROW ── */
  .vk-row {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    gap: var(--vk-gap);
    width: 100%;
  }

  /* ── BASE KEY ── */
  .vk-key {
    flex: 0 0 var(--vk-key-w);
    width: var(--vk-key-w);
    height: var(--vk-key-h);
    min-width: 0;
    background: var(--vk-key-bg);
    color: var(--vk-key-color);
    border: none;
    border-radius: var(--vk-radius);
    font-size: var(--vk-fz);
    font-weight: 400;
    font-family: var(--vk-font);
    letter-spacing: 0.01em;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 1px 0 0.5px var(--vk-key-shadow);
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    transition:
      transform 0.07s ease,
      opacity 0.07s ease;
    position: relative;
    overflow: hidden;
  }

  .vk-key::before {
    content: "";
    position: absolute;
    inset: 0 0 55% 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.07) 0%, transparent 100%);
    border-radius: var(--vk-radius) var(--vk-radius) 0 0;
    pointer-events: none;
  }

  /* ── FUNCTION KEYS (Shift, Backspace) ── */
  .vk-key.vk-fn {
    flex: 0 0 calc(var(--vk-key-w) * 1.45);
    width: calc(var(--vk-key-w) * 1.45);
    font-size: var(--vk-fz-sm);
    background: var(--vk-fn-bg);
    color: var(--vk-fn-color);
    box-shadow: 0 1px 0 0.5px var(--vk-fn-shadow);
  }

  /* ── SHIFT key: default = accent color icon ── */
  .vk-key.vk-shift {
    color: var(--vk-accent);
    font-size: calc(var(--vk-fz-sm) * 1.1);
    transition:
      background 0.15s,
      color 0.15s,
      transform 0.07s,
      opacity 0.07s;
  }

  /* ── SHIFT ON: blue filled background ── */
  .vk-key.vk-shift.vk-shift-on {
    background: var(--vk-shift-on-bg);
    color: #ffffff;
    box-shadow: 0 1px 0 0.5px rgba(0, 0, 0, 0.4);
  }

  /* ── PRESS FEEDBACK ── */
  .vk-key:active,
  .vk-key.vk-pressed {
    transform: scale(0.88);
    opacity: 0.72;
    box-shadow: none;
  }

  /* ── PAGE BOTTOM PADDING ── */
  @media (max-width: 1024px) {
    body:has(#vk-container[style*="flex"]) .draw-wrapper,
    body:has(#vk-container[style*="flex"]) .container__main,
    body:has(#vk-container[style*="flex"]) .container__english,
    body:has(#vk-container[style*="flex"]) .container__reader,
    body:has(#vk-container[style*="flex"]) .tv {
      padding-bottom: 260px !important;
    }
  }
</style>
