---
import KeyboardIcon from "@/assets/icons/KeyboardIcon.svg";
---

<button id="keyboard-trigger" class="show_on_touch" aria-label="Toggle virtual keyboard">
  <KeyboardIcon />
</button>

<style>
  @media (hover: none), (pointer: coarse) {
    .show_on_touch {
      display: flex !important;
    }
  }

  #keyboard-trigger {
    background-color: transparent;
    color: var(--primary);
    border: 1px solid var(--primary);
    border-radius: 50%;
    width: 49px;
    height: 49px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease-in-out;
  }

  @media (max-width: 640px) {
    #keyboard-trigger {
      width: 32px !important;
      height: 32px !important;
      min-width: 32px !important;
      min-height: 32px !important;
      padding: 0 !important;
    }

    #keyboard-trigger svg {
      width: 16px !important;
      height: 16px !important;
    }
  }
  #keyboard-trigger:hover {
    transform: translateY(-2px);
  }

  #keyboard-trigger.active {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 12px rgba(0, 0, 0, 0.2);
    color: #ffc0cb;
  }
</style>

<script is:inline>
  const showOnTouchElement = document.querySelector(".show_on_touch");
  const isTouchDevice = window.matchMedia("(hover: none), (pointer: coarse)").matches;
  showOnTouchElement.style.display = isTouchDevice ? "flex" : "none";

  const keyboardTrigger = document.getElementById("keyboard-trigger");

  if (keyboardTrigger) {
    keyboardTrigger.addEventListener("click", () => {
      // VirtualKeyboard ka toggle button click karo
      const vkToggleBtn = document.getElementById("vk-toggle-btn");
      if (vkToggleBtn) {
        vkToggleBtn.dispatchEvent(new PointerEvent("pointerdown", { bubbles: true }));
      }

      // Active state sync karo
      const vkContainer = document.getElementById("vk-container");
      const isVisible = vkContainer && vkContainer.style.display === "flex";
      if (isVisible) {
        keyboardTrigger.classList.remove("active");
        keyboardTrigger.setAttribute("aria-pressed", "false");
      } else {
        keyboardTrigger.classList.add("active");
        keyboardTrigger.setAttribute("aria-pressed", "true");
      }
    });
  }
</script>
