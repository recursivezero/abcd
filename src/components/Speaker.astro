---

<style is:inline>
  .speaker-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
  }

  #voice-dropdown {
    width: max-content;
    height: 36px;
    font-size: 0.85rem;
    padding: 0 0.5rem;
    border-radius: 100px;
    border: 1px solid var(--primary);
    background: transparent;
    color: var(--primary);
    cursor: pointer;
  }

  .mute-button {
    background: var(--color-bg-secondary);
    color: #ffffff;
    border: 1px solid var(--primary);
    border-radius: 100px;
    cursor: pointer;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .mute-button:hover,
  .mute-button[aria-pressed="true"] {
    color: var(--primary);
  }
  .mute-icon {
    font-size: 1.3rem;
  }

  @media (max-width: 640px) {
    .mute-button {
      width: 32px !important;
      height: 32px !important;
      padding: 0 !important;
      min-width: 32px !important;
      min-height: 32px !important;
    }

    .mute-icon {
      font-size: 1rem !important;
    }
  }
</style>

<div class="speaker-controls">
  <select id="voice-dropdown">
    <option selected disabled>Select Voice</option>
    <option value="mudra">Mudra</option>
    <option value="rutvi">Rutvi</option>
  </select>

  <button type="button" class="mute-button" id="mute-button" aria-pressed="false" title="Mute">
    <span class="mute-icon">🔊</span>
  </button>
</div>

<script is:inline>
  let currentAudio = null;
  let isMuted = false;

  document.addEventListener("DOMContentLoaded", () => {
    const voicesSelection = document.getElementById("voice-dropdown");
    const muteBtn = document.getElementById("mute-button");
    const muteIcon = muteBtn.querySelector(".mute-icon");

    let currentVoice = "";
    const stopAudio = () => {
      if (currentAudio) {
        currentAudio.pause();
        currentAudio = null;
      }
    };

    window.playLetterSound = (letter) => {
      if (isMuted || !currentVoice) return;

      stopAudio();

      try {
        currentAudio = new Audio(`/assets/media/alphabets/${currentVoice}/${letter.toLowerCase()}.ogg`);
        currentAudio.play().catch((e) => console.log("Audio play failed:", e));
      } catch (error) {
        console.error("Error playing sound:", error);
      }
    };

    // Mute toggle
    muteBtn.addEventListener("click", () => {
      isMuted = !isMuted;
      muteIcon.textContent = isMuted ? "🔇" : "🔊";
      muteBtn.setAttribute("aria-pressed", isMuted);

      if (isMuted) {
        stopAudio();
      }
    });

    voicesSelection.addEventListener("change", (e) => {
      currentVoice = e.target.value;
    });
  });
</script>
