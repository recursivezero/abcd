---
// ThemeProvider.astro
---

<script is:inline>
  const sunIcon =
    '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
  const moonIcon = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';

  /* ── Apply theme ── */
  function applyTheme(theme) {
    const html = document.documentElement;

    // 1. Set data-theme
    html.setAttribute("data-theme", theme);
    html.classList.toggle("dark", theme === "dark");

    // 2. Directly set html background — CSS layer ko bypass karta hai
    if (theme === "dark") {
      html.style.backgroundColor = "#020608";
      html.style.backgroundImage = "linear-gradient(180deg, #020608 0%, #031a20 50%, #052e38 100%)";
      html.style.backgroundAttachment = "fixed";
      html.style.backgroundSize = "cover";
    } else {
      html.style.backgroundColor = "#ffffff";
      html.style.backgroundImage = "none";
      html.style.backgroundAttachment = "";
      html.style.backgroundSize = "";
    }

    // 3. Body transparent rakho
    if (document.body) {
      document.body.style.backgroundColor = "transparent";
      document.body.style.backgroundImage = "none";
    }

    // 4. Icon update
    const icon = document.getElementById("themeIcon");
    if (icon) icon.innerHTML = theme === "dark" ? sunIcon : moonIcon;
  }

  function getSavedTheme() {
    return localStorage.getItem("theme") || "light";
  }

  function toggleTheme() {
    const next = getSavedTheme() === "dark" ? "light" : "dark";
    localStorage.setItem("theme", next);
    applyTheme(next);
  }

  function attachToggle() {
    const btn = document.getElementById("headerThemeToggle");
    if (!btn) return;
    const newBtn = btn.cloneNode(true);
    btn.replaceWith(newBtn);
    newBtn.addEventListener("click", toggleTheme);
  }

  function init() {
    applyTheme(getSavedTheme());
    attachToggle();
  }

  // Immediately — no flash
  (function () {
    applyTheme(getSavedTheme());
  })();

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:after-swap", () => applyTheme(getSavedTheme()));
</script>
