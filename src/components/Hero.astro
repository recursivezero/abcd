---
interface Props {
  appName?: string;
}
const { appName } = Astro.props;

const ageGroups = [
  {
    icon: "🧸",
    label: "Toddlers",
    range: "1–3 Years",
    color: "#EDE9FE",
    darkColor: "#3b1f6e",
    explore: "#7C3AED",
    href: "/games/3-5"
  },
  {
    icon: "🏠",
    label: "Preschoolers",
    range: "3–5 Years",
    color: "#FEF9C3",
    darkColor: "#4a3a00",
    explore: "#D97706",
    href: "/games/3-5"
  },
  {
    icon: "🎨",
    label: "Early Learners",
    range: "5–8 Years",
    color: "#DCFCE7",
    darkColor: "#0f3d20",
    explore: "#16A34A",
    href: "/games/6-8"
  },
  {
    icon: "💡",
    label: "Kids",
    range: "8–12 Years",
    color: "#DBEAFE",
    darkColor: "#1e3a6e",
    explore: "#2563EB",
    href: "/games/9-12"
  },
  {
    icon: "🎮",
    label: "Teens",
    range: "12+ Years",
    color: "#FCE7F3",
    darkColor: "#4a1030",
    explore: "#DB2777",
    href: "/games/teens"
  },
  {
    icon: "👨‍👩‍👧‍👦",
    label: "Family",
    range: "All Ages",
    color: "#FFF0E0",
    darkColor: "#4a2a00",
    explore: "#EA6C00",
    href: "/games/adults"
  }
];
---

<section class="hero-section">
  <img src="/assets/images/kids-hero1.png" alt="Kids learning together" class="hero-bg-img" loading="eager" />
</section>

<section class="age-section">
  <h2 class="age-title">
    <span>🎀</span>
    Explore by Age Group
    <span>🎀</span>
  </h2>
  <div class="age-grid">
    {
      ageGroups.map((group) => (
        <a href={group.href} class="age-card" style={`--card-bg: ${group.color}; --card-bg-dark: ${group.darkColor};`}>
          <span class="age-icon">{group.icon}</span>
          <h3 class="age-label" style={`color: ${group.explore};`}>
            {group.label}
          </h3>
          <p class="age-range" style={`color: ${group.explore};`}>
            {group.range}
          </p>
          <span class="age-explore" style={`color: ${group.explore};`}>
            Explore →
          </span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .hero-section {
    width: 100%;
    overflow: hidden;
    line-height: 0;
    position: relative;
  }

  .hero-bg-img {
    width: 100%;
    height: auto;
    display: block;
    opacity: 1;
    transition: filter 0.3s ease;
  }

  /* Dark mode: slight cool overlay via filter, no opacity dimming */
  :global([data-theme="dark"]) .hero-bg-img {
    filter: brightness(0.85) saturate(0.9);
  }

  /* ── Age Section ── */
  .age-section {
    padding: 3rem 2rem 4rem;
    text-align: center;
    background: transparent;
  }

  .age-title {
    font-size: 1.85rem;
    font-weight: 900;
    color: #1a3353;
    margin-bottom: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
  }

  :global([data-theme="dark"]) .age-title {
    color: #e0f7fa;
  }

  .age-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .age-card {
    background: var(--card-bg);
    border-radius: 1.4rem;
    padding: 1.8rem 1rem 1.4rem;
    text-align: center;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.07);
  }

  :global([data-theme="dark"]) .age-card {
    background: var(--card-bg-dark);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(34, 211, 238, 0.15);
  }

  .age-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.13);
  }

  :global([data-theme="dark"]) .age-card:hover {
    box-shadow: 0 0 20px rgba(34, 211, 238, 0.2);
    border-color: rgba(34, 211, 238, 0.4);
  }

  .age-icon {
    font-size: 2.8rem;
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .age-label {
    font-size: 1.05rem;
    font-weight: 800;
    margin: 0;
  }
  .age-range {
    font-size: 0.88rem;
    font-weight: 600;
    margin: 0;
  }
  .age-explore {
    font-size: 0.95rem;
    font-weight: 700;
    margin-top: 0.4rem;
  }

  @media (max-width: 1024px) {
    .age-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .age-section {
      padding: 2rem 1rem 3rem;
    }
    .age-title {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .age-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    .age-card {
      padding: 1.4rem 0.75rem 1.1rem;
    }
    .age-icon {
      font-size: 2.2rem;
    }
    .age-label {
      font-size: 0.95rem;
    }
    .age-range {
      font-size: 0.8rem;
    }
    .age-explore {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .age-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.6rem;
    }
    .age-card {
      padding: 1.2rem 0.6rem 1rem;
      border-radius: 1rem;
    }
    .age-icon {
      font-size: 2rem;
    }
    .age-label {
      font-size: 0.88rem;
    }
  }
</style>
