---
import ThemeProvider from "@/components/ThemeProvider.astro";
import BaseHead from "@/layouts/BaseHead";
import Footer from "@/layouts/common/Footer";
import Header from "@/layouts/common/Header.astro";
import Menu from "@/layouts/common/Menu";
import { siteConfig } from "@/site-config";

const {
  meta: { title, description = siteConfig.description, ogImage },
  sidebar = true
} = Astro.props;
---

<html lang={siteConfig.lang}>
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body id="body" class="body__container">
    <ThemeProvider />
    <Header title={title}>
      <slot name="header-left" slot="left" />
      <slot name="header-right" slot="right" />
    </Header>
    <main id="main" class="main">
      {
        sidebar && (
          <div class="sidebar" id="sidebar">
            {/* PIN BUTTON — desktop only, sidebar ke andar top-right */}
            <button class="pin-btn" id="pinBtn" aria-label="Pin sidebar" title="Sidebar pin karo">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="12" y1="17" x2="12" y2="22" />
                <path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z" />
              </svg>
            </button>
            <Menu />
          </div>
        )
      }
      {
        sidebar && (
          <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
            <span id="toggleIcon" class="toggle-icon-wrap"></span>
          </button>
        )
      }

      {/* OVERLAY — mobile pe sidebar ke bahar click karne par close */}
      <div class="sidebar-overlay" id="sidebarOverlay"></div>

      <div class="content" id="mainContent">
        <slot><p>This is my fallback content, if there is no child passed into slot</p></slot>
      </div>
    </main>

    <style is:global>
      .main {
        display: flex;
        width: 100%;
        position: relative;
      }

      /* ── SIDEBAR ── */
      .sidebar {
        position: fixed;
        top: 0;
        left: 0;

        width: 260px;
        max-width: 80vw;
        height: 100vh;

        background: var(--background);
        z-index: 1200;
        overflow-y: auto;

        transform: translateX(-100%);
        transition: transform 0.3s ease;
        box-shadow: 4px 0 20px rgba(0, 0, 0, 0.12);
        padding-top: 6rem;
      }

      /* Sidebar open (overlay mode) */
      .sidebar.open {
        transform: translateX(0);
      }

      /* Sidebar PINNED — desktop only: sidebar layout mein aa jaati hai */
      .sidebar.pinned {
        position: sticky;
        top: 0;
        transform: translateX(0);
        height: 100vh;
        flex-shrink: 0;
        box-shadow: none;
        border-right: 1px solid rgba(124, 58, 237, 0.12);
      }

      /* Content shifts right when pinned */
      .main.sidebar-pinned .content {
        margin-left: 0;
      }

      /* ── PIN BUTTON ── */
      .pin-btn {
        position: absolute;
        top: 4.2rem;
        right: 10px;

        width: 28px;
        height: 28px;

        border: 1.5px solid rgba(124, 58, 237, 0.25);
        border-radius: 8px;
        background: transparent;

        color: #7c3aed;
        display: flex;
        align-items: center;
        justify-content: center;

        cursor: pointer;
        opacity: 0.5;
        transition:
          opacity 0.2s ease,
          background 0.2s ease,
          transform 0.2s ease;
        z-index: 10;
      }

      .pin-btn:hover {
        opacity: 1;
        background: rgba(124, 58, 237, 0.08);
      }

      /* Pinned active state */
      .pin-btn.active {
        opacity: 1;
        background: rgba(124, 58, 237, 0.12);
        border-color: #7c3aed;
        transform: rotate(45deg);
      }

      /* Pin button sirf desktop pe dikhao */
      @media (max-width: 768px) {
        .pin-btn {
          display: none !important;
        }
      }

      /* ── OVERLAY ── */
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 1199;
        cursor: pointer;
      }

      .sidebar-overlay.show {
        display: block;
      }

      /* ── CONTENT ── */
      .content {
        flex: 1;
        min-width: 0;
        width: 100%;
        transition: all 0.3s ease;
      }

      /* ── TOGGLE BUTTON ── */
      .sidebar-toggle {
        position: fixed !important;

        top: 16px !important;
        left: 12px !important;

        width: 42px !important;
        height: 42px !important;

        border: none;
        border-radius: 12px;

        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);

        color: #7c3aed !important;

        display: flex !important;
        align-items: center;
        justify-content: center;

        cursor: pointer;

        z-index: 2147483647 !important;

        opacity: 1 !important;
        visibility: visible !important;
        pointer-events: auto !important;
        overflow: visible !important;

        box-shadow:
          0 6px 18px rgba(124, 58, 237, 0.16),
          0 2px 6px rgba(0, 0, 0, 0.08);

        transition:
          background 0.22s ease,
          box-shadow 0.22s ease,
          transform 0.22s ease;
      }

      .sidebar-toggle svg {
        width: 18px !important;
        height: 18px !important;
        display: block;
      }

      /* ── TOGGLE ICON WRAP ── */
      .toggle-icon-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
      }

      @media (max-width: 768px) {
        .sidebar-toggle {
          top: 14px !important;
          left: 10px !important;
          width: 40px !important;
          height: 40px !important;
          display: flex !important;
          opacity: 1 !important;
          visibility: visible !important;
          z-index: 2147483647 !important;
        }

        .sidebar {
          width: 82vw;
          max-width: 300px;
          position: fixed !important;
          top: 0 !important;
        }
      }
    </style>

    <script>
      const sidebar = document.getElementById("sidebar") as HTMLElement | null;
      const toggle = document.getElementById("sidebarToggle") as HTMLElement | null;
      const icon = document.getElementById("toggleIcon") as HTMLElement | null;
      const pinBtn = document.getElementById("pinBtn") as HTMLElement | null;
      const overlay = document.getElementById("sidebarOverlay") as HTMLElement | null;
      const mainEl = document.getElementById("main") as HTMLElement | null;

      // LocalStorage se pin state yaad rakho
      let isPinned = localStorage.getItem("sidebarPinned") === "true";

      // ── SVG ICONS ──
      const ICON_HAMBURGER = `
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
          fill="none" stroke="#7c3aed" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="9" x2="21" y2="9"></line>
          <line x1="3" y1="15" x2="21" y2="15"></line>
        </svg>`;

      const ICON_LAYOUT = `
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="16" rx="2"></rect>
          <line x1="9" y1="4" x2="9" y2="20"></line>
        </svg>`;

      const ICON_CLOSE = `
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>`;

      function isMobile() {
        return window.innerWidth <= 768;
      }

      // Closed state icon: mobile pe hamburger, desktop pe layout icon
      function setClosedIcon() {
        if (!icon) return;
        icon.innerHTML = isMobile() ? ICON_HAMBURGER : ICON_LAYOUT;
      }

      // Toggle button ko show/hide karo (inline style se — CSS se override ho sakta tha)
      function showToggle() {
        if (toggle) toggle.style.display = "flex";
      }

      function hideToggle() {
        if (toggle) toggle.style.display = "none";
      }

      function applyPinState() {
        if (!sidebar || !mainEl || !pinBtn) return;

        if (isPinned && !isMobile()) {
          // ── PINNED (desktop only) ──
          sidebar.classList.add("pinned");
          sidebar.classList.remove("open");
          mainEl.classList.add("sidebar-pinned");
          pinBtn.classList.add("active");
          if (overlay) overlay.classList.remove("show");
          // Pinned hone par toggle button hide karo
          hideToggle();
        } else {
          // ── UNPINNED ──
          sidebar.classList.remove("pinned");
          mainEl.classList.remove("sidebar-pinned");
          pinBtn.classList.remove("active");
          // Toggle wapas dikhao aur icon reset karo
          showToggle();
          setClosedIcon();
        }
      }

      function openSidebar() {
        if (!sidebar) return;
        sidebar.classList.add("open");
        // Overlay mobile pe hi dikhao
        if (isMobile() && overlay) {
          overlay.classList.add("show");
        }
        // Close icon set karo
        if (icon) icon.innerHTML = ICON_CLOSE;
      }

      function closeSidebar() {
        if (!sidebar) return;
        sidebar.classList.remove("open");
        if (overlay) overlay.classList.remove("show");
        // Closed icon restore karo (hamburger ya layout)
        setClosedIcon();
      }

      // ── PIN TOGGLE ──
      if (pinBtn) {
        pinBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          if (isMobile()) return; // mobile pe pin kaam nahi karta

          isPinned = !isPinned;
          localStorage.setItem("sidebarPinned", String(isPinned));
          applyPinState();
        });
      }

      // ── INIT ──
      if (toggle && sidebar && icon) {
        sidebar.classList.remove("open");
        setClosedIcon();
        // Page load pe pin state restore karo
        applyPinState();

        // ── TOGGLE BUTTON CLICK ──
        toggle.addEventListener("click", () => {
          // Desktop pinned mode mein toggle kuch nahi karega (button waise bhi hidden hai)
          if (isPinned && !isMobile()) return;

          const isOpen = sidebar.classList.contains("open");
          if (isOpen) {
            closeSidebar();
          } else {
            openSidebar();
          }
        });
      }

      // ── OVERLAY CLICK — sidebar close karo ──
      if (overlay) {
        overlay.addEventListener("click", () => {
          closeSidebar();
        });
      }

      // ── OUTSIDE CLICK — desktop pe sidebar close karo ──
      document.addEventListener("click", (e) => {
        if (!sidebar || !toggle) return;
        if (isPinned && !isMobile()) return;

        const target = e.target as Node;
        const clickedInsideSidebar = sidebar.contains(target);
        const clickedToggle = toggle.contains(target);

        if (!clickedInsideSidebar && !clickedToggle) {
          closeSidebar();
        }
      });

      // ── RESIZE — mobile <-> desktop switch ──
      window.addEventListener("resize", () => {
        if (isMobile()) {
          // Mobile pe: pinned state ignore, sidebar overlay mode mein
          if (sidebar) {
            sidebar.classList.remove("pinned");
          }
          if (mainEl) mainEl.classList.remove("sidebar-pinned");
          if (pinBtn) pinBtn.classList.remove("active");

          // Mobile pe toggle HAMESHA dikhna chahiye
          showToggle();

          // Agar sidebar open nahi hai to icon closed state mein rakho
          if (!sidebar?.classList.contains("open")) {
            setClosedIcon();
          }
        } else {
          // Desktop pe: pin state restore karo
          applyPinState();

          // Agar sidebar open nahi aur pinned nahi, to icon reset karo
          if (!sidebar?.classList.contains("open") && !isPinned) {
            setClosedIcon();
          }
        }
      });
    </script>

    <Footer />

    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker
          .getRegistrations()
          .then((registrations) => {
            const unregisterPromises = registrations.map(async (registration) => {
              return registration.unregister().then((success) => {
                if (success) {
                  console.log("Successfully unregistered service worker:", registration.scope);
                } else {
                  console.warn("Failed to unregister service worker:", registration.scope);
                }
                return success;
              });
            });
            return Promise.all(unregisterPromises);
          })
          .then(() => {
            if (!import.meta.env.DEV) {
              window.addEventListener("load", () => {
                navigator.serviceWorker
                  .register("/service-worker.js", { scope: "/" })
                  .then((registration) => {
                    console.log("Service Worker successfully registered:", registration.scope);
                    registration.update().then(() => {
                      console.log("Service Worker checked for updates");
                    });
                  })
                  .catch((error) => {
                    console.error("Service Worker registration failed:", error);
                  });
              });
            } else {
              console.log("Service Worker registration skipped in development mode");
            }
          })
          .catch((error) => {
            console.error("Service Worker cleanup failed:", error);
          });
      }
    </script>
  </body>
</html>