---
import ThemeProvider from "@/components/ThemeProvider.astro";
import BaseHead from "@/layouts/BaseHead";
import Footer from "@/layouts/common/Footer";
import Header from "@/layouts/common/Header.astro";
import Menu from "@/layouts/common/Menu";
import { siteConfig } from "@/site-config";

const {
  meta: { title, description = siteConfig.description, ogImage },
  sidebar = true
} = Astro.props;
---

<html lang={siteConfig.lang}>
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body id="body" class="body__container" style="overflow: visible;">
    <ThemeProvider />
    <Header title={title}>
      <slot name="header-left" slot="left" />
      <slot name="header-right" slot="right" />
    </Header>
    <main id="main" class="main">
      {
        sidebar && (
          <div class="sidebar" id="sidebar">
            <Menu />
          </div>
        )
      }

      <!-- overlay ko main ke BAHAR rakha — flex layout disturb nahi hoga -->
      <div class="sidebar-overlay" id="sidebarOverlay"></div>

      <div class="content" id="mainContent">
        <slot><p>This is my fallback content, if there is no child passed into slot</p></slot>
      </div>
    </main>

    {
      sidebar && (
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
          <span id="toggleIcon" class="toggle-icon-wrap" />
        </button>
      )
    }

    <style is:global>
      /* ── MAIN CONTAINER ── */
      .main {
        display: flex;
        width: 100%;
        position: relative;
        overflow-x: hidden !important;
        overflow-y: visible !important;
        margin-top: 0;
        gap: 0 !important;
        align-items: flex-start !important;
        min-height: auto !important;
        height: auto !important;
        background: transparent !important;
      }

      html {
        overflow-y: visible !important;
      }
      html,
      body {
        min-height: 100vh;
      }

      .body__container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ── SIDEBAR BASE — closed: zero flex width ── */
      .sidebar {
        flex: 0 0 0;
        width: 0;
        height: 0;
        min-width: 0;
        max-width: 0;
        overflow: hidden;
        margin-right: 0 !important;
        padding-right: 0 !important;
        margin-left: 0 !important;
        padding-left: 0 !important;
        border-right: none !important;
      }

      /* Sidebar OPEN */
      .sidebar.open {
        flex: 0 0 260px;
        position: relative;
        width: 260px;
        height: auto;
        max-width: 260px;
        margin-right: 0 !important;
        padding-right: 0 !important;
        padding-left: 0 !important;
        margin-left: 0 !important;
        overflow-y: auto;
        padding-top: 1rem;
        border-right: 1px solid rgba(124, 58, 237, 0.1);
        box-shadow: none !important;
      }

      .sidebar.open::-webkit-scrollbar,
      .sidebar.pinned::-webkit-scrollbar {
        width: 0;
        display: none;
      }
      .sidebar.open::-webkit-scrollbar-track,
      .sidebar.pinned::-webkit-scrollbar-track {
        background: transparent;
      }
      .sidebar.open::-webkit-scrollbar-thumb,
      .sidebar.pinned::-webkit-scrollbar-thumb {
        background: transparent;
      }

      /* Sidebar PINNED */
      .sidebar.pinned {
        flex: 0 0 260px;
        width: 260px;
        height: auto;
        max-width: 260px;
        margin-right: 0 !important;
        padding-right: 0 !important;
        padding-left: 0 !important;
        margin-left: 0 !important;
        position: relative;
        overflow-y: auto;
        padding-top: 1rem;
        border-right: 1px solid rgba(124, 58, 237, 0.1);
        box-shadow: none !important;
      }

      .sidebar.open .pin-btn,
      .sidebar.pinned .pin-btn {
        display: flex;
      }

      /* ── CONTENT  ── */
      .content {
        flex: 1;
        min-width: 0;

        min-height: auto !important;
        height: fit-content !important;

        margin: 0 !important;
        padding: 0 !important;

        background: transparent !important;
      }

      /* Dark mode fix */
      [data-theme="dark"] .main {
        background: transparent !important;
      }

      [data-theme="dark"] .content {
        background: transparent !important;
      }

      [data-theme="dark"] .sidebar {
        border-right: 1px solid rgba(255, 255, 255, 0.06);
      }

      /* ── OVERLAY — position:fixed hai, flex layout pe zero impact ── */
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 1199;
        cursor: pointer;
      }

      .sidebar-overlay.show {
        display: block;
      }

      /* ── PIN BUTTON ── */
      .pin-btn {
        position: static !important;

        width: 36px;
        height: 36px;

        display: flex;
        align-items: center;
        justify-content: center;

        border: 1.5px solid rgba(124, 58, 237, 0.25);
        border-radius: 12px;
        background: transparent;
        color: #7c3aed;

        cursor: pointer;
        margin-left: 6px;
      }
      .pin-btn:hover {
        opacity: 1;
        background: rgba(124, 58, 237, 0.08);
      }

      .pin-btn.active {
        opacity: 1;
        background: rgba(124, 58, 237, 0.12);
        border-color: #7c3aed;
        transform: rotate(45deg);
      }

      @media (max-width: 768px) {
        .pin-btn {
          display: none !important;
        }
      }

      /* ── TOGGLE BUTTON ── */
      .sidebar-toggle {
        position: fixed !important;

        left: 12px !important;
        bottom: 24px !important;

        width: 46px !important;
        height: 46px !important;

        border: none;
        border-radius: 50%;

        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);

        display: flex !important;
        align-items: center;
        justify-content: center;

        z-index: 99999 !important;

        box-shadow:
          0 6px 24px rgba(0, 0, 0, 0.12),
          0 2px 8px rgba(0, 0, 0, 0.08);

        margin: 0 !important;
        padding: 0 !important;
      }
      .sidebar-toggle:hover {
        background: rgba(124, 58, 237, 0.08) !important;
        box-shadow:
          0 8px 28px rgba(124, 58, 237, 0.28),
          0 2px 8px rgba(0, 0, 0, 0.1);
      }

      .toggle-icon-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        pointer-events: none;
      }

      .toggle-icon-wrap svg {
        width: 20px !important;
        height: 20px !important;
        display: block;
        pointer-events: none;
      }

      /* ── MOBILE OVERRIDES ── */
      @media (max-width: 768px) {
        .sidebar {
          position: fixed !important;
          top: 0 !important;
          left: 0 !important;
          flex: none !important; /* ✅ mobile pe flex layout se bahar */
          width: 0 !important;
          max-width: 0 !important;
          height: 100vh !important;
          z-index: 1200;
          overflow: hidden;
          padding-top: 0;
          transition: width 0.3s ease !important;
          box-shadow: none;
          border-right: none !important;
        }

        .sidebar.open {
          flex: none !important;
          width: 82vw !important;
          max-width: 300px !important;
          overflow-y: auto !important;
          padding-top: 1rem !important;
          box-shadow: none !important;
          scrollbar-width: none !important;
          border-right: none !important;
        }

        .sidebar.open::-webkit-scrollbar {
          width: 2px;
        }

        .sidebar.pinned {
          flex: none !important;
          width: 82vw !important;
          height: 100vh !important;
          max-width: 300px !important;
          overflow-y: auto !important;
          padding-top: 1rem !important;
          box-shadow: 4px 0 20px rgba(0, 0, 0, 0.18) !important;
          scrollbar-width: none !important;
          border-right: none !important;
        }

        .sidebar-toggle {
          bottom: 20px !important;
          left: 16px !important;
          top: auto !important;
          width: 48px !important;
          height: 48px !important;
          display: flex !important;
        }
      }
    </style>

    <script>
      const sidebar = document.getElementById("sidebar") as HTMLElement | null;
      const toggle = document.getElementById("sidebarToggle") as HTMLElement | null;
      const icon = document.getElementById("toggleIcon") as HTMLElement | null;
      const pinBtn = document.getElementById("pinBtn") as HTMLElement | null;
      const overlay = document.getElementById("sidebarOverlay") as HTMLElement | null;

      let isPinned = localStorage.getItem("sidebarPinned") === "true";

      const ICON_HAMBURGER = `
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
          fill="none" stroke="#7c3aed" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="9" x2="21" y2="9"></line>
          <line x1="3" y1="15" x2="21" y2="15"></line>
        </svg>`;

      const ICON_LAYOUT = `
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
          fill="none" stroke="#7c3aed" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="16" rx="2"></rect>
          <line x1="9" y1="4" x2="9" y2="20"></line>
        </svg>`;

      const ICON_CLOSE = `
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
          fill="none" stroke="#7c3aed" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>`;

      function isMobile() {
        return window.innerWidth <= 768;
      }

      function setClosedIcon() {
        if (!icon) return;
        icon.innerHTML = isMobile() ? ICON_HAMBURGER : ICON_LAYOUT;
      }

      function showToggle() {
        if (toggle) toggle.style.display = "flex";
      }

      function applyPinState() {
        if (!sidebar || !pinBtn) return;

        if (isPinned && !isMobile()) {
          sidebar.classList.add("pinned");
          sidebar.classList.remove("open");
          pinBtn.classList.add("active");
          if (overlay) overlay.classList.remove("show");
          showToggle();
          setClosedIcon();
        } else {
          sidebar.classList.remove("pinned");
          pinBtn.classList.remove("active");
          showToggle();
          setClosedIcon();
        }
      }

      function openSidebar() {
        if (!sidebar) return;
        sidebar.classList.add("open");
        if (isMobile() && overlay) overlay.classList.add("show");
        if (icon) icon.innerHTML = ICON_CLOSE;
      }

      function closeSidebar() {
        if (!sidebar) return;
        sidebar.classList.remove("open");
        if (overlay) overlay.classList.remove("show");
        setClosedIcon();
      }

      if (pinBtn) {
        pinBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          if (isMobile()) return;
          isPinned = !isPinned;
          localStorage.setItem("sidebarPinned", String(isPinned));
          applyPinState();
        });
      }

      if (toggle && sidebar && icon) {
        sidebar.classList.remove("open");
        setClosedIcon();
        applyPinState();

        toggle.addEventListener("click", (e) => {
          e.stopPropagation();
          if (isPinned && !isMobile()) return;
          const isOpen = sidebar.classList.contains("open");
          if (isOpen) {
            closeSidebar();
          } else {
            openSidebar();
          }
        });
      }

      if (overlay) {
        overlay.addEventListener("click", () => closeSidebar());
      }

      document.addEventListener("click", (e) => {
        if (!sidebar || !toggle) return;
        if (isPinned && !isMobile()) return;
        const target = e.target as Node;
        if (!sidebar.contains(target) && !toggle.contains(target)) {
          closeSidebar();
        }
      });

      window.addEventListener("resize", () => {
        if (isMobile()) {
          if (sidebar) sidebar.classList.remove("pinned");
          if (pinBtn) pinBtn.classList.remove("active");
          showToggle();
          if (!sidebar?.classList.contains("open")) setClosedIcon();
        } else {
          applyPinState();
          if (!sidebar?.classList.contains("open") && !isPinned) setClosedIcon();
        }
      });
    </script>
    <Footer />

    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker
          .getRegistrations()
          .then((registrations) => {
            const unregisterPromises = registrations.map(async (registration) => {
              return registration.unregister().then((success) => {
                if (success) {
                  console.log("Successfully unregistered service worker:", registration.scope);
                } else {
                  console.warn("Failed to unregister service worker:", registration.scope);
                }
                return success;
              });
            });
            return Promise.all(unregisterPromises);
          })
          .then(() => {
            if (!import.meta.env.DEV) {
              window.addEventListener("load", () => {
                navigator.serviceWorker
                  .register("/service-worker.js", { scope: "/" })
                  .then((registration) => {
                    console.log("Service Worker successfully registered:", registration.scope);
                    registration.update().then(() => {
                      console.log("Service Worker checked for updates");
                    });
                  })
                  .catch((error) => {
                    console.error("Service Worker registration failed:", error);
                  });
              });
            } else {
              console.log("Service Worker registration skipped in development mode");
            }
          })
          .catch((error) => {
            console.error("Service Worker cleanup failed:", error);
          });
      }
    </script>
  </body>
</html>
