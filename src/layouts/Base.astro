---
import ThemeProvider from "@/components/ThemeProvider.astro";
import BaseHead from "@/layouts/BaseHead";
import Footer from "@/layouts/common/Footer";
import Header from "@/layouts/common/Header.astro";
import Menu from "@/layouts/common/Menu";
import { siteConfig } from "@/site-config";

const {
  meta: { title, description = siteConfig.description, ogImage },
  sidebar = true
} = Astro.props;
---

<html lang={siteConfig.lang}>
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body id="body" class="body__container">
    <ThemeProvider />
    <Header title={title}>
      <slot name="header-left" slot="left" />
      <slot name="header-right" slot="right" />
    </Header>
    <main id="main" class="main">
      {
        sidebar && (
          <div class="sidebar" id="sidebar">
            {/* PIN BUTTON — desktop only, sidebar ke andar top-right */}
            <button class="pin-btn" id="pinBtn" aria-label="Pin sidebar" title="Sidebar pin karo">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="12" y1="17" x2="12" y2="22" />
                <path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z" />
              </svg>
            </button>
            <Menu />
          </div>
        )
      }
      {
        sidebar && (
          <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
            <span id="toggleIcon" class="mobile-menu-icon">
              <span />
              <span />
            </span>
          </button>
        )
      }

      {/* OVERLAY — mobile pe sidebar ke bahar click karne par close */}
      <div class="sidebar-overlay" id="sidebarOverlay"></div>

      <div class="content" id="mainContent">
        <slot><p>This is my fallback content, if there is no child passed into slot</p></slot>
      </div>
    </main>

    <style is:global>
      .main {
        display: flex;
        width: 100%;
        position: relative;
      }

      /* ── SIDEBAR ── */
      .sidebar {
        position: fixed;
        top: 0;
        left: 0;

        width: 260px;
        max-width: 80vw;
        height: 100vh;

        background: var(--background);
        z-index: 1200;
        overflow-y: auto;

        transform: translateX(-100%);
        transition: transform 0.3s ease;
        box-shadow: 4px 0 20px rgba(0, 0, 0, 0.12);
        padding-top: 6rem;
      }

      /* Sidebar open (overlay mode) */
      .sidebar.open {
        transform: translateX(0);
      }

      /* Sidebar PINNED — desktop only: sidebar layout mein aa jaati hai */
      .sidebar.pinned {
        position: sticky;
        top: 0;
        transform: translateX(0);
        height: 100vh;
        flex-shrink: 0;
        box-shadow: none;
        border-right: 1px solid rgba(124, 58, 237, 0.12);
      }

      /* Content shifts right when pinned */
      .main.sidebar-pinned .content {
        margin-left: 0;
      }

      /* ── PIN BUTTON ── */
      .pin-btn {
        position: absolute;
        top: 4.2rem;
        right: 10px;

        width: 28px;
        height: 28px;

        border: 1.5px solid rgba(124, 58, 237, 0.25);
        border-radius: 8px;
        background: transparent;

        color: #7c3aed;
        display: flex;
        align-items: center;
        justify-content: center;

        cursor: pointer;
        opacity: 0.5;
        transition:
          opacity 0.2s ease,
          background 0.2s ease,
          transform 0.2s ease;
        z-index: 10;
      }

      .pin-btn:hover {
        opacity: 1;
        background: rgba(124, 58, 237, 0.08);
      }

      /* Pinned active state */
      .pin-btn.active {
        opacity: 1;
        background: rgba(124, 58, 237, 0.12);
        border-color: #7c3aed;
        transform: rotate(45deg); /* pin rotates to show it's locked */
      }

      /* Pin button sirf desktop pe dikhao */
      @media (max-width: 768px) {
        .pin-btn {
          display: none !important;
        }
      }

      /* ── OVERLAY ── */
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 1199; /* sidebar ke neeche, content ke upar */
        cursor: pointer;
      }

      .sidebar-overlay.show {
        display: block;
      }

      /* ── CONTENT ── */
      .content {
        flex: 1;
        min-width: 0;
        width: 100%;
        transition: all 0.3s ease;
      }

      /* ── TOGGLE BUTTON ── */
      .sidebar-toggle {
        position: fixed !important;

        top: 16px !important;
        left: 12px !important;

        width: 42px !important;
        height: 42px !important;

        border: none;
        border-radius: 12px;

        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);

        color: #7c3aed !important;

        display: flex !important;
        align-items: center;
        justify-content: center;

        cursor: pointer;

        z-index: 2147483647 !important;

        opacity: 1 !important;
        visibility: visible !important;
        pointer-events: auto !important;
        overflow: visible !important;

        box-shadow:
          0 6px 18px rgba(124, 58, 237, 0.16),
          0 2px 6px rgba(0, 0, 0, 0.08);

        transition:
          background 0.22s ease,
          box-shadow 0.22s ease,
          transform 0.22s ease;
      }

      /* Pinned hone par toggle button hide karo (desktop) */
      .main.sidebar-pinned .sidebar-toggle {
        display: none !important;
      }

      .sidebar-toggle svg {
        width: 16px !important;
        height: 16px !important;
      }

      @media (max-width: 768px) {
        .sidebar-toggle {
          top: 14px !important;
          left: 10px !important;
          width: 40px !important;
          height: 40px !important;
          display: flex !important;
          opacity: 1 !important;
          visibility: visible !important;
          z-index: 2147483647 !important;
        }

        .sidebar {
          width: 82vw;
          max-width: 300px;
          /* Mobile pe sidebar hamesha overlay mode mein rahegi, pinned nahi */
          position: fixed !important;
          top: 0 !important;
        }

        /* Mobile pe toggle button kabhi hide mat karo */
        .main.sidebar-pinned .sidebar-toggle {
          display: flex !important;
        }
      }

      /* ── MOBILE MENU ICON ── */
      .mobile-menu-icon {
        display: flex !important;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 4px;
        width: 20px;
        height: 20px;
      }

      .mobile-menu-icon span {
        display: block !important;
        width: 18px;
        height: 2px;
        background: #7c3aed;
        border-radius: 999px;
      }
    </style>

    <script>
      const sidebar = document.getElementById("sidebar") as HTMLElement | null;
      const toggle = document.getElementById("sidebarToggle") as HTMLElement | null;
      const icon = document.getElementById("toggleIcon") as HTMLElement | null;
      const pinBtn = document.getElementById("pinBtn") as HTMLElement | null;
      const overlay = document.getElementById("sidebarOverlay") as HTMLElement | null;
      const mainEl = document.getElementById("main") as HTMLElement | null;

      // LocalStorage se pin state yaad rakho
      let isPinned = localStorage.getItem("sidebarPinned") === "true";

      const desktopIcon = `
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="16" rx="2"></rect>
          <line x1="9" y1="4" x2="9" y2="20"></line>
        </svg>
      `;

      const mobileIcon = `
        <div style="display:flex;flex-direction:column;gap:4px;align-items:center;justify-content:center;">
          <span style="width:18px;height:2px;background:#7c3aed;border-radius:999px;display:block;"></span>
          <span style="width:18px;height:2px;background:#7c3aed;border-radius:999px;display:block;"></span>
          <span style="width:18px;height:2px;background:#7c3aed;border-radius:999px;display:block;"></span>
        </div>
      `;

      function isMobile() {
        return window.innerWidth <= 768;
      }

      function setClosedIcon() {
        if (!icon) return;
        if (isMobile()) {
          icon.classList.add("mobile-menu-icon");
          icon.innerHTML = mobileIcon;
        } else {
          icon.classList.remove("mobile-menu-icon");
          icon.innerHTML = desktopIcon;
        }
      }

      function applyPinState() {
        if (!sidebar || !mainEl || !pinBtn) return;

        if (isPinned && !isMobile()) {
          sidebar.classList.add("pinned");
          sidebar.classList.remove("open");
          mainEl.classList.add("sidebar-pinned");
          pinBtn.classList.add("active");
          if (overlay) overlay.classList.remove("show");
        } else {
          sidebar.classList.remove("pinned");
          mainEl.classList.remove("sidebar-pinned");
          pinBtn.classList.remove("active");
        }
      }

      function openSidebar() {
        if (!sidebar) return;
        sidebar.classList.add("open");
        // Overlay sirf mobile pe dikhao
        if (isMobile() && overlay) {
          overlay.classList.add("show");
        }
        if (icon) {
          icon.classList.remove("mobile-menu-icon");
          icon.innerHTML = "✕";
        }
      }

      function closeSidebar() {
        if (!sidebar) return;
        sidebar.classList.remove("open");
        if (overlay) overlay.classList.remove("show");
        setClosedIcon();
      }

      // ── PIN TOGGLE ──
      if (pinBtn) {
        pinBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          if (isMobile()) return; // mobile pe pin kaam nahi karta

          isPinned = !isPinned;
          localStorage.setItem("sidebarPinned", String(isPinned));
          applyPinState();
        });
      }

      // ── SIDEBAR TOGGLE BUTTON ──
      if (toggle && sidebar && icon) {
        sidebar.classList.remove("open");
        setClosedIcon();

        // Page load pe pin state restore karo
        applyPinState();

        toggle.addEventListener("click", () => {
          if (isPinned && !isMobile()) return; // pinned hai to toggle kuch nahi karega

          const isOpen = sidebar.classList.toggle("open");

          if (isOpen) {
            openSidebar();
          } else {
            closeSidebar();
          }
        });
      }

      // ── OVERLAY CLICK — sidebar close karo ──
      if (overlay) {
        overlay.addEventListener("click", () => {
          closeSidebar();
        });
      }

      // ── OUTSIDE CLICK — desktop pe sidebar close karo ──
      document.addEventListener("click", (e) => {
        if (!sidebar || !toggle) return;
        if (isPinned && !isMobile()) return;

        const target = e.target as Node;
        const clickedInsideSidebar = sidebar.contains(target);
        const clickedToggle = toggle.contains(target);

        if (!clickedInsideSidebar && !clickedToggle) {
          closeSidebar();
        }
      });

      // ── RESIZE — mobile <-> desktop switch ──
      window.addEventListener("resize", () => {
        if (isMobile()) {
          // Mobile pe pinned state ignore karo, sidebar band karo
          if (sidebar) {
            sidebar.classList.remove("pinned");
          }
          if (mainEl) mainEl.classList.remove("sidebar-pinned");
          if (pinBtn) pinBtn.classList.remove("active");
          if (!sidebar?.classList.contains("open")) {
            setClosedIcon();
          }
        } else {
          // Desktop pe wapas aao to pin state restore karo
          applyPinState();
          if (!sidebar?.classList.contains("open") && !isPinned) {
            setClosedIcon();
          }
        }
      });
    </script>

    <Footer />

    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker
          .getRegistrations()
          .then((registrations) => {
            const unregisterPromises = registrations.map(async (registration) => {
              return registration.unregister().then((success) => {
                if (success) {
                  console.log("Successfully unregistered service worker:", registration.scope);
                } else {
                  console.warn("Failed to unregister service worker:", registration.scope);
                }
                return success;
              });
            });
            return Promise.all(unregisterPromises);
          })
          .then(() => {
            if (!import.meta.env.DEV) {
              window.addEventListener("load", () => {
                navigator.serviceWorker
                  .register("/service-worker.js", { scope: "/" })
                  .then((registration) => {
                    console.log("Service Worker successfully registered:", registration.scope);
                    registration.update().then(() => {
                      console.log("Service Worker checked for updates");
                    });
                  })
                  .catch((error) => {
                    console.error("Service Worker registration failed:", error);
                  });
              });
            } else {
              console.log("Service Worker registration skipped in development mode");
            }
          })
          .catch((error) => {
            console.error("Service Worker cleanup failed:", error);
          });
      }
    </script>
  </body>
</html>
