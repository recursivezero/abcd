---
import ThemeProvider from "@/components/ThemeProvider.astro";
import BaseHead from "@/layouts/BaseHead";
import Footer from "@/layouts/common/Footer";
import Header from "@/layouts/common/Header.astro";
import Menu from "@/layouts/common/Menu";
import { siteConfig } from "@/site-config";

const {
  meta: { title, description = siteConfig.description, ogImage },
  sidebar = true
} = Astro.props;
---

<html lang={siteConfig.lang}>
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body id="body" class="body__container" style="overflow: visible;">
    <ThemeProvider />
    <Header title={title}>
      <slot name="header-left" slot="left" />
      <slot name="header-right" slot="right" />
    </Header>
    <main id="main" class="main">
      {
        sidebar && (
          <div class="sidebar" id="sidebar">
            <button class="pin-btn" id="pinBtn" aria-label="Pin sidebar" title="Sidebar pin karo">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="12" y1="17" x2="12" y2="22" />
                <path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z" />
              </svg>
            </button>
            <Menu />
          </div>
        )
      }
      {
        sidebar && (
          <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
            <span id="toggleIcon" class="toggle-icon-wrap" />
          </button>
        )
      }

      {/* OVERLAY — sirf mobile pe */}
      <div class="sidebar-overlay" id="sidebarOverlay"></div>

      <div class="content" id="mainContent">
        <slot><p>This is my fallback content, if there is no child passed into slot</p></slot>
      </div>
    </main>

    <style is:global>
      /* ── MAIN CONTAINER ── */
      .main {
        display: flex;
        width: 100%;
        position: relative;
        overflow: visible;
        margin-top: 0;
      }
      .content {
        flex: 1;
        min-width: 0;
        width: 100%;
        padding-top: 0;
      }
      html {
        overflow-y: visible !important;
      }

      /* ── SIDEBAR ── */
      .sidebar {
        /* Desktop: layout flow mein rehti hai, flex shrink allowed */
        flex-shrink: 0;
        width: 0; /* default: collapsed */
        overflow: hidden;
        height: 100vh;
        position: sticky;
        top: 0;

        background: var(--background);
        z-index: 100;
        border-right: 1px solid transparent;
        padding-top: 0;

        transition:
          width 0.3s ease,
          border-color 0.3s ease;
      }

      /* Sidebar OPEN — desktop push mode */
      .sidebar.open {
        width: 260px;
        border-right-color: rgba(124, 58, 237, 0.12);
        overflow-y: auto;
        padding-top: 6rem;
      }

      /* Sidebar PINNED — same as open but persists */
      .sidebar.pinned {
        width: 260px;
        border-right-color: rgba(124, 58, 237, 0.12);
        overflow-y: auto;
        padding-top: 6rem;
      }

      /* ── CONTENT ── */
      .content {
        flex: 1;
        min-width: 0;
        width: 100%;
        /* transition hata diya — content khud hi push hoga sidebar ke flex width se */
      }

      /* ── PIN BUTTON ── */
      .pin-btn {
        position: absolute;
        top: 4.2rem;
        right: 10px;

        width: 28px;
        height: 28px;

        border: 1.5px solid rgba(124, 58, 237, 0.25);
        border-radius: 8px;
        background: transparent;

        color: #7c3aed;
        display: flex;
        align-items: center;
        justify-content: center;

        cursor: pointer;
        opacity: 0.5;
        transition:
          opacity 0.2s ease,
          background 0.2s ease,
          transform 0.2s ease;
        z-index: 10;
      }

      .pin-btn:hover {
        opacity: 1;
        background: rgba(124, 58, 237, 0.08);
      }

      .pin-btn.active {
        opacity: 1;
        background: rgba(124, 58, 237, 0.12);
        border-color: #7c3aed;
        transform: rotate(45deg);
      }

      @media (max-width: 768px) {
        .pin-btn {
          display: none !important;
        }
      }

      /* ── OVERLAY — sirf mobile ── */
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 1199;
        cursor: pointer;
      }

      .sidebar-overlay.show {
        display: block;
      }

      /* ── TOGGLE BUTTON ── */
      .sidebar-toggle {
        position: fixed !important;
        bottom: 24px !important;
        left: 16px !important;
        transform: none !important;
        top: auto !important;
        width: 48px !important;
        height: 48px !important;
        border: none;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        color: #7c3aed !important;
        display: flex !important;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 2147483647 !important;
        opacity: 1 !important;
        visibility: visible !important;
        pointer-events: auto !important;
        box-shadow:
          0 6px 24px rgba(124, 58, 237, 0.22),
          0 2px 8px rgba(0, 0, 0, 0.1);
        transition:
          background 0.22s ease,
          box-shadow 0.22s ease;
      }

      .sidebar-toggle:hover {
        background: rgba(124, 58, 237, 0.08) !important;
        box-shadow:
          0 8px 28px rgba(124, 58, 237, 0.28),
          0 2px 8px rgba(0, 0, 0, 0.1);
      }

      .sidebar-toggle svg {
        width: 18px !important;
        height: 18px !important;
        display: block;
      }

      .toggle-icon-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
      }

      /* ── MOBILE OVERRIDES ── */
      @media (max-width: 768px) {
        /* Mobile pe sidebar fixed overlay mode mein */
        .sidebar {
          position: fixed !important;
          top: 0 !important;
          left: 0 !important;
          width: 0 !important; /* closed: 0 */
          height: 100vh !important;
          z-index: 1200;
          overflow: hidden;
          padding-top: 0;
          transition: width 0.3s ease !important;
          box-shadow: none;
        }

        .sidebar.open {
          width: 82vw !important;
          max-width: 300px !important;
          overflow-y: auto !important;
          padding-top: 6rem !important;
          box-shadow: 4px 0 20px rgba(0, 0, 0, 0.18) !important;
        }

        /* Mobile pinned = open (pin concept nahi hai) */
        .sidebar.pinned {
          width: 82vw !important;
          max-width: 300px !important;
          overflow-y: auto !important;
          padding-top: 6rem !important;
          box-shadow: 4px 0 20px rgba(0, 0, 0, 0.18) !important;
        }

        .sidebar-toggle {
          bottom: 20px !important;
          left: 16px !important;
          top: auto !important;
          width: 48px !important;
          height: 48px !important;
        }
      }
    </style>

    <script>
      const sidebar = document.getElementById("sidebar") as HTMLElement | null;
      const toggle = document.getElementById("sidebarToggle") as HTMLElement | null;
      const icon = document.getElementById("toggleIcon") as HTMLElement | null;
      const pinBtn = document.getElementById("pinBtn") as HTMLElement | null;
      const overlay = document.getElementById("sidebarOverlay") as HTMLElement | null;
      const mainEl = document.getElementById("main") as HTMLElement | null;

      let isPinned = localStorage.getItem("sidebarPinned") === "true";

      const ICON_HAMBURGER = `
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
          fill="none" stroke="#7c3aed" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="9" x2="21" y2="9"></line>
          <line x1="3" y1="15" x2="21" y2="15"></line>
        </svg>`;

      const ICON_LAYOUT = `
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="16" rx="2"></rect>
          <line x1="9" y1="4" x2="9" y2="20"></line>
        </svg>`;

      const ICON_CLOSE = `
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>`;

      function isMobile() {
        return window.innerWidth <= 768;
      }

      function setClosedIcon() {
        if (!icon) return;
        icon.innerHTML = isMobile() ? ICON_HAMBURGER : ICON_LAYOUT;
      }

      function showToggle() {
        if (toggle) toggle.style.display = "flex";
      }

      function applyPinState() {
        if (!sidebar || !pinBtn) return;

        if (isPinned && !isMobile()) {
          sidebar.classList.add("pinned");
          sidebar.classList.remove("open");
          pinBtn.classList.add("active");
          if (overlay) overlay.classList.remove("show");
          showToggle();
          setClosedIcon();
        } else {
          sidebar.classList.remove("pinned");
          pinBtn.classList.remove("active");
          showToggle();
          setClosedIcon();
        }
      }
      function openSidebar() {
        if (!sidebar) return;
        sidebar.classList.add("open");
        // Overlay sirf mobile pe
        if (isMobile() && overlay) {
          overlay.classList.add("show");
        }
        if (icon) icon.innerHTML = ICON_CLOSE;
      }

      function closeSidebar() {
        if (!sidebar) return;
        sidebar.classList.remove("open");
        if (overlay) overlay.classList.remove("show");
        setClosedIcon();
      }

      // Pin toggle
      if (pinBtn) {
        pinBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          if (isMobile()) return;
          isPinned = !isPinned;
          localStorage.setItem("sidebarPinned", String(isPinned));
          applyPinState();
        });
      }

      // Init
      if (toggle && sidebar && icon) {
        sidebar.classList.remove("open");
        setClosedIcon();
        applyPinState();

        toggle.addEventListener("click", () => {
          if (isPinned && !isMobile()) return;
          const isOpen = sidebar.classList.contains("open");
          if (isOpen) {
            closeSidebar();
          } else {
            openSidebar();
          }
        });
      }

      // Overlay click
      if (overlay) {
        overlay.addEventListener("click", () => {
          closeSidebar();
        });
      }

      // Outside click — desktop pe close
      document.addEventListener("click", (e) => {
        if (!sidebar || !toggle) return;
        if (isPinned && !isMobile()) return;
        const target = e.target as Node;
        if (!sidebar.contains(target) && !toggle.contains(target)) {
          closeSidebar();
        }
      });

      // Resize handler
      window.addEventListener("resize", () => {
        if (isMobile()) {
          if (sidebar) sidebar.classList.remove("pinned");
          if (pinBtn) pinBtn.classList.remove("active");
          showToggle();
          if (!sidebar?.classList.contains("open")) {
            setClosedIcon();
          }
        } else {
          applyPinState();
          if (!sidebar?.classList.contains("open") && !isPinned) {
            setClosedIcon();
          }
        }
      });
    </script>

    <Footer />

    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker
          .getRegistrations()
          .then((registrations) => {
            const unregisterPromises = registrations.map(async (registration) => {
              return registration.unregister().then((success) => {
                if (success) {
                  console.log("Successfully unregistered service worker:", registration.scope);
                } else {
                  console.warn("Failed to unregister service worker:", registration.scope);
                }
                return success;
              });
            });
            return Promise.all(unregisterPromises);
          })
          .then(() => {
            if (!import.meta.env.DEV) {
              window.addEventListener("load", () => {
                navigator.serviceWorker
                  .register("/service-worker.js", { scope: "/" })
                  .then((registration) => {
                    console.log("Service Worker successfully registered:", registration.scope);
                    registration.update().then(() => {
                      console.log("Service Worker checked for updates");
                    });
                  })
                  .catch((error) => {
                    console.error("Service Worker registration failed:", error);
                  });
              });
            } else {
              console.log("Service Worker registration skipped in development mode");
            }
          })
          .catch((error) => {
            console.error("Service Worker cleanup failed:", error);
          });
      }
    </script>
  </body>
</html>
