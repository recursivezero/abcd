---
import "@/assets/styles/footer.css";
---

<footer class="container__footer">
  <div class="footer__inner">
    <div class="footer__main-content">
      <!-- Brand -->
      <div class="footer__brand-section">
        <div class="brand">abcd<span class="kbd">kbd</span></div>
        <p class="footer__tagline">Making learning fun and engaging for young minds everywhere.</p>
        <span class="footer__badge">🎓 Free to Learn</span>
      </div>

      <!-- Nav -->
      <nav class="footer__nav">
        <div class="footer__nav--item">
          <button class="footer__nav--title" type="button" aria-expanded="false" aria-controls="footer-col-1">
            <span>Learning</span>
            <i class="fa fa-chevron-down chevron"></i>
          </button>
          <div class="footer__nav--links" id="footer-col-1">
            <a href="/alphabets">Reading</a>
            <a href="/math">Math</a>
            <a href="/crossword">Games</a>
            <a href="/draw">Creativity</a>
            <a href="/map">India Map</a>
          </div>
        </div>

        <div class="footer__nav--item">
          <button class="footer__nav--title" type="button" aria-expanded="false" aria-controls="footer-col-2">
            <span>General</span>
            <i class="fa fa-chevron-down chevron"></i>
          </button>
          <div class="footer__nav--links" id="footer-col-2">
            <a href="/faq">FAQs</a>
            <a href="/support">Support</a>
            <a href="/blog">Blog</a>
            <a href="/about">About Us</a>
            <a href="/contact">Contact Us</a>
          </div>
        </div>

        <div class="footer__nav--item">
          <button class="footer__nav--title" type="button" aria-expanded="false" aria-controls="footer-col-3">
            <span>Resources</span>
            <i class="fa fa-chevron-down chevron"></i>
          </button>
          <div class="footer__nav--links" id="footer-col-3">
            <a href="/school">School Programs</a>
            <a href="/classroom">Classroom Tools</a>
            <a href="/teacher">Teacher Resources</a>
            <a href="/parent">Parent Resources</a>
          </div>
        </div>
      </nav>
    </div>

    <!-- Copyright -->
    <div class="copyright">
      <span class="copyright__text">© 2025 recursivezero.com. All rights reserved.</span>
      <div class="copyright__links">
        <a href="/privacy">Privacy Policy</a>
        <span class="sep">|</span>
        <a href="/terms">Terms of Service</a>
        <span class="sep">|</span>
        <a href="/cookies">Cookies</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  function initFooter() {
    var isMobile = window.innerWidth <= 768;
    var items = document.querySelectorAll(".footer__nav--item");

    items.forEach(function (item) {
      var btn = item.querySelector(".footer__nav--title");
      var links = item.querySelector(".footer__nav--links");
      if (!btn || !links) return;

      if (!isMobile) {
        // Desktop: links hamesha visible, button non-clickable
        links.style.display = "flex";
        btn.style.pointerEvents = "none";
        btn.style.cursor = "default";
        btn.setAttribute("aria-expanded", "true");
      } else {
        // Mobile: links hidden by default
        links.style.display = "none";
        btn.style.pointerEvents = "auto";
        btn.style.cursor = "pointer";
        btn.setAttribute("aria-expanded", "false");
      }
    });

    if (!isMobile) return;

    // Mobile: button click handler
    items.forEach(function (item) {
      var btn = item.querySelector(".footer__nav--title");
      var links = item.querySelector(".footer__nav--links");
      if (!btn || !links) return;

      // Remove old handler
      var newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);

      newBtn.addEventListener("click", function () {
        var isOpen = newBtn.getAttribute("aria-expanded") === "true";

        // Sab band karo
        items.forEach(function (el) {
          var b = el.querySelector(".footer__nav--title");
          var l = el.querySelector(".footer__nav--links");
          if (b) b.setAttribute("aria-expanded", "false");
          if (l) l.style.display = "none";
        });

        // Agar band tha toh kholo
        if (!isOpen) {
          newBtn.setAttribute("aria-expanded", "true");
          links.style.display = "flex";
        }
      });
    });
  }

  initFooter();

  var _rt;
  window.addEventListener("resize", function () {
    clearTimeout(_rt);
    _rt = setTimeout(initFooter, 150);
  });

  document.addEventListener("astro:page-load", initFooter);
</script>
