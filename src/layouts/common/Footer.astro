---
import "@/assets/styles/footer.css";
---

<footer class="container__footer">
  <div class="footer__inner">

    <!-- ══ MAIN CONTENT ══ -->
    <div class="footer__main-content">

      <!-- Brand Column -->
      <div class="footer__brand-section">
        <div class="brand">abcd<span class="kbd">kbd</span></div>
        <p class="footer__tagline">Making learning fun and engaging for young minds everywhere.</p>
        <span class="footer__badge">🎓 Free to Learn</span>
      </div>

      <!-- Nav Columns -->
      <nav class="footer__nav">

        <details class="footer__nav--item" open>
          <summary class="footer__nav--title">
            <span>Learning</span>
            <i class="fa fa-chevron-down chevron"></i>
          </summary>
          <div class="footer__nav--links">
            <a href="/alphabets">Reading</a>
            <a href="/math">Math</a>
            <a href="/crossword">Games</a>
            <a href="/draw">Creativity</a>
            <a href="/map">India Map</a>
          </div>
        </details>

        <details class="footer__nav--item" open>
          <summary class="footer__nav--title">
            <span>General</span>
            <i class="fa fa-chevron-down chevron"></i>
          </summary>
          <div class="footer__nav--links">
            <a href="/faq">FAQs</a>
            <a href="/support">Support</a>
            <a href="/blog">Blog</a>
            <a href="/about">About Us</a>
            <a href="/contact">Contact Us</a>
          </div>
        </details>

        <details class="footer__nav--item" open>
          <summary class="footer__nav--title">
            <span>Resources</span>
            <i class="fa fa-chevron-down chevron"></i>
          </summary>
          <div class="footer__nav--links">
            <a href="/school">School Programs</a>
            <a href="/classroom">Classroom Tools</a>
            <a href="/teacher">Teacher Resources</a>
            <a href="/parent">Parent Resources</a>
          </div>
        </details>

      </nav>
    </div>

    <!-- ══ COPYRIGHT ══ -->
    <div class="copyright">
      <span class="copyright__text">© 2025 recursivezero.com. All rights reserved.</span>
      <div class="copyright__links">
        <a href="/privacy">Privacy Policy</a>
        <span class="sep">|</span>
        <a href="/terms">Terms of Service</a>
        <span class="sep">|</span>
        <a href="/cookies">Cookies</a>
      </div>
    </div>

  </div>
</footer>

<script is:inline>
  function initFooterAccordion() {
    const isMobile = window.innerWidth <= 768;
    const items = document.querySelectorAll("details.footer__nav--item");

    items.forEach((item) => {
      if (isMobile) {
        item.removeAttribute("open");
      } else {
        item.setAttribute("open", "");
      }

      const oldSummary = item.querySelector(".footer__nav--title");
      if (!oldSummary) return;
      const newSummary = oldSummary.cloneNode(true);
      oldSummary.replaceWith(newSummary);

      newSummary.addEventListener("click", (e) => {
        if (window.innerWidth > 768) return;
        e.preventDefault();
        const isOpen = item.hasAttribute("open");
        items.forEach((el) => el.removeAttribute("open"));
        if (!isOpen) item.setAttribute("open", "");
      });
    });
  }

  initFooterAccordion();

  let t;
  window.addEventListener("resize", () => {
    clearTimeout(t);
    t = setTimeout(initFooterAccordion, 150);
  });

  document.addEventListener("astro:page-load", initFooterAccordion);
</script>