---
import "@/assets/styles/menu.css";
import HamIcon from "@/assets/icons/ham.svg";
import ArrowIcon from "@/assets/icons/arrow.svg";
import Navigation from "@/layouts/Navigation";
import { NavbarLinks } from "@/utils/constants";
---

<button class="menu-button" popovertarget="nav" popovertargetaction="toggle">
  <HamIcon width={24} height={24} />
</button>

<div class="sidebar_layout">
  <aside popover="auto" id="nav">
    <button class="menu-button hider" id="hiderBtn" aria-label="Close drawer">
      <span class="sr-only">Close drawer</span>
    </button>

    <!-- TOP ACTIONS -->
    <div class="actions top-actions">
      <button class="menu-button minimize-toggle" aria-label="Toggle menu size">
        <ArrowIcon width={24} height={24} style={{ transform: "rotate(-135deg)" }} />
      </button>

      <button class="menu-button theme-toggle" aria-label="Toggle theme" id="sidebarThemeToggle">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="pointer-events: none; display: block;"
          id="sidebarThemeIcon"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
      </button>

      <button class="pin-btn" id="pinBtn" aria-label="Pin sidebar" title="Pin Sidebar">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="12" y1="17" x2="12" y2="22"></line>
          <path
            d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"
          ></path>
        </svg>
      </button>

      <button class="menu-button placement-toggle">
        <ArrowIcon width={24} height={24} />
      </button>
    </div>

    <Navigation pages={NavbarLinks} />
  </aside>
</div>

<script is:inline>
  (function () {
    const sunPath =
      '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
    const moonPath = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';

    const ICON_HAMBURGER =
      '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="9" x2="21" y2="9"></line><line x1="3" y1="15" x2="21" y2="15"></line></svg>';
    const ICON_LAYOUT =
      '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><line x1="9" y1="4" x2="9" y2="20"></line></svg>';

    function updateSidebarIcon(theme) {
      const svg = document.getElementById("sidebarThemeIcon");
      if (svg) svg.innerHTML = theme === "dark" ? moonPath : sunPath;
    }

    function sidebarToggleTheme() {
      const current = localStorage.getItem("theme") || "light";
      const next = current === "dark" ? "light" : "dark";
      localStorage.setItem("theme", next);

      const h = document.documentElement;
      h.setAttribute("data-theme", next);
      h.classList.toggle("dark", next === "dark");

      if (next === "dark") {
        h.style.backgroundColor = "#020608";
        h.style.backgroundImage = "linear-gradient(180deg,#020608 0%,#031a20 50%,#052e38 100%)";
        h.style.backgroundAttachment = "fixed";
      } else {
        h.style.backgroundColor = "#ffffff";
        h.style.backgroundImage = "none";
      }

      document.body.style.backgroundColor = "transparent";
      updateSidebarIcon(next);

      const headerIcon = document.getElementById("themeIcon");
      if (headerIcon) {
        const sunIcon =
          '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
        const moonIcon = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
        headerIcon.innerHTML = next === "dark" ? sunIcon : moonIcon;
      }
    }

    function initSidebarTheme() {
      updateSidebarIcon(localStorage.getItem("theme") || "light");
      const btn = document.getElementById("sidebarThemeToggle");
      if (!btn) return;
      const newBtn = btn.cloneNode(true);
      btn.replaceWith(newBtn);
      newBtn.addEventListener("click", sidebarToggleTheme);
    }

    function initHider() {
      const hiderBtn = document.getElementById("hiderBtn");
      if (!hiderBtn) return;
      const newHider = hiderBtn.cloneNode(true);
      hiderBtn.replaceWith(newHider);

      newHider.addEventListener("click", (e) => {
        e.stopPropagation();
        e.preventDefault();

        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebarOverlay");
        const toggleIcon = document.getElementById("toggleIcon");

        if (sidebar) {
          sidebar.classList.remove("open");
          sidebar.classList.remove("pinned");
        }
        if (overlay) overlay.classList.remove("show");
        localStorage.setItem("sidebarPinned", "false");

        const isMobile = window.innerWidth <= 768;
        if (toggleIcon) {
          toggleIcon.innerHTML = isMobile ? ICON_HAMBURGER : ICON_LAYOUT;
        }
      });
    }

    function initMinimize() {
      const minimizeBtn = document.querySelector(".minimize-toggle");
      const nav = document.querySelector("#nav");
      if (!minimizeBtn || !nav) return;
      const newBtn = minimizeBtn.cloneNode(true);
      minimizeBtn.replaceWith(newBtn);
      newBtn.addEventListener("click", () => {
        nav.classList.toggle("minimized");
        newBtn.classList.toggle("rotated");
        newBtn.setAttribute("title", nav.classList.contains("minimized") ? "Open sidebar" : "Close sidebar");
      });
    }

    function initPlacer() {
      const placer = document.querySelector(".placement-toggle");
      if (!placer) return;
      const newPlacer = placer.cloneNode(true);
      placer.replaceWith(newPlacer);
      newPlacer.addEventListener("click", () => {
        document.documentElement.dataset.placement =
          document.documentElement.dataset.placement === "top" ? "bottom" : "top";
      });
    }

    function initAll() {
      initSidebarTheme();
      initHider();
      initMinimize();
      initPlacer();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initAll);
    } else {
      initAll();
    }

    document.addEventListener("astro:page-load", initAll);
  })();
</script>
