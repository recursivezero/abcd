---
import "@/assets/styles/header.css";
import { APP_NAME, NavbarLinks } from "@/utils/constants";
import { DATASET } from "@/mappers/dataset";
import { gamesData } from "@/data/gamesData";
import { Picture } from "astro:assets";
import logoImage from "/public/assets/images/48x48.png";
import stateData from "@/data/state.json";
import glossaryData from "@/data/glossary.json";
import numberData from "@/data/numbers.json";

const navItems = NavbarLinks.filter((l) => l.isActive).map((l) => ({
  name: l.name || l.title || "",
  path: l.path,
  type: "page",
  sub: ""
}));

const alphabetItems = Object.keys(DATASET).map((key) => ({
  name: key.charAt(0).toUpperCase() + key.slice(1),
  path: `/alphabets/${key}/playground/`,
  type: "alphabet",
  sub: DATASET[key].description || ""
}));

const gameItems = Object.values(gamesData)
  .flat()
  .map((game) => ({
    name: game.title,
    path: game.link,
    type: "game",
    sub: game.description || ""
  }));

const stateItems = stateData
  .filter((s) => s.isActive)
  .flatMap((s) => [
    { name: s.name, path: `/map/${s.id}`, type: "state", sub: s.capital ? `Capital: ${s.capital}` : "" },
    { name: s.dance, path: `/map/${s.id}`, type: "dance", sub: `State: ${s.name}` },
    ...(s.festival ? [{ name: s.festival, path: `/map/${s.id}`, type: "festival", sub: `State: ${s.name}` }] : []),
    ...(s.capital ? [{ name: s.capital, path: `/map/${s.id}`, type: "capital", sub: `Capital of ${s.name}` }] : []),
    ...(s.famous_food ? [{ name: s.famous_food, path: `/map/${s.id}`, type: "food", sub: `Food of ${s.name}` }] : []),
    ...(s.famous_place
      ? [{ name: s.famous_place, path: `/map/${s.id}`, type: "place", sub: `Place in ${s.name}` }]
      : [])
  ]);

const glossaryItems = Object.entries(glossaryData).map(([key, val]) => ({
  name: val.title || key.charAt(0).toUpperCase() + key.slice(1),
  path: `/glossary/${key}`,
  type: "glossary",
  sub: val.description || ""
}));

const numberItems = Object.entries(numberData).map(([key, val]) => ({
  name: val.title || key.charAt(0).toUpperCase() + key.slice(1),
  path: `/numbers/${key}`,
  type: "numbers",
  sub: val.description || ""
}));

const varnmalaItems = [
  { name: "Varnmala Hindi", path: "/varnmala/hindi", type: "varnmala", sub: "Hindi Varnmala" },
  { name: "Varnmala English", path: "/varnmala/english", type: "varnmala", sub: "English Varnmala" },
  { name: "Varnmala Listen", path: "/varnmala/listen", type: "varnmala", sub: "Listen & Learn" },
  { name: "Varnmala Play", path: "/varnmala/play", type: "varnmala", sub: "Play & Learn" },
  { name: "Varnmala Write", path: "/varnmala/write", type: "varnmala", sub: "Write Practice" },
  { name: "Barahkhadi", path: "/varnmala/barahkhadi", type: "varnmala", sub: "Hindi Barahkhadi" }
];

const galleryItems = [
  { name: "Gallery Queue", path: "/gallery/queue", type: "gallery", sub: "Queue Gallery" },
  { name: "Gallery Slider", path: "/gallery/slider", type: "gallery", sub: "Slider Gallery" },
  { name: "Gallery Stack", path: "/gallery/stack", type: "gallery", sub: "Stack Gallery" }
];

const canvasItems = [
  { name: "Canvas Draw", path: "/canvas", type: "canvas", sub: "Drawing Canvas" },
  { name: "Canvas Quote", path: "/canvas/quote", type: "canvas", sub: "Quote Canvas" },
  { name: "Canvas Text", path: "/canvas/text", type: "canvas", sub: "Text Canvas" }
];

const hidenseekItems = [
  { name: "Hide N Seek Grid", path: "/hidenseek", type: "hidenseek", sub: "Grid Game" },
  { name: "Hide N Seek KBD", path: "/hidenseek/kbd", type: "hidenseek", sub: "Keyboard Game" }
];

const allSearchItems = [
  ...gameItems,
  ...alphabetItems,
  ...stateItems,
  ...glossaryItems,
  ...numberItems,
  ...varnmalaItems,
  ...galleryItems,
  ...canvasItems,
  ...hidenseekItems,
  ...navItems
];

const allSearchItemsJSON = JSON.stringify(allSearchItems);
---

<header class="header">
  <div class="header__brand">
    <a href="/" class="logo__link">
      <Picture src={logoImage} formats={["png", "webp"]} alt="abcdkbd logo" class="logo" />
      <p title={APP_NAME}>abcd<span class="kbd">kbd</span></p>
    </a>
  </div>

  <div class="nav__links">
    <a href="/" class:list={{ "is-active": Astro.url.pathname === "/home" || Astro.url.pathname === "/" }}>Home</a>
    <a href="/about" class:list={{ "is-active": Astro.url.pathname.startsWith("/about") }}>About</a>
    <a href="/games" class:list={{ "is-active": Astro.url.pathname.startsWith("/games") }}>Categories</a>
    <a href="/contact" class:list={{ "is-active": Astro.url.pathname.startsWith("/contact") }}>Contact</a>
  </div>

  <div class="action__group">
    <slot name="left" />
    <slot name="right" />
    <button class="theme-toggle" id="headerThemeToggle" aria-label="Toggle theme" title="Toggle Theme">
      <svg
        id="themeIcon"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
    </button>
  </div>
</header>

<button class="hamburger" id="hamburger" aria-label="Toggle menu">
  <span></span>
  <span></span>
  <span></span>
</button>

<div class="mobile-overlay" id="mobileOverlay"></div>

<div class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu__header">
    <a href="/" class="mobile-logo">
      abcd<span style="color:#14b8a6;">kbd</span>
    </a>

    <ul class="mobile-nav__links">
      <li><a href="/">🏠 Home</a></li>
      <li><a href="/about">ℹ️ About</a></li>
      <li><a href="/games">🧩 Categories</a></li>
      <li><a href="/contact">📩 Contact Us</a></li>
    </ul>

    <div class="mobile-actions">
      <div class="mobile-controls">
        <span>Toggle Theme</span>
        <button class="theme-toggle" id="mobileThemeToggle" aria-label="Toggle theme">
          <svg
            id="mobileThemeIcon"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<div class="hero-search">
  <div class="hero-search__wrap">
    <div class="hero-search__box" id="heroSearchBox">
      <span class="hero-search__icon">🔍</span>
      <input type="text" id="heroSearch" placeholder="Search games, alphabets, states..." autocomplete="off" />
      <button id="heroClear" class="hero-search__clear" style="display:none;">✕</button>
    </div>
    <div class="hero-search__dropdown" id="heroSuggestions" style="display:none;"></div>
  </div>
</div>

<div class="header-spacer" id="headerSpacer"></div>

<style is:global>
  .theme-toggle {
    background: none;
    border: 1.5px solid #e2e8f0;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #0ed4f7;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .theme-toggle:hover {
    background: #ede9fe;
    border-color: #0cd9e0;
    transform: rotate(20deg);
  }
  [data-theme="dark"] .theme-toggle {
    border-color: #334155;
    color: #16ade4;
  }
  [data-theme="dark"] .theme-toggle:hover {
    background: #e9e6ee;
    border-color: #0ba4ce;
  }
  .gs-section-title {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    color: #7c3aed;
    padding: 8px 16px 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-top: 1px solid #f1f5f9;
    margin-top: 2px;
  }
  .gs-section-title:first-child {
    border-top: none;
    margin-top: 0;
  }
  .gs-result-item {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 7px 16px !important;
    text-decoration: none !important;
    color: #1e293b !important;
    font-size: 13px !important;
    font-weight: 500 !important;
    transition: background 0.12s !important;
    gap: 10px !important;
  }
  .gs-result-item:hover {
    background: #f5f3ff !important;
    color: #7c3aed !important;
  }
  .gs-result-left {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    flex: 1 !important;
    min-width: 0 !important;
  }
  .gs-emoji-box {
    width: 30px !important;
    height: 30px !important;
    border-radius: 8px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 15px !important;
    flex-shrink: 0 !important;
  }
  .gs-result-info {
    display: flex !important;
    flex-direction: column !important;
    min-width: 0 !important;
  }
  .gs-result-name {
    font-size: 13px !important;
    font-weight: 600 !important;
    color: inherit !important;
    white-space: nowrap !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
  }
  .gs-result-sub {
    font-size: 11px !important;
    color: #94a3b8 !important;
    white-space: nowrap !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
  }
  .gs-type-tag {
    font-size: 10px !important;
    font-weight: 700 !important;
    padding: 2px 7px !important;
    border-radius: 20px !important;
    flex-shrink: 0 !important;
    text-transform: capitalize !important;
  }
  .gs-empty {
    padding: 20px 16px;
    text-align: center;
    color: #94a3b8;
    font-size: 14px;
  }
  .gs-c-game {
    background: #dcfce7 !important;
  }
  .gs-c-alphabet {
    background: #dbeafe !important;
  }
  .gs-c-page {
    background: #fef9c3 !important;
  }
  .gs-c-state {
    background: #ffe4e6 !important;
  }
  .gs-c-dance {
    background: #fce7f3 !important;
  }
  .gs-c-festival {
    background: #fef3c7 !important;
  }
  .gs-c-capital {
    background: #e0f2fe !important;
  }
  .gs-c-food {
    background: #fff7ed !important;
  }
  .gs-c-place {
    background: #f0fdf4 !important;
  }
  .gs-c-glossary {
    background: #f3e8ff !important;
  }
  .gs-c-numbers {
    background: #fef9c3 !important;
  }
  .gs-c-varnmala {
    background: #fce7f3 !important;
  }
  .gs-c-gallery {
    background: #e0f2fe !important;
  }
  .gs-c-canvas {
    background: #dcfce7 !important;
  }
  .gs-c-hidenseek {
    background: #fef3c7 !important;
  }
  .gs-t-game {
    background: #dcfce7 !important;
    color: #16a34a !important;
  }
  .gs-t-alphabet {
    background: #dbeafe !important;
    color: #2563eb !important;
  }
  .gs-t-page {
    background: #fef9c3 !important;
    color: #d97706 !important;
  }
  .gs-t-state {
    background: #ffe4e6 !important;
    color: #e11d48 !important;
  }
  .gs-t-dance {
    background: #fce7f3 !important;
    color: #db2777 !important;
  }
  .gs-t-festival {
    background: #fef3c7 !important;
    color: #d97706 !important;
  }
  .gs-t-capital {
    background: #e0f2fe !important;
    color: #0284c7 !important;
  }
  .gs-t-food {
    background: #fff7ed !important;
    color: #ea580c !important;
  }
  .gs-t-place {
    background: #f0fdf4 !important;
    color: #16a34a !important;
  }
  .gs-t-glossary {
    background: #f3e8ff !important;
    color: #7c3aed !important;
  }
  .gs-t-numbers {
    background: #fef9c3 !important;
    color: #ca8a04 !important;
  }
  .gs-t-varnmala {
    background: #fce7f3 !important;
    color: #db2777 !important;
  }
  .gs-t-gallery {
    background: #e0f2fe !important;
    color: #0284c7 !important;
  }
  .gs-t-canvas {
    background: #dcfce7 !important;
    color: #16a34a !important;
  }
  .gs-t-hidenseek {
    background: #fef3c7 !important;
    color: #d97706 !important;
  }
</style>

<script is:inline define:vars={{ allSearchItemsJSON }}>
  window.__searchItems = JSON.parse(allSearchItemsJSON);

  const groupTitle = {
    game: "🎮 Games",
    alphabet: "🔤 Alphabets",
    page: "📄 Pages",
    state: "🗺️ States",
    dance: "💃 Dances",
    festival: "🎉 Festivals",
    capital: "🏛️ Capitals",
    food: "🍛 Foods",
    place: "📍 Places",
    glossary: "📖 Glossary",
    numbers: "🔢 Numbers",
    varnmala: "अ Varnmala",
    gallery: "🖼️ Gallery",
    canvas: "🎨 Canvas",
    hidenseek: "🔍 Hide N Seek"
  };
  const typeEmoji = {
    game: "🎮",
    alphabet: "🔤",
    page: "📄",
    state: "🗺️",
    dance: "💃",
    festival: "🎉",
    capital: "🏛️",
    food: "🍛",
    place: "📍",
    glossary: "📖",
    numbers: "🔢",
    varnmala: "अ",
    gallery: "🖼️",
    canvas: "🎨",
    hidenseek: "🔍"
  };

  function buildDropdown(query, dropdown) {
    const items = window.__searchItems || [];
    const q = query.trim().toLowerCase();
    if (!q) {
      dropdown.style.display = "none";
      return;
    }
    const matched = items.filter((item) => item.name && item.name.toLowerCase().includes(q)).slice(0, 25);
    if (matched.length === 0) {
      dropdown.innerHTML = `<div class="gs-empty">No results for "<strong>${query}</strong>"</div>`;
      dropdown.style.display = "block";
      return;
    }
    const groups = {};
    matched.forEach((item) => {
      if (!groups[item.type]) groups[item.type] = [];
      groups[item.type].push(item);
    });
    let html = "";
    for (const [type, items2] of Object.entries(groups)) {
      html += `<div class="gs-section-title">${groupTitle[type] || type}</div>`;
      items2.forEach((item) => {
        html += `<a href="${item.path}" class="gs-result-item">
          <div class="gs-result-left">
            <div class="gs-emoji-box gs-c-${type}">${typeEmoji[type] || "•"}</div>
            <div class="gs-result-info">
              <span class="gs-result-name">${item.name}</span>
              ${item.sub ? `<span class="gs-result-sub">${item.sub}</span>` : ""}
            </div>
          </div>
          <span class="gs-type-tag gs-t-${type}">${type}</span>
        </a>`;
      });
    }
    dropdown.innerHTML = html;
    dropdown.style.display = "block";
  }

  // ── SPACER FIX: dynamically set spacer height ──
  function updateSpacer() {
    const header = document.querySelector(".header");
    const heroSearch = document.querySelector(".hero-search");
    const spacer = document.getElementById("headerSpacer");
    if (header && heroSearch && spacer) {
      const headerH = header.getBoundingClientRect().height;
      const searchH = heroSearch.getBoundingClientRect().height;
      document.documentElement.style.setProperty("--header-h", headerH + "px");
      spacer.style.height = headerH + searchH + "px";
    }
  }

  function initHeroSearch() {
    const input = document.getElementById("heroSearch");
    const clearBtn = document.getElementById("heroClear");
    const dropdown = document.getElementById("heroSuggestions");
    if (!input) return;
    input.addEventListener("input", (e) => {
      const q = e.target.value;
      if (clearBtn) clearBtn.style.display = q ? "block" : "none";
      buildDropdown(q, dropdown);
    });
    clearBtn &&
      clearBtn.addEventListener("click", () => {
        input.value = "";
        if (dropdown) dropdown.style.display = "none";
        if (clearBtn) clearBtn.style.display = "none";
        input.focus();
      });
    input.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        if (dropdown) dropdown.style.display = "none";
        input.blur();
      }
    });
    document.addEventListener("click", (e) => {
      if (!e.target.closest(".hero-search__wrap") && dropdown) dropdown.style.display = "none";
    });
  }

  const sunIcon = `<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`;
  const moonIcon = `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`;

  function applyThemeStyles(theme) {
    const html = document.documentElement;
    html.setAttribute("data-theme", theme);
    html.classList.toggle("dark", theme === "dark");
    if (theme === "dark") {
      html.style.backgroundColor = "#020608";
      html.style.backgroundImage = "linear-gradient(180deg, #020608 0%, #031a20 50%, #052e38 100%)";
      html.style.backgroundAttachment = "fixed";
      html.style.backgroundSize = "cover";
    } else {
      html.style.backgroundColor = "#ffffff";
      html.style.backgroundImage = "none";
      html.style.backgroundAttachment = "";
      html.style.backgroundSize = "";
    }
    if (document.body) {
      document.body.style.backgroundColor = "transparent";
      document.body.style.backgroundImage = "none";
    }
  }

  function updateThemeIcon() {
    const theme = localStorage.getItem("theme") || "light";
    const themeIcon = document.getElementById("themeIcon");
    const mobileThemeIcon = document.getElementById("mobileThemeIcon");
    if (themeIcon) themeIcon.innerHTML = theme === "dark" ? sunIcon : moonIcon;
    if (mobileThemeIcon) mobileThemeIcon.innerHTML = theme === "dark" ? sunIcon : moonIcon;
  }

  function initThemeToggle() {
    const headerThemeToggle = document.getElementById("headerThemeToggle");
    const mobileThemeToggle = document.getElementById("mobileThemeToggle");

    function toggleTheme() {
      const current = localStorage.getItem("theme") || "light";
      const next = current === "dark" ? "light" : "dark";
      localStorage.setItem("theme", next);
      applyThemeStyles(next);
      updateThemeIcon();
    }

    headerThemeToggle?.addEventListener("click", toggleTheme);
    mobileThemeToggle?.addEventListener("click", toggleTheme);

    applyThemeStyles(localStorage.getItem("theme") || "light");
    updateThemeIcon();
  }

  function initHamburger() {
    const hamburger = document.getElementById("hamburger");
    const menuClose = document.getElementById("menuClose");
    const mobileMenu = document.getElementById("mobileMenu");
    const mobileOverlay = document.getElementById("mobileOverlay");

    function openMenu() {
      hamburger?.classList.add("open");
      mobileMenu?.classList.add("open");
      mobileOverlay?.classList.add("open");
      document.body.style.overflow = "hidden";
    }
    function closeMenu() {
      hamburger?.classList.remove("open");
      mobileMenu?.classList.remove("open");
      mobileOverlay?.classList.remove("open");
      document.body.style.overflow = "";
    }

    hamburger?.addEventListener("click", () => {
      if (mobileMenu?.classList.contains("open")) {
        closeMenu();
      } else {
        openMenu();
      }
    });
    menuClose?.addEventListener("click", closeMenu);
    mobileOverlay?.addEventListener("click", closeMenu);
    document.querySelectorAll(".mobile-nav__links a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  function init() {
    initHeroSearch();
    initThemeToggle();
    initHamburger();
    updateSpacer();
  }

  // resize pe bhi update karo
  window.addEventListener("resize", updateSpacer);

  init();
  document.addEventListener("astro:page-load", init);
</script>
