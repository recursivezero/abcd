<script is:inline define:vars={{ allSearchItemsJSON }}>
  window.__searchItems = JSON.parse(allSearchItemsJSON);

  /* ── Constants ── */
  const GROUP_TITLE = {
    game: "🎮 Games",
    alphabet: "🔤 Alphabets",
    page: "📄 Pages",
    state: "🗺️ States",
    dance: "💃 Dances",
    festival: "🎉 Festivals",
    capital: "🏛️ Capitals",
    food: "🍛 Foods",
    place: "📍 Places",
    glossary: "📖 Glossary",
    numbers: "🔢 Numbers",
    varnmala: "अ Varnmala",
    gallery: "🖼️ Gallery",
    canvas: "🎨 Canvas",
    hidenseek: "🔍 Hide N Seek"
  };
  const TYPE_EMOJI = {
    game: "🎮",
    alphabet: "🔤",
    page: "📄",
    state: "🗺️",
    dance: "💃",
    festival: "🎉",
    capital: "🏛️",
    food: "🍛",
    place: "📍",
    glossary: "📖",
    numbers: "🔢",
    varnmala: "अ",
    gallery: "🖼️",
    canvas: "🎨",
    hidenseek: "🔍"
  };

  /* ── Highlight matching text ── */
  function highlight(text, q) {
    if (!q || !text) return escHtml(text);
    const idx = text.toLowerCase().indexOf(q.toLowerCase());
    if (idx === -1) return escHtml(text);
    return (
      escHtml(text.slice(0, idx)) +
      `<mark>${escHtml(text.slice(idx, idx + q.length))}</mark>` +
      escHtml(text.slice(idx + q.length))
    );
  }
  function escHtml(s) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  /* ── Build dropdown HTML ── */
  function buildDropdown(query, dropdown, combobox) {
    const items = window.__searchItems || [];
    const q = query.trim().toLowerCase();
    if (!q) {
      closeDropdown(dropdown, combobox);
      return;
    }

    const matched = items.filter((item) => item.name && item.name.toLowerCase().includes(q)).slice(0, 30);

    if (matched.length === 0) {
      dropdown.innerHTML = `
        <div class="gs-empty" role="status">
          <span class="gs-empty-icon">🔍</span>
          No results for <strong>"${escHtml(query)}"</strong>
        </div>`;
      openDropdown(dropdown, combobox);
      return;
    }

    /* Group by type */
    const groups = {};
    matched.forEach((item) => {
      if (!groups[item.type]) groups[item.type] = [];
      groups[item.type].push(item);
    });

    let html = "";
    let idx = 0;
    for (const [type, list] of Object.entries(groups)) {
      html += `<div class="gs-section-title" role="presentation">
        ${GROUP_TITLE[type] || type}
        <span class="gs-section-count">${list.length}</span>
      </div>`;
      list.forEach((item) => {
        html += `<a
          href="${item.path}"
          class="gs-result-item"
          role="option"
          id="gs-option-${idx}"
          aria-selected="false"
          data-idx="${idx}"
          tabindex="-1"
        >
          <div class="gs-result-left">
            <div class="gs-emoji-box gs-c-${type}" aria-hidden="true">${TYPE_EMOJI[type] || "•"}</div>
            <div class="gs-result-info">
              <span class="gs-result-name">${highlight(item.name, q)}</span>
              ${item.sub ? `<span class="gs-result-sub">${escHtml(item.sub)}</span>` : ""}
            </div>
          </div>
          <span class="gs-type-tag gs-t-${type}" aria-hidden="true">${type}</span>
        </a>`;
        idx++;
      });
    }

    /* Keyboard hint footer */
    html += `<div class="gs-footer-hint" aria-hidden="true">
      <span class="gs-hint-pair"><kbd>↑</kbd><kbd>↓</kbd> Navigate</span>
      <span class="gs-hint-pair"><kbd>↵</kbd> Open</span>
      <span class="gs-hint-pair"><kbd>Esc</kbd> Close</span>
    </div>`;

    dropdown.innerHTML = html;
    openDropdown(dropdown, combobox);
  }

  function openDropdown(dropdown, combobox) {
    dropdown.style.display = "block";
    if (combobox) combobox.setAttribute("aria-expanded", "true");
  }
  function closeDropdown(dropdown, combobox) {
    dropdown.style.display = "none";
    if (combobox) combobox.setAttribute("aria-expanded", "false");
  }

  /* ── Keyboard navigation state ── */
  let activeIndex = -1;

  function getOptions(dropdown) {
    return Array.from(dropdown.querySelectorAll(".gs-result-item[role='option']"));
  }

  function setActive(dropdown, input, idx) {
    const options = getOptions(dropdown);
    if (!options.length) return;

    /* clamp */
    if (idx < -1) idx = options.length - 1;
    if (idx >= options.length) idx = -1;
    activeIndex = idx;

    options.forEach((opt, i) => {
      const active = i === idx;
      opt.setAttribute("aria-selected", String(active));
      if (active) {
        opt.classList.add("gs-active");
        input.setAttribute("aria-activedescendant", opt.id);
        /* scroll into view without jumping the page */
        opt.scrollIntoView({ block: "nearest", inline: "nearest" });
      } else {
        opt.classList.remove("gs-active");
      }
    });

    if (idx === -1) input.setAttribute("aria-activedescendant", "");
  }

  /* ── Main init ── */
  function initHeroSearch() {
    const input = document.getElementById("heroSearch");
    const clearBtn = document.getElementById("heroClear");
    const dropdown = document.getElementById("heroSuggestions");
    const combobox = document.getElementById("heroSearchBox");
    if (!input) return;

    /* typing */
    input.addEventListener("input", (e) => {
      const q = e.target.value;
      clearBtn.style.display = q ? "flex" : "none";
      activeIndex = -1;
      input.setAttribute("aria-activedescendant", "");
      buildDropdown(q, dropdown, combobox);
    });

    /* clear button */
    clearBtn?.addEventListener("click", () => {
      input.value = "";
      clearBtn.style.display = "none";
      closeDropdown(dropdown, combobox);
      activeIndex = -1;
      input.setAttribute("aria-activedescendant", "");
      input.focus();
    });

    /* keyboard navigation */
    input.addEventListener("keydown", (e) => {
      if (dropdown.style.display === "none") return;
      const options = getOptions(dropdown);

      switch (e.key) {
        case "ArrowDown":
          e.preventDefault();
          setActive(dropdown, input, activeIndex + 1);
          break;
        case "ArrowUp":
          e.preventDefault();
          setActive(dropdown, input, activeIndex - 1);
          break;
        case "Enter":
          e.preventDefault();
          if (activeIndex >= 0 && options[activeIndex]) {
            options[activeIndex].click();
          }
          break;
        case "Escape":
          closeDropdown(dropdown, combobox);
          activeIndex = -1;
          input.setAttribute("aria-activedescendant", "");
          input.blur();
          break;
        case "Tab":
          closeDropdown(dropdown, combobox);
          activeIndex = -1;
          break;
      }
    });

    /* mouse hover sync */
    dropdown.addEventListener("mousemove", (e) => {
      const item = e.target.closest(".gs-result-item[role='option']");
      if (!item) return;
      const idx = parseInt(item.dataset.idx, 10);
      if (!isNaN(idx)) setActive(dropdown, input, idx);
    });

    /* close on outside click */
    document.addEventListener("click", (e) => {
      if (!e.target.closest(".hero-search__wrap")) {
        closeDropdown(dropdown, combobox);
        activeIndex = -1;
      }
    });

    /* close on focus leaving the wrap */
    document.addEventListener("focusin", (e) => {
      if (!e.target.closest(".hero-search__wrap")) {
        closeDropdown(dropdown, combobox);
        activeIndex = -1;
      }
    });
  }

  /* ── Spacer ── */
  function updateSpacer() {
    const header = document.querySelector(".header");
    const heroSearch = document.querySelector(".hero-search");
    const spacer = document.getElementById("headerSpacer");
    if (!header || !spacer) return;

    // Both .header and .hero-search are position:fixed (per header.css)
    // so they are fully out of document flow.
    // Spacer must equal their combined height so page content
    // starts exactly below the search bar — no gap, no overlap.
    const headerRect = header.getBoundingClientRect();
    const searchRect = heroSearch ? heroSearch.getBoundingClientRect() : { height: 0 };

    const totalH = headerRect.height + searchRect.height;

    // Set CSS var for hero-search top: positioning
    document.documentElement.style.setProperty("--header-h", headerRect.height + "px");

    // Override header.css spacer height (height:0 / 130px / 120px)
    // with the real measured value
    spacer.style.setProperty("height", totalH + "px", "important");
  }

  /* ── Theme ── */
  const sunIcon = `<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`;
  const moonIcon = `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`;

  function applyThemeStyles(theme) {
    const html = document.documentElement;
    html.setAttribute("data-theme", theme);
    html.classList.toggle("dark", theme === "dark");
    if (theme === "dark") {
      html.style.backgroundColor = "#020608";
      html.style.backgroundImage = "linear-gradient(180deg, #020608 0%, #031a20 50%, #052e38 100%)";
      html.style.backgroundAttachment = "fixed";
      html.style.backgroundSize = "cover";
    } else {
      html.style.backgroundColor = "#ffffff";
      html.style.backgroundImage = "none";
      html.style.backgroundAttachment = "";
      html.style.backgroundSize = "";
    }
    if (document.body) {
      document.body.style.backgroundColor = "transparent";
      document.body.style.backgroundImage = "none";
    }
  }

  function updateThemeIcon() {
    const theme = localStorage.getItem("theme") || "light";
    const themeIcon = document.getElementById("themeIcon");
    const mobileThemeIcon = document.getElementById("mobileThemeIcon");
    if (themeIcon) themeIcon.innerHTML = theme === "dark" ? sunIcon : moonIcon;
    if (mobileThemeIcon) mobileThemeIcon.innerHTML = theme === "dark" ? sunIcon : moonIcon;
  }

  function initThemeToggle() {
    const headerThemeToggle = document.getElementById("headerThemeToggle");
    const mobileThemeToggle = document.getElementById("mobileThemeToggle");
    function toggleTheme() {
      const current = localStorage.getItem("theme") || "light";
      const next = current === "dark" ? "light" : "dark";
      localStorage.setItem("theme", next);
      applyThemeStyles(next);
      updateThemeIcon();
    }
    headerThemeToggle?.addEventListener("click", toggleTheme);
    mobileThemeToggle?.addEventListener("click", toggleTheme);
    applyThemeStyles(localStorage.getItem("theme") || "light");
    updateThemeIcon();
  }

  /* ── Hamburger ── */
  function initHamburger() {
    const hamburger = document.getElementById("hamburger");
    const mobileMenu = document.getElementById("mobileMenu");
    const mobileOverlay = document.getElementById("mobileOverlay");

    function openMenu() {
      hamburger?.classList.add("open");
      hamburger?.setAttribute("aria-expanded", "true");
      mobileMenu?.classList.add("open");
      mobileOverlay?.classList.add("open");
      mobileOverlay?.removeAttribute("aria-hidden");
      document.body.style.overflow = "hidden";
    }
    function closeMenu() {
      hamburger?.classList.remove("open");
      hamburger?.setAttribute("aria-expanded", "false");
      mobileMenu?.classList.remove("open");
      mobileOverlay?.classList.remove("open");
      mobileOverlay?.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }

    hamburger?.addEventListener("click", () => {
      mobileMenu?.classList.contains("open") ? closeMenu() : openMenu();
    });
    mobileOverlay?.addEventListener("click", closeMenu);
    document.querySelectorAll(".mobile-nav__links a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  /* ── Boot ── */
  function init() {
    document.querySelector(".hero-search__box")?.style.removeProperty("margin-left");
    initHeroSearch();
    initThemeToggle();
    initHamburger();
    updateSpacer();
  }
  window.addEventListener("resize", updateSpacer);

  // Run immediately
  init();

  // Re-run after fonts/images may have shifted layout
  document.addEventListener("DOMContentLoaded", updateSpacer);
  window.addEventListener("load", updateSpacer);

  // Astro view transitions
  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:after-swap", updateSpacer);
</script>
