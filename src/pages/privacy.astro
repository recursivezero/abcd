      // Open a blank popup and write clean content into it
      var printWin = window.open("", "_blank", "width=900,height=700");
      printWin.document.write(`
        <!DOCTYPE html>
        <html lang="en">
        <head>
          <meta charset="UTF-8"/>
          <title>Privacy Policy – abcdkbd.com</title>
          <style>
            *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
            body { font-family: sans-serif; background: #fff; color: #333; padding: 30px 40px; }
            h1 { font-size: 22px; font-weight: 800; color: #1a1a2e; margin-bottom: 6px; }
            .meta { font-size: 11px; color: #888; margin-bottom: 20px; }
            .t-welcome {
              background: #faf8ff; border: 1px solid #ede9fc; border-radius: 10px;
              padding: 14px 18px; margin-bottom: 14px;
              font-size: 13px; font-weight: 600; color: #374151; line-height: 1.65;
              display: flex; gap: 12px; align-items: center;
            }
            .t-star { display: none; }
            .pp-dl-btn { display: none; }
            .t-acc {
              background: #fff; border: 1px solid #e5e7eb; border-radius: 8px;
              margin-bottom: 10px; overflow: hidden;
              page-break-inside: avoid; break-inside: avoid;
            }
            .t-acc-h {
              display: flex; align-items: center; gap: 12px;
              padding: 12px 16px; background: #faf9ff;
            }
            .t-ico {
              width: 34px; height: 34px; border-radius: 50%;
              display: flex; align-items: center; justify-content: center; flex-shrink: 0;
            }
            .t-acc-info h3 { font-size: 14px; font-weight: 800; color: #1a1a2e; margin: 0 0 2px; }
            .t-acc-info p  { font-size: 12px; color: #6b7280; margin: 0; }
            .t-chev { display: none; }
            .t-acc-body {
              display: block !important;
              padding: 10px 16px 14px 62px;
              font-size: 13px; font-weight: 600; color: #4b5563; line-height: 1.75;
              border-top: 1px solid #f0eeff;
            }
            .t-acc-body ul { padding-left: 18px; margin: 6px 0; }
            .t-acc-body li { margin-bottom: 4px; }
            .t-acc-body p  { margin-bottom: 6px; }
            .t-acc-body strong { font-weight: 800; }
            .t-acc-body a  { color: #7c5cbf; text-decoration: none; }
            @page { margin: 1.5cm 1.8cm; size: A4; }
          </style>
        </head>
        <body>
          <h1>Privacy Policy</h1>
          <p class="meta">abcdkbd.com &nbsp;|&nbsp; Last Updated: July 16, 2025</p>
          ${welcome}
          ${sections}
          <script>
            window.onload = function() {
