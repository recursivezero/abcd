---
import "@/assets/styles/draw.css";
import Back from "@/components/BackButton.astro";
import ControlsContainer from "@/components/ControllerContainer.astro";
import DrawComponent from "@/components/DrawKeyboard.astro";
import VirtualKeyboard from "@/components/VirtualKeyboard.astro";
import MobileSplash from "@/components/MobileSplash.astro";
import BaseLayout from "@/layouts/Base";

const meta = {
  title: "Draw",
  description:
    "Practice drawing letters and shapes using your keyboard. An interactive tool for learning letter formation and improving skills."
};
---

<style>
  :global(.content) {
    min-height: 100vh !important;
    height: auto !important;
  }

  :global(.back) {
    position: sticky !important;
    top: 0rem !important;
    left: 0rem !important;
    z-index: 999 !important;
    margin-left: -1.5rem !important;
  }

  :global(.controls) {
    position: static !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
    gap: 0.25rem !important;
    align-items: center !important;
    background: transparent !important;
    top: unset !important;
    right: unset !important;
  }

  :global(.control-group) {
    flex-direction: row !important;
    align-items: center !important;
    gap: 0.25rem !important;
  }

  :global(.nav__links) {
    justify-content: flex-end !important;
    padding-right: 2rem !important;
  }

  :global(.control-button) {
    width: 2.2rem !important;
    height: 2.2rem !important;
    font-size: 0.9rem !important;
  }

  :global(.font-icon),
  :global(.color-icon),
  :global(.bg-icon) {
    font-size: 0.9rem !important;
  }

  :global(.img-icon) {
    width: 0.9rem !important;
    height: 0.9rem !important;
  }

  :global(.mute-button) {
    width: 2.2rem !important;
    height: 2.2rem !important;
    padding: 0 !important;
    font-size: 0.9rem !important;
  }

  :global(.mute-icon) {
    font-size: 1rem !important;
  }

  :global(.help) {
    width: 2.2rem !important;
    height: 2.2rem !important;
    font-size: 1rem !important;
    padding: 0 !important;
  }

  :global(#voice-dropdown) {
    height: 2.2rem !important;
    font-size: 0.75rem !important;
    padding: 0 0.4rem !important;
    border-radius: 9999px !important;
    border: 1.5px solid var(--primary, #3b82f6) !important;
    background: transparent !important;
    cursor: pointer !important;
    width: 5.5rem !important;
  }

  :global(.controls-container svg) {
    width: 1rem !important;
    height: 1rem !important;
  }

  :global(.action__group) {
    max-width: none !important;
    flex-wrap: nowrap !important;
    gap: 0.2rem !important;
  }

  :global([slot="header-right"]) {
    max-width: none !important;
  }

  :global(.controls-container) {
    gap: 0.2rem !important;
    flex-wrap: nowrap !important;
    align-items: center !important;
  }

  :global(.share-trigger-button) {
    width: 2.2rem !important;
    height: 2.2rem !important;
    padding: 0 !important;
    font-size: 0.9rem !important;
    border-radius: 50% !important;
  }

  :global(.share-trigger-button svg) {
    width: 0.85rem !important;
    height: 0.85rem !important;
  }

  :global(.theme-toggle) {
    width: 2.2rem !important;
    height: 2.2rem !important;
  }

  :global(#keyboard-trigger) {
    width: 2.2rem !important;
    height: 2.2rem !important;
  }

  /* Mobile pe saare buttons aur icons same size */
  @media (max-width: 640px) {
    :global(.control-button),
    :global(.mute-button),
    :global(.help),
    :global(#keyboard-trigger),
    :global(.share-trigger-button),
    :global(.theme-toggle) {
      width: 2.2rem !important;
      height: 2.2rem !important;
      min-width: 2.2rem !important;
      min-height: 2.2rem !important;
      font-size: 0.85rem !important;
      padding: 0 !important;
    }

    :global(.font-icon),
    :global(.color-icon),
    :global(.bg-icon),
    :global(.mute-icon) {
      font-size: 0.85rem !important;
    }

    :global(.img-icon) {
      width: 0.85rem !important;
      height: 0.85rem !important;
    }

    :global(.controls-container svg),
    :global(.share-trigger-button svg),
    :global(#keyboard-trigger svg) {
      width: 0.85rem !important;
      height: 0.85rem !important;
    }

    :global(#voice-dropdown) {
      height: 2.2rem !important;
      width: 5.5rem !important;
      font-size: 0.7rem !important;
    }

    :global(.share-button-container) {
      display: flex !important;
      align-items: center !important;
    }

    /* Share popover — body level pe render hoga JS se */
    :global(.share-popover.mobile-teleported) {
      position: fixed !important;
      z-index: 99999 !important;
      left: 0.5rem !important;
      right: 0.5rem !important;
      max-width: calc(100vw - 1rem) !important;
      top: auto !important;
    }
  }
</style>

<BaseLayout meta={meta}>
  <MobileSplash stay={true} />
  <ControlsContainer slot="header-right" />
  <Back />
  <DrawComponent />
  <VirtualKeyboard />
</BaseLayout>

<script>
  function handleControlsPosition() {
    const actionGroup = document.querySelector(".action__group") as HTMLElement | null;
    const heroSearch = document.querySelector(".hero-search") as HTMLElement | null;
    const content = document.getElementById("mainContent");
    const vkContainer = document.getElementById("vk-container");

    if (!actionGroup || !heroSearch) return;

    if (window.innerWidth <= 640) {
      const searchBottom = heroSearch.getBoundingClientRect().bottom;

      actionGroup.style.display = "flex";
      actionGroup.style.position = "fixed";
      actionGroup.style.top = searchBottom + "px";
      actionGroup.style.left = "0";
      actionGroup.style.width = "100%";
      actionGroup.style.background = "var(--background)";
      actionGroup.style.padding = "0.4rem 0.5rem";
      actionGroup.style.zIndex = "998";
      actionGroup.style.borderBottom = "1px solid rgba(124,58,237,0.15)";
      actionGroup.style.justifyContent = "flex-start";
      actionGroup.style.flexWrap = "nowrap";
      actionGroup.style.gap = "0.25rem";
      actionGroup.style.boxSizing = "border-box";
      actionGroup.style.overflowX = "auto";
      actionGroup.style.overflowY = "visible";

      // Theme toggle hide
      const themeToggle = actionGroup.querySelector(".theme-toggle") as HTMLElement | null;
      if (themeToggle) themeToggle.style.display = "none";

      setTimeout(() => {
        const spacer = document.getElementById("headerSpacer");
        if (spacer) {
          const stripBottom = actionGroup.getBoundingClientRect().bottom;
          spacer.style.setProperty("height", stripBottom + "px", "important");
        }
        if (content && vkContainer) {
          const vkH = vkContainer.getBoundingClientRect().height;
          content.style.paddingBottom = vkH + 16 + "px";
        }
      }, 100);
    } else {
      actionGroup.style.cssText = "";
      const themeToggle = actionGroup.querySelector(".theme-toggle") as HTMLElement | null;
      if (themeToggle) themeToggle.style.display = "";
      if (content) content.style.paddingBottom = "";
    }
  }

  function fixSharePopover() {
    if (window.innerWidth > 640) return;

    const shareTrigger = document.getElementById("shareTrigger") as HTMLButtonElement | null;
    const sharePopover = document.getElementById("sharePopover") as HTMLDivElement | null;
    if (!shareTrigger || !sharePopover) return;

    // Popover ko body mein move karo taaki overflow clip na ho
    if (!sharePopover.classList.contains("mobile-teleported")) {
      document.body.appendChild(sharePopover);
      sharePopover.classList.add("mobile-teleported");
    }

    // Position update function
    function updatePopoverPosition() {
      if (!shareTrigger || !sharePopover) return;
      const triggerRect = shareTrigger.getBoundingClientRect();
      const spaceAbove = triggerRect.top;
      const spaceBelow = window.innerHeight - triggerRect.bottom;

      if (spaceAbove > spaceBelow) {
        // Upar dikhao
        sharePopover.style.bottom = window.innerHeight - triggerRect.top + 8 + "px";
        sharePopover.style.top = "auto";
      } else {
        // Neeche dikhao
        sharePopover.style.top = triggerRect.bottom + 8 + "px";
        sharePopover.style.bottom = "auto";
      }
    }

    shareTrigger.addEventListener("click", () => {
      setTimeout(() => {
        if (sharePopover.classList.contains("is-open")) {
          updatePopoverPosition();
        }
      }, 10);
    });
  }

  function init() {
    handleControlsPosition();
    fixSharePopover();
  }

  document.addEventListener("DOMContentLoaded", init);
  window.addEventListener("resize", () => handleControlsPosition());
  window.addEventListener("load", init);
  document.addEventListener("astro:page-load", init);
</script>
