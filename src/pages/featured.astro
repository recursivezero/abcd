---
// src/pages/featured.astro
import Base from "../layouts/Base.astro";
import { featuredGames, FEATURED_MAX } from "../data/FeaturedGames";
import { gamesData } from "../data/gamesData";
import type { Game } from "../data/gamesData";

const allGames: Array<Game & { id: string }> = Object.values(gamesData)
  .flat()
  .map((game) => ({
    ...game,
    id: game.link.replace(/^\//, "").toLowerCase()
  }));

const featured = featuredGames
  .slice(0, FEATURED_MAX)
  .map((id) => allGames.find((g) => g.id === id))
  .filter((g): g is Game & { id: string } => g !== undefined);
---

<Base meta={{ title: "Featured Games" }}>
  <div class="fp-wrap">
    <div class="fp-hdr">
      <h1 class="fp-title">Featured Games <span class="fp-spark">🌟</span></h1>
      <p class="fp-sub">Hand-picked activities your kids will love right now 🎮</p>
    </div>

    {
      featured.length === 0 ? (
        <div class="fp-empty">
          <span>🎲</span>
          <p>No featured games configured yet.</p>
        </div>
      ) : (
        <div class="fp-grid">
          {featured.map((game) => (
            <a href={game.link} class="fp-card" aria-label={`Play ${game.title}`}>
              <div class="fp-badge">⭐ Featured</div>
              <div class="fp-thumb-wrap">
                <img
                  src={game.image}
                  alt={game.title}
                  class="fp-thumb"
                  loading="lazy"
                  onerror="if(this.dataset.errored)return;this.dataset.errored='1';this.onerror=null;this.src='/assets/images/game-placeholder.svg'"
                />
                <div class="fp-overlay" />
              </div>
              <div class="fp-body">
                <div class="fp-tags">
                  {game.tags.slice(0, 2).map((tag) => (
                    <span class="fp-tag">{tag}</span>
                  ))}
                </div>
                <h3 class="fp-game-title">{game.title}</h3>
                <p class="fp-desc">{game.description}</p>
                <div class="fp-footer">
                  <span class="fp-play-btn">
                    <span>▶</span> Play Now
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</Base>

<style>
  .fp-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .fp-hdr {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .fp-title {
    font-size: 2rem;
    font-weight: 900;
    color: #1a1a40;
    margin: 0 0 6px;
  }
  .fp-spark {
    font-size: 1.6rem;
  }
  .fp-sub {
    font-size: 14px;
    color: #888;
    font-weight: 600;
    margin: 0;
  }

  /* Same grid layout as category tiles */
  .fp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin: 0 auto;
  }

  /* Card — mirrors .fg-card exactly */
  .fp-card {
    border-radius: 20px;
    overflow: hidden;
    background: #fff;
    border: 2px solid #e8e8f0;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    position: relative;
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      border-color 0.22s ease;
  }
  .fp-card:hover {
    transform: translateY(-7px);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.13);
    border-color: #c8b8ff;
  }

  .fp-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 3;
    background: linear-gradient(135deg, #7048c0, #d03070);
    color: #fff;
    font-size: 10px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 50px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    box-shadow: 0 2px 8px rgba(112, 72, 192, 0.35);
  }

  .fp-thumb-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #f0eeff;
    flex-shrink: 0;
  }
  .fp-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
    display: block;
  }
  .fp-card:hover .fp-thumb {
    transform: scale(1.06);
  }
  .fp-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(10, 5, 30, 0.35) 100%);
    pointer-events: none;
  }

  .fp-body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 6px;
  }
  .fp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .fp-tag {
    background: #f0eeff;
    color: #7048c0;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }
  .fp-game-title {
    font-size: 15px;
    font-weight: 900;
    color: #1a1a40;
    margin: 0;
    line-height: 1.25;
  }
  .fp-desc {
    font-size: 12px;
    color: #666;
    font-weight: 600;
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .fp-footer {
    margin-top: auto;
    padding-top: 8px;
  }
  .fp-play-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(135deg, #7048c0, #d03070);
    color: #fff;
    font-size: 12px;
    font-weight: 800;
    padding: 7px 16px;
    border-radius: 50px;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
  .fp-card:hover .fp-play-btn {
    opacity: 0.92;
    transform: scale(1.04);
  }

  .fp-empty {
    text-align: center;
    padding: 3rem;
    background: #f9f7ff;
    border-radius: 20px;
    border: 2px dashed #d2caff;
  }
  .fp-empty span {
    font-size: 3rem;
    display: block;
    margin-bottom: 12px;
  }
  .fp-empty p {
    color: #7048c0;
    font-weight: 700;
  }

  /* Dark mode */
  :global([data-theme="dark"]) .fp-title {
    color: #e0f7fa;
  }
  :global([data-theme="dark"]) .fp-sub {
    color: #aaa;
  }
  :global([data-theme="dark"]) .fp-card {
    background: rgba(3, 26, 32, 0.72);
    border-color: rgba(34, 211, 238, 0.12);
    backdrop-filter: blur(10px);
  }
  :global([data-theme="dark"]) .fp-card:hover {
    border-color: rgba(34, 211, 238, 0.3);
    box-shadow:
      0 12px 30px rgba(0, 0, 0, 0.45),
      0 0 22px rgba(34, 211, 238, 0.12);
  }
  :global([data-theme="dark"]) .fp-game-title {
    color: #7dd3fc;
  }
  :global([data-theme="dark"]) .fp-desc {
    color: #94a3b8;
  }
  :global([data-theme="dark"]) .fp-tag {
    background: rgba(34, 211, 238, 0.12);
    color: #7dd3fc;
  }
  :global([data-theme="dark"]) .fp-thumb-wrap {
    background: rgba(112, 72, 192, 0.2);
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .fp-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 860px) {
    .fp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .fp-wrap {
      padding: 2rem 1rem 3rem;
    }
    .fp-grid {
      grid-template-columns: 1fr;
    }
    .fp-title {
      font-size: 1.6rem;
    }
  }
</style>
