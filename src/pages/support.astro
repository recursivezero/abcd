---
import BaseLayout from "@/layouts/Base";

const meta = {
  title: "Support & Help Center",
  description: "Get help, support, and answers to your questions about abcdkbd.com."
};

const faqs = [
  {
    icon: "❓",
    iconColor: "#7c3aed",
    iconBg: "#ede9fe",
    question: "How do I start learning?",
    answer: `Just visit the <a href="/" class="s-link">Home</a> page and click on any topic.<br/>No login or registration is required. Start exploring and learning!`,
    open: true
  },
  {
    icon: "📱",
    iconColor: "#2563eb",
    iconBg: "#dbeafe",
    question: "Does this work on mobile?",
    answer: "Yes! Our website is almost responsive but best works on desktop and tablets."
  },
  {
    icon: "🛡️",
    iconColor: "#16a34a",
    iconBg: "#dcfce7",
    question: "Is this app safe for children?",
    answer: "Absolutely. We are ad-free and designed with child safety and simplicity in mind."
  },
  {
    icon: "📶",
    iconColor: "#d97706",
    iconBg: "#fef3c7",
    question: "Can I use it offline?",
    answer: "Some activities support offline mode <em>(coming soon)</em>. Stay tuned for updates!"
  },
  {
    icon: "🚩",
    iconColor: "#dc2626",
    iconBg: "#fee2e2",
    question: "How do I report inappropriate content or a bug?",
    answer: `Please contact us at <a href="mailto:abcdkbd@outlook.com" class="s-link">abcdkbd@outlook.com</a> with details and screenshots if possible.`
  },
  {
    icon: "👤",
    iconColor: "#7c3aed",
    iconBg: "#ede9fe",
    question: "Do you collect personal information?",
    answer: `We collect only minimal non-personal data for better experience.<br/>For more details, please read our <a href="/privacy" class="s-link">Privacy Policy</a>.`
  },
  {
    icon: "🎓",
    iconColor: "#2563eb",
    iconBg: "#dbeafe",
    question: "How can teachers use ABCDKBD?",
    answer: `Visit our <a href="/teachers" class="s-link">Teacher's Corner</a> to access resources, printables and integration support.`
  },
  {
    icon: "✉️",
    iconColor: "#d97706",
    iconBg: "#fef3c7",
    question: "Who can I contact for more help?",
    answer: `You can email us at <a href="mailto:abcdkbd@outlook.com" class="s-link">abcdkbd@outlook.com</a>. We're happy to help!`
  }
];
---

<style is:inline>
  @import url("https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap");

  .s-wrap {
    max-width: 1450px;
    width: 100%;
    margin: 0 auto;
    padding: 30px 40px 60px;
    font-family: "Nunito", sans-serif;
  }

  /* ── HERO IMAGE ── */
  .s-hero-image {
    display: block;
    margin-bottom: 30px;
    width: 100%;
  }
  .s-hero-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── HOW CAN WE HELP ── */
  .s-help-heading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    font-size: 1.4rem;
    font-weight: 800;
    color: #4338ca;
    margin-bottom: 1.5rem;
  }
  .s-heading-line {
    flex: 0 0 40px;
    height: 2px;
    background: #c7d2fe;
    border-radius: 2px;
  }

  .s-help-cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .s-help-card {
    background: #fff;
    border: 1.5px solid #ede9fc;
    border-radius: 18px;
    padding: 1.3rem 1rem;
    text-align: center;
    box-shadow: 0 2px 12px rgba(124, 92, 191, 0.06);
    transition:
      box-shadow 0.2s,
      transform 0.2s;
    cursor: pointer;
  }
  .s-help-card:hover {
    box-shadow: 0 4px 18px rgba(99, 102, 241, 0.13);
    transform: translateY(-2px);
  }
  .s-help-icon {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin: 0 auto 0.75rem;
  }
  .s-help-card h3 {
    font-size: 0.95rem;
    font-weight: 800;
    color: #1f2937;
    margin: 0 0 0.35rem;
  }
  .s-help-card p {
    font-size: 0.82rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.45;
  }

  /* ── BODY GRID ── */
  .s-body {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ── SIDEBAR ── */
  .s-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .s-box {
    background: #fff;
    border: 1.5px solid #ede9fc;
    border-radius: 18px;
    padding: 1.3rem 1.4rem;
    box-shadow: 0 2px 12px rgba(124, 92, 191, 0.06);
    font-size: 0.88rem;
    color: #374151;
    line-height: 1.65;
  }

  .s-box-title {
    font-size: 1rem;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .s-box-title.blue {
    color: #4338ca;
  }

  .s-box p {
    margin: 0.3rem 0 0.7rem;
  }

  .s-checklist {
    list-style: none;
    padding: 0;
    margin: 0 0 0.6rem;
  }
  .s-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
    margin-bottom: 0.3rem;
    font-size: 0.86rem;
  }

  .s-contact-email {
    display: inline-block;
    color: #4338ca;
    font-weight: 700;
    font-size: 0.86rem;
    text-decoration: none;
    background: #ede9fe;
    padding: 0.35rem 0.85rem;
    border-radius: 8px;
    margin-bottom: 0.75rem;
  }
  .s-contact-email:hover {
    background: #ddd6fe;
  }

  .s-reply-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.83rem;
    color: #6b7280;
  }
  .s-reply-row strong {
    color: #4338ca;
  }

  .s-teachers-btn {
    display: inline-block;
    background: #7c5cbf;
    color: #fff;
    text-decoration: none;
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
    font-size: 0.86rem;
    font-weight: 800;
    margin-top: 0.6rem;
    transition:
      background 0.15s,
      transform 0.1s;
    letter-spacing: 0.01em;
  }
  .s-teachers-btn:hover {
    background: #6344a8;
    transform: translateY(-1px);
  }

  /* ── FAQ ── */
  .s-faq-section {
  }

  .s-faq-heading {
    font-size: 1.35rem;
    font-weight: 800;
    color: #6c6ccf;
    margin: 0 0 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .s-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .s-acc {
    background: #fff;
    border: 1.5px solid #ede9fc;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(124, 92, 191, 0.05);
    transition: box-shadow 0.2s;
  }
  .s-acc:hover {
    box-shadow: 0 4px 18px rgba(124, 92, 191, 0.1);
  }
  .s-acc.open {
    box-shadow: 0 4px 18px rgba(124, 92, 191, 0.12);
  }

  .s-acc-h {
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 14px 18px;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
  }
  .s-acc-h:hover {
    background: #faf9ff;
  }

  .s-acc-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
    flex-shrink: 0;
  }

  .s-acc-info {
    flex: 1;
    min-width: 0;
  }
  .s-acc-info h3 {
    font-size: 15px;
    font-weight: 800;
    color: #4338ca;
    margin: 0;
    line-height: 1.4;
  }

  .s-chev {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #f3f0fd;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition:
      transform 0.22s,
      background 0.15s;
  }
  .s-acc.open .s-chev {
    transform: rotate(180deg);
    background: #7c5cbf;
  }
  .s-acc.open .s-chev svg path {
    stroke: #fff;
  }

  .s-acc-body {
    display: none;
    padding: 4px 18px 16px 69px;
    font-size: 13.5px;
    font-weight: 600;
    color: #4b5563;
    line-height: 1.75;
    border-top: 1.5px solid #f3f0fd;
  }
  .s-acc.open .s-acc-body {
    display: block;
  }

  .s-link {
    color: #7c5cbf;
    text-decoration: none;
    font-weight: 700;
  }
  .s-link:hover {
    text-decoration: underline;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .s-body {
      grid-template-columns: 1fr;
    }
    .s-help-cards {
      grid-template-columns: repeat(2, 1fr);
    }
    .s-wrap {
      padding: 20px 16px 40px;
    }
  }
</style>

<BaseLayout meta={meta}>
  <div class="s-wrap">
    <!-- HERO IMAGE (full width, exactly like terms.astro) -->
    <div class="s-hero-image">
      <img src="/assets/images/hero-support.png" alt="Support & Help Center" />
    </div>

    <!-- HOW CAN WE HELP -->
    <h2 class="s-help-heading">
      <span class="s-heading-line"></span>
      How can we help you?
      <span class="s-heading-line"></span>
    </h2>

    <div class="s-help-cards">
      <div class="s-help-card">
        <div class="s-help-icon" style="background:#ede9fe;">❓</div>
        <h3>Common Questions</h3>
        <p>Find answers to frequently asked questions.</p>
      </div>
      <div class="s-help-card">
        <div class="s-help-icon" style="background:#dbeafe;">🔧</div>
        <h3>Technical Help</h3>
        <p>Get help for technical issues.</p>
      </div>
      <div class="s-help-card">
        <div class="s-help-icon" style="background:#dcfce7;">🛡️</div>
        <h3>Safety &amp; Privacy</h3>
        <p>Learn about safety, privacy &amp; policies.</p>
      </div>
      <div class="s-help-card">
        <div class="s-help-icon" style="background:#fef3c7;">✉️</div>
        <h3>Contact Support</h3>
        <p>Still need help? Reach out to us.</p>
      </div>
      <div class="s-help-card">
        <div class="s-help-icon" style="background:#fce7f3;">🎓</div>
        <h3>For Teachers</h3>
        <p>Resources and support for educators.</p>
      </div>
    </div>

    <!-- BODY: SIDEBAR + FAQ -->
    <div class="s-body">
      <!-- SIDEBAR -->
      <div class="s-sidebar">
        <div class="s-box">
          <h3 class="s-box-title">👋 Need Help?</h3>
          <p>We're here to ensure your learning experience is smooth and enjoyable for everyone.</p>
          <ul class="s-checklist">
            <li>✅ For Parents</li>
            <li>✅ For Teachers</li>
            <li>✅ For Students</li>
          </ul>
        </div>

        <div class="s-box">
          <h3 class="s-box-title blue">✉️ Contact Support</h3>
          <p>Still facing issues?<br />Have suggestions or ideas?<br />We'd love to hear from you!</p>
          <a href="mailto:abcdkbd@outlook.com" class="s-contact-email">abcdkbd@outlook.com</a>
          <div class="s-reply-row">
            <span>🕐</span>
            <span>We typically reply within <strong>24 hours</strong></span>
          </div>
        </div>

        <div class="s-box">
          <h3 class="s-box-title">🏫 For Teachers &amp; Schools</h3>
          <p>Want to use ABCDKBD in your classroom or curriculum?</p>
          <ul class="s-checklist">
            <li>✅ Visit our <strong>Teacher's Corner</strong></li>
            <li>✅ Reach out for integration help and printable resources.</li>
          </ul>
          <a href="/teachers" class="s-teachers-btn">Go to Teacher's Corner &rarr;</a>
        </div>
      </div>

      <!-- FAQ -->
      <div class="s-faq-section">
        <h2 class="s-faq-heading">📌 Common Questions</h2>

        <div class="s-faq-list">
          {
            faqs.map((faq, i) => (
              <div class={`s-acc${faq.open ? " open" : ""}`} id={`s${i}`}>
                <div class="s-acc-h" onclick={`sToggle(${i})`}>
                  <div class="s-acc-icon" style={`background:${faq.iconBg};`}>
                    {faq.icon}
                  </div>
                  <div class="s-acc-info">
                    <h3>{faq.question}</h3>
                  </div>
                  <span class="s-chev">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                      <path
                        d="M6 9l6 6 6-6"
                        stroke="#7c5cbf"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </div>
                <div class="s-acc-body" set:html={faq.answer} />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
