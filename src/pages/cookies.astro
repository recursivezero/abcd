---
import BaseLayout from "@/layouts/Base";

const meta = {
  title: "Cookies Policy",
  description: "Read about our cookie policy and how we use cookies on abcdkbd.com to improve your experience."
};
---

<style is:inline>
  /* ── GOOGLE FONT ── */
  @import url("https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap");

  .c-wrap {
    max-width: 1450px;
    width: 100%;
    margin: 0 auto;
    padding: 30px 40px 60px;
    font-family: "Nunito", sans-serif;
  }

  /* ── HERO ── */
  .cookies-hero-image {
    display: block;
    margin-bottom: 30px;
    width: 100%;
  }
  .cookies-hero-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── BODY GRID ── */
  .c-body {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ── SIDEBAR ── */
  .c-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .c-box {
    background: #fff;
    border: 1.5px solid #ede9fc;
    border-radius: 18px;
    padding: 1.3rem 1.4rem;
    box-shadow: 0 2px 12px rgba(124, 92, 191, 0.06);
  }

  .c-box-title {
    font-size: 11px;
    font-weight: 800;
    color: #a78bfa;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.85rem;
    display: block;
  }

  /* TOC */
  .c-toc {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .c-toc li {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 8px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .c-toc li:hover {
    background: #f5f3ff;
  }
  .c-toc li span.lbl {
    font-size: 15px;
    font-weight: 700;
    color: #374151;
  }

  /* Number badges */
  .n {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    flex-shrink: 0;
  }
  .n1 {
    background: #ede9fe;
    color: #7c3aed;
  }
  .n2 {
    background: #dbeafe;
    color: #1d4ed8;
  }
  .n3 {
    background: #dcfce7;
    color: #15803d;
  }
  .n4 {
    background: #fef3c7;
    color: #b45309;
  }
  .n5 {
    background: #fce7f3;
    color: #be185d;
  }
  .n6 {
    background: #e0f2fe;
    color: #0369a1;
  }

  /* ── PRIVACY MATTERS BOX ── */
  .c-box.privacy {
    text-align: center;
    padding: 1.4rem 1.3rem 1.5rem;
  }

  .c-privacy-icon {
    width: 58px;
    height: 58px;
    background: linear-gradient(135deg, #9b72e6 0%, #7c5cbf 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.7rem;
    box-shadow: 0 4px 12px rgba(124, 92, 191, 0.3);
  }

  .c-box.privacy h4 {
    font-size: 15px;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 4px;
  }
  .c-box.privacy p {
    font-size: 13px;
    color: #6b7280;
    margin: 0 0 0.9rem;
    line-height: 1.55;
  }

  .c-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #7c5cbf;
    color: #fff;
    border-radius: 999px;
    padding: 9px 22px;
    font-size: 13.5px;
    font-weight: 800;
    font-family: "Nunito", sans-serif;
    text-decoration: none;
    transition:
      background 0.15s,
      transform 0.1s;
    letter-spacing: 0.01em;
  }
  .c-btn:hover {
    background: #6344a8;
    transform: translateY(-1px);
  }
  .c-btn .arr {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    font-size: 12px;
    line-height: 1;
  }

  /* ── LAST UPDATED BOX ── */
  .c-box.updated {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .c-updated-icon {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    margin-top: 2px;
    background: #ede9fe;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .c-box.updated h4 {
    font-size: 14px;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 4px;
  }
  .c-box.updated p {
    font-size: 12.5px;
    color: #6b7280;
    line-height: 1.55;
    margin: 0;
  }
  .c-box.updated span.date {
    color: #7c5cbf;
    font-weight: 800;
  }

  /* ── CONTENT AREA ── */
  .c-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  /* Intro banner */
  .c-welcome {
    background: #fff;
    border: 1.5px solid #ede9fc;
    border-radius: 18px;
    padding: 1.1rem 1.3rem;
    display: flex;
    gap: 14px;
    align-items: center;
    box-shadow: 0 2px 12px rgba(124, 92, 191, 0.06);
  }
  .c-star {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #9b72e6 0%, #7c5cbf 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #fff;
    font-size: 18px;
    box-shadow: 0 2px 8px rgba(124, 92, 191, 0.3);
  }
  .c-welcome p {
    font-size: 13.5px;
    font-weight: 600;
    color: #374151;
    line-height: 1.65;
    margin: 0;
  }

  /* ── ACCORDION ── */
  .c-acc {
    background: #fff;
    border: 1.5px solid #ede9fc;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(124, 92, 191, 0.05);
    transition: box-shadow 0.2s;
  }
  .c-acc:hover {
    box-shadow: 0 4px 18px rgba(124, 92, 191, 0.1);
  }
  .c-acc.open {
    box-shadow: 0 4px 18px rgba(124, 92, 191, 0.12);
  }

  .c-acc-h {
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 16px 20px;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
  }
  .c-acc-h:hover {
    background: #faf9ff;
  }

  .c-ico {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .c-acc-info {
    flex: 1;
    min-width: 0;
  }
  .c-acc-info h3 {
    font-size: 15.5px;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 3px;
  }
  .c-acc-info p {
    font-size: 13px;
    font-weight: 600;
    color: #6b7280;
    margin: 0;
  }

  /* Chevron */
  .c-chev {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #f3f0fd;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition:
      transform 0.22s,
      background 0.15s;
  }
  .c-chev svg {
    display: block;
  }
  .c-acc.open .c-chev {
    transform: rotate(180deg);
    background: #7c5cbf;
  }
  .c-acc.open .c-chev svg path {
    stroke: #fff;
  }

  /* Expanded body */
  .c-acc-body {
    display: none;
    padding: 4px 20px 18px 73px;
    font-size: 13.5px;
    font-weight: 600;
    color: #4b5563;
    line-height: 1.78;
    border-top: 1.5px solid #f3f0fd;
  }
  .c-acc.open .c-acc-body {
    display: block;
  }
  .c-acc-body a {
    color: #7c5cbf;
    text-decoration: none;
  }
  .c-acc-body a:hover {
    text-decoration: underline;
  }
  .c-acc-body ul {
    margin: 6px 0 4px;
    padding-left: 18px;
  }
  .c-acc-body li {
    margin-bottom: 3px;
  }

  /* Cookie type cards inside accordion */
  .c-type-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin-top: 10px;
  }
  .c-type-card {
    border-radius: 12px;
    padding: 12px 14px;
    font-size: 13px;
  }
  .c-type-card h5 {
    font-size: 13px;
    font-weight: 800;
    margin: 0 0 5px;
  }
  .c-type-card p {
    font-size: 12px;
    font-weight: 600;
    color: #6b7280;
    margin: 0 0 5px;
  }
  .c-type-card ul {
    margin: 0;
    padding-left: 14px;
    font-size: 12px;
    color: #6b7280;
  }

  /* Control methods row */
  .c-control-row {
    display: flex;
    gap: 10px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .c-control-item {
    flex: 1;
    min-width: 140px;
    background: #f5f3ff;
    border-radius: 12px;
    padding: 10px 12px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }
  .c-control-item .ci-ico {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .c-control-item h6 {
    font-size: 12.5px;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 2px;
  }
  .c-control-item p {
    font-size: 11.5px;
    font-weight: 600;
    color: #6b7280;
    margin: 0;
  }
  .c-control-item a {
    color: #7c5cbf;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .c-body {
      grid-template-columns: 1fr;
    }
    .c-wrap {
      padding: 20px 16px 40px;
    }
    .c-type-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<BaseLayout meta={meta}>
  <div class="c-wrap">
    <!-- HERO IMAGE -->
    <div class="cookies-hero-image">
      <img src="/assets/images/hero-cookies.png" alt="Cookies Policy" />
    </div>

    <!-- BODY -->
    <div class="c-body">
      <!-- ══ SIDEBAR ══ -->
      <div class="c-sidebar">
        <!-- Table of Contents -->
        <div class="c-box">
          <span class="c-box-title">On this page</span>
          <ul class="c-toc">
            <li onclick="cGo(0)"><span class="n n1">1</span><span class="lbl">What Are Cookies?</span></li>
            <li onclick="cGo(1)"><span class="n n2">2</span><span class="lbl">Types of Cookies We Use</span></li>
            <li onclick="cGo(2)"><span class="n n3">3</span><span class="lbl">How You Can Control Cookies</span></li>
            <li onclick="cGo(3)"><span class="n n4">4</span><span class="lbl">Third-Party Cookies</span></li>
            <li onclick="cGo(4)"><span class="n n5">5</span><span class="lbl">Updates to This Policy</span></li>
            <li onclick="cGo(5)"><span class="n n6">6</span><span class="lbl">Contact Us</span></li>
          </ul>
        </div>

        <!-- Your Privacy Matters -->
        <div class="c-box privacy">
          <div class="c-privacy-icon">
            <svg
              width="26"
              height="26"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#fff"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              <path d="M9 12l2 2 4-4"></path>
            </svg>
          </div>
          <h4>Your Privacy Matters</h4>
          <p>We respect your privacy and are committed to being transparent about how we use cookies.</p>
          <a href="/contact" class="c-btn">
            Contact Us
            <span class="arr">›</span>
          </a>
        </div>

        <!-- Last Updated -->
        <div class="c-box updated">
          <div class="c-updated-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#7c3aed"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </div>
          <div>
            <h4>Last Updated</h4>
            <p>This policy was last updated on <span class="date">July 16, 2025</span>.</p>
          </div>
        </div>
      </div>
      <!-- END SIDEBAR -->

      <!-- ══ MAIN CONTENT ══ -->
      <div class="c-content">
        <!-- Intro Banner -->
        <div class="c-welcome">
          <div class="c-star">🍪</div>
          <p>
            This policy explains how <strong>abcdkbd.com</strong> uses cookies and similar technologies to improve your experience.<br
            />
            By continuing to use our site, you agree to our use of cookies as described below.
          </p>
        </div>

        <!-- 1. What Are Cookies? -->
        <div class="c-acc" id="c0">
          <div class="c-acc-h" onclick="cToggle(0)">
            <div class="c-ico" style="background:#ede9fe">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#7c3aed"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="8.5" cy="10" r="1.5" fill="#7c3aed"></circle>
                <circle cx="15.5" cy="10" r="1.5" fill="#7c3aed"></circle>
                <circle cx="12" cy="15" r="1" fill="#7c3aed"></circle>
                <circle cx="9" cy="14" r="0.8" fill="#7c3aed"></circle>
                <circle cx="15" cy="14" r="0.8" fill="#7c3aed"></circle>
              </svg>
            </div>
            <div class="c-acc-info">
              <h3>1. What Are Cookies?</h3>
              <p>Small text files stored on your device when you visit a website.</p>
            </div>
            <span class="c-chev">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <path
                  d="M6 9l6 6 6-6"
                  stroke="#7c5cbf"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </div>
          <div class="c-acc-body">
            Cookies are small text files stored on your device when you visit a website. They help the site remember
            your preferences and improve your experience on future visits. Cookies do <strong>not</strong> contain personal
            information like your name or password — they simply help the website function better.
          </div>
        </div>

        <!-- 2. Types of Cookies We Use -->
        <div class="c-acc" id="c1">
          <div class="c-acc-h" onclick="cToggle(1)">
            <div class="c-ico" style="background:#dbeafe">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#1d4ed8"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                <polyline points="2 17 12 22 22 17"></polyline>
                <polyline points="2 12 12 17 22 12"></polyline>
              </svg>
            </div>
            <div class="c-acc-info">
              <h3>2. Types of Cookies We Use</h3>
              <p>We use four categories of cookies on abcdkbd.com.</p>
            </div>
            <span class="c-chev">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <path
                  d="M6 9l6 6 6-6"
                  stroke="#7c5cbf"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </div>
          <div class="c-acc-body">
            We use the following types of cookies to operate and improve our platform:
            <div class="c-type-grid">
              <!-- Essential -->
              <div class="c-type-card" style="background:#f0fdf4; border: 1.5px solid #bbf7d0;">
                <h5 style="color:#15803d;">🛡️ a. Essential Cookies</h5>
                <p>Necessary for the website to function properly.</p>
                <ul>
                  <li>Session management</li>
                  <li>Login / authentication</li>
                  <li>Security</li>
                </ul>
              </div>
              <!-- Analytics -->
              <div class="c-type-card" style="background:#eff6ff; border: 1.5px solid #bfdbfe;">
                <h5 style="color:#1d4ed8;">📊 b. Analytics Cookies</h5>
                <p>Used to collect anonymous usage data to improve our website.</p>
                <ul>
                  <li>Page views, clicks, and user flow</li>
                  <li>Device / browser info</li>
                </ul>
              </div>
              <!-- Preference -->
              <div class="c-type-card" style="background:#fefce8; border: 1.5px solid #fde68a;">
                <h5 style="color:#b45309;">⚙️ c. Preference Cookies</h5>
                <p>Remember your choices, such as:</p>
                <ul>
                  <li>Language selection</li>
                  <li>Theme (light / dark mode)</li>
                </ul>
              </div>
              <!-- Marketing -->
              <div class="c-type-card" style="background:#fdf2f8; border: 1.5px solid #f9a8d4;">
                <h5 style="color:#be185d;">📢 d. Marketing / Third-Party Cookies</h5>
                <p>Used to deliver personalized ads or integrate third-party tools.</p>
                <ul>
                  <li>Google Ads</li>
                  <li>Social media embeds (YouTube, etc.)</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- 3. How You Can Control Cookies -->
        <div class="c-acc" id="c2">
          <div class="c-acc-h" onclick="cToggle(2)">
            <div class="c-ico" style="background:#dcfce7">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#15803d"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="3"></circle>
                <path
                  d="M19.07 4.93l-1.41 1.41M4.93 4.93l1.41 1.41M4.93 19.07l1.41-1.41M19.07 19.07l-1.41-1.41M21 12h-2M5 12H3M12 3V1M12 23v-2"
                ></path>
              </svg>
            </div>
            <div class="c-acc-info">
              <h3>3. How You Can Control Cookies</h3>
              <p>You can manage or delete cookies via browser settings or our cookie banner.</p>
            </div>
            <span class="c-chev">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <path
                  d="M6 9l6 6 6-6"
                  stroke="#7c5cbf"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </div>
          <div class="c-acc-body">
            You can manage or delete cookies at any time through the following methods:
            <div class="c-control-row">
              <div class="c-control-item">
                <div class="ci-ico" style="background:#dbeafe;">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#1d4ed8"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <h6>Browser Settings</h6>
                  <p>Clear cookies, block third-party cookies directly from your browser.</p>
                </div>
              </div>
              <div class="c-control-item">
                <div class="ci-ico" style="background:#dcfce7;">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#15803d"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  </svg>
                </div>
                <div>
                  <h6>Cookie Banner</h6>
                  <p>On our site, accept or decline categories via the cookie consent banner.</p>
                </div>
              </div>
              <div class="c-control-item">
                <div class="ci-ico" style="background:#fef3c7;">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#b45309"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                    <polyline points="2 17 12 22 22 17"></polyline>
                  </svg>
                </div>
                <div>
                  <h6>Tools Like <a href="https://youradchoices.com" target="_blank">YourAdChoices</a></h6>
                  <p>For ad personalization preferences.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 4. Third-Party Cookies -->
        <div class="c-acc" id="c3">
          <div class="c-acc-h" onclick="cToggle(3)">
            <div class="c-ico" style="background:#fef3c7">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#b45309"
