---
import BaseLayout from "@/layouts/Base";

const meta = {
  title: "Cookies Policy",
  description: "Read about our cookie policy and how we use cookies on abcdkbd.com to improve your experience."
};
---

<style is:inline>
  * {
    box-sizing: border-box;
  }

  .c-wrap {
    max-width: 1450px;
    width: 100%;
    margin: 0 auto;
    padding: 30px 40px 60px;
    background: #f7f7fb;
  }

  .cookies-hero-image {
    display: block;
    margin-bottom: 24px;
    width: 100%;
  }
  .cookies-hero-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 20px;
  }

  .c-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.2rem;
    align-items: start;
  }

  /* ── SIDEBAR ── */
  .c-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: sticky;
    top: 20px;
  }

  .c-box {
    background: #fff;
    border-radius: 16px;
    padding: 1rem;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
  }

  .c-box-title {
    font-size: 10.5px;
    font-weight: 800;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.65rem;
    display: block;
  }

  .c-toc {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .c-toc li {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 6px 8px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .c-toc li:hover {
    background: #f5f3ff;
  }
  .c-toc li.active {
    background: #f0edff;
  }
  .c-toc li.active span.lbl {
    color: #6d28d9;
    font-weight: 800;
  }
  .c-toc li span.lbl {
    font-size: 13px;
    font-weight: 700;
    color: #374151;
    line-height: 1.3;
  }

  .n {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11.5px;
    font-weight: 800;
    flex-shrink: 0;
  }
  .n1 {
    background: #ede9fe;
    color: #6d28d9;
  }
  .n2 {
    background: #dbeafe;
    color: #1d4ed8;
  }
  .n3 {
    background: #dcfce7;
    color: #15803d;
  }
  .n4 {
    background: #fef3c7;
    color: #b45309;
  }
  .n5 {
    background: #fce7f3;
    color: #be185d;
  }
  .n6 {
    background: #e0f2fe;
    color: #0369a1;
  }

  .c-box.privacy {
    text-align: center;
    padding: 1.2rem 1rem 0.9rem;
  }
  .c-privacy-icon {
    width: 54px;
    height: 54px;
    background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.6rem;
    box-shadow: 0 4px 14px rgba(109, 40, 217, 0.35);
  }
  .c-box.privacy h4 {
    font-size: 14.5px;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 5px;
  }
  .c-box.privacy p {
    font-size: 12px;
    color: #6b7280;
    margin: 0 0 0.85rem;
    line-height: 1.5;
  }
  .c-privacy-deco {
    display: flex;
    justify-content: center;
    margin-top: 0.75rem;
    font-size: 40px;
    line-height: 1;
  }
  .c-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #6d28d9;
    color: #fff;
    border-radius: 999px;
    padding: 9px 20px;
    font-size: 13px;
    font-weight: 800;
    font-family: "Nunito", sans-serif;
    text-decoration: none;
    transition:
      background 0.15s,
      transform 0.1s;
  }
  .c-btn:hover {
    background: #5b21b6;
    transform: translateY(-1px);
  }
  .c-btn .arr {
    width: 20px;
    height: 20px;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 900;
  }

  /* ── CONTENT ── */
  .c-content {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
  }

  .c-section {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.055);
  }

  .c-sec-head {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 18px 20px 16px;
  }

  .c-ico {
    width: 44px;
    height: 44px;
    min-width: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }
  .c-ico svg {
    display: block;
    flex-shrink: 0;
  }

  .c-sec-text {
    flex: 1;
    min-width: 0;
  }
  .c-sec-text h3 {
    font-size: 16.5px;
    font-weight: 800;
    color: #111827;
    margin: 0 0 4px;
  }
  .c-sec-text p.sub {
    font-size: 13px;
    font-weight: 600;
    color: #6b7280;
    margin: 0;
    line-height: 1.55;
  }
  .c-sec-text p.sub strong {
    color: #6d28d9;
  }

  .c-sec-body {
    padding: 0 20px 18px 78px;
    font-size: 13.5px;
    font-weight: 600;
    color: #4b5563;
    line-height: 1.75;
  }
  .c-sec-body a {
    color: #6d28d9;
    text-decoration: none;
  }
  .c-sec-body a:hover {
    text-decoration: underline;
  }
  .c-sec-body ul {
    margin: 4px 0;
    padding-left: 18px;
  }
  .c-sec-body li {
    margin-bottom: 3px;
  }

  /* ── TYPE CARDS 4-col ── */
  .c-type-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-top: 2px;
  }
  .c-type-card {
    border-radius: 14px;
    padding: 16px 14px 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 7px;
  }
  .c-type-card ul {
    text-align: left;
    width: 100%;
  }
  .c-card-ico {
    width: 38px;
    height: 38px;
    min-width: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: 4px;
    overflow: hidden;
  }
  .c-card-ico svg {
    display: block;
    flex-shrink: 0;
  }

  .c-type-card h5 {
    font-size: 13px;
    font-weight: 800;
    margin: 0;
    line-height: 1.35;
  }
  .c-type-card p {
    font-size: 12px;
    font-weight: 600;
    color: #6b7280;
    margin: 0;
    line-height: 1.5;
  }
  .c-type-card ul {
    margin: 2px 0 0;
    padding-left: 14px;
    font-size: 12px;
    color: #6b7280;
    font-weight: 600;
  }
  .c-type-card li {
    margin-bottom: 3px;
  }

  /* ── CONTROL ROW ── */
  .c-control-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 9px;
    margin-top: 8px;
  }
  .c-control-item {
    background: #f5f3ff;
    border-radius: 12px;
    padding: 11px 13px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }
  .ci-ico {
    width: 30px;
    height: 30px;
    min-width: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }
  .ci-ico svg {
    display: block;
    flex-shrink: 0;
  }
  .c-control-item h6 {
    font-size: 12.5px;
    font-weight: 800;
    color: #111827;
    margin: 0 0 2px;
  }
  .c-control-item p {
    font-size: 11.5px;
    font-weight: 600;
    color: #6b7280;
    margin: 0;
    line-height: 1.4;
  }
  .c-control-item a {
    color: #6d28d9;
    font-weight: 800;
  }

  @media (max-width: 1100px) {
    .c-type-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 900px) {
    .c-body {
      grid-template-columns: 1fr;
    }
    .c-wrap {
      padding: 20px 16px 40px;
    }
    .c-sec-body {
      padding-left: 20px;
    }
    .c-control-row {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 600px) {
    .c-type-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<BaseLayout meta={meta}>
  <div class="c-wrap">
    <div class="cookies-hero-image">
      <img src="/assets/images/hero-cookies.png" alt="Cookies Policy" />
    </div>

    <div class="c-body">
      <!-- SIDEBAR -->
      <div class="c-sidebar">
        <div class="c-box">
          <span class="c-box-title">On this page</span>
          <ul class="c-toc">
            <li class="active" onclick="cGo(0)">
              <span class="n n1">1</span><span class="lbl">What Are Cookies?</span>
            </li>
            <li onclick="cGo(1)"><span class="n n2">2</span><span class="lbl">Types of Cookies We Use</span></li>
            <li onclick="cGo(2)"><span class="n n3">3</span><span class="lbl">How You Can Control Cookies</span></li>
            <li onclick="cGo(3)"><span class="n n4">4</span><span class="lbl">Third-Party Cookies</span></li>
            <li onclick="cGo(4)"><span class="n n5">5</span><span class="lbl">Updates to This Policy</span></li>
            <li onclick="cGo(5)"><span class="n n6">6</span><span class="lbl">Contact Us</span></li>
          </ul>
        </div>
        <div class="c-box privacy">
          <div class="c-privacy-icon">
            <!-- Purple shield with checkmark — matches sidebar image exactly -->
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M12 2L4 5.5V11c0 5 3.5 9.3 8 10.5C16.5 20.3 20 16 20 11V5.5L12 2z"
                fill="rgba(255,255,255,0.25)"
                stroke="#fff"
                stroke-width="1.8"
                stroke-linejoin="round"></path>
              <polyline
                points="8.5,12 11,14.5 15.5,9.5"
                stroke="#fff"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                fill="none"></polyline>
            </svg>
          </div>
          <h4>Your Privacy Matters</h4>
          <p>We respect your privacy and are committed to being transparene.</p>
          <a href="/contact" class="c-btn">Contact Us <span class="arr">›</span></a>
          <div class="c-privacy-deco">☁️🔒</div>
        </div>
      </div>

      <!-- MAIN CONTENT -->
      <div class="c-content">
        <!-- 1. What Are Cookies -->
        <div class="c-section" id="c0">
          <div class="c-sec-head">
            <!-- Cookie icon: center circle + 6 radial dots around it -->
            <div class="c-ico" style="background:#ede9fe;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- center filled circle -->
                <circle cx="12" cy="12" r="3.2" fill="#7c3aed"></circle>
                <!-- 6 outer dots evenly spaced in a ring (r=7.5 from center) -->
                <!-- top -->
                <circle cx="12" cy="4.5" r="1.8" fill="#7c3aed"></circle>
                <!-- top-right -->
                <circle cx="18.99" cy="8.25" r="1.8" fill="#7c3aed"></circle>
                <!-- bottom-right -->
                <circle cx="18.99" cy="15.75" r="1.8" fill="#7c3aed"></circle>
                <!-- bottom -->
                <circle cx="12" cy="19.5" r="1.8" fill="#7c3aed"></circle>
                <!-- bottom-left -->
                <circle cx="5.01" cy="15.75" r="1.8" fill="#7c3aed"></circle>
                <!-- top-left -->
                <circle cx="5.01" cy="8.25" r="1.8" fill="#7c3aed"></circle>
              </svg>
            </div>
            <div class="c-sec-text">
              <h3>1. &nbsp;What Are Cookies?</h3>
              <p class="sub">
                Cookies are small text files stored on your device when you visit a website.<br />They help the site
                remember your preferences and improve your experience.
              </p>
            </div>
          </div>
        </div>

        <!-- 2. Types of Cookies We Use -->
        <div class="c-section" id="c1">
          <div class="c-sec-head">
            <!-- Blue stacked layers with gradient fills — matches image -->
            <div class="c-ico" style="background:#dbeafe;">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- bottom layer -->
                <polygon
                  points="13,18.5 2,13 13,7.5 24,13"
                  fill="#93c5fd"
                  stroke="#3b82f6"
                  stroke-width="1.4"
                  stroke-linejoin="round"></polygon>
                <!-- middle layer -->
                <polygon
                  points="13,14 2,8.5 13,3 24,8.5"
                  fill="#bfdbfe"
                  stroke="#2563eb"
                  stroke-width="1.4"
                  stroke-linejoin="round"></polygon>
                <!-- top layer -->
                <polygon
                  points="13,9.5 2,4 13,-1.5 24,4"
                  fill="#dbeafe"
                  stroke="#1d4ed8"
                  stroke-width="1.4"
                  stroke-linejoin="round"></polygon>
                <!-- redraw visible stacked appearance -->
                <polygon
                  points="13,22 3,16.5 13,11 23,16.5"
                  fill="#93c5fd"
                  stroke="#3b82f6"
                  stroke-width="1.5"
                  stroke-linejoin="round"></polygon>
                <polygon
                  points="13,17 3,11.5 13,6 23,11.5"
                  fill="#bfdbfe"
                  stroke="#2563eb"
                  stroke-width="1.5"
                  stroke-linejoin="round"></polygon>
                <polygon
                  points="13,12 3,6.5 13,1 23,6.5"
                  fill="#eff6ff"
                  stroke="#1d4ed8"
                  stroke-width="1.5"
                  stroke-linejoin="round"></polygon>
              </svg>
            </div>
            <div class="c-sec-text">
              <h3>2. &nbsp;Types of Cookies We Use</h3>
            </div>
          </div>
          <div class="c-sec-body">
            <div class="c-type-grid">
              <!-- a. Essential — green shield with bold checkmark -->
              <div class="c-type-card" style="background:#f0fdf4; border:1.5px solid #bbf7d0;">
                <div class="c-card-ico" style="background:#dcfce7;">
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- shield body -->
                    <path
                      d="M11 2L3 5.5V10.5c0 4.8 3.3 8.8 8 9.8 4.7-1 8-5 8-9.8V5.5L11 2z"
                      fill="#86efac"
                      stroke="#16a34a"
                      stroke-width="1.6"
                      stroke-linejoin="round"></path>
                    <!-- inner shield highlight -->
                    <path d="M11 4.5L5.5 7V11c0 3.3 2.3 6.1 5.5 6.8 3.2-.7 5.5-3.5 5.5-6.8V7L11 4.5z" fill="#bbf7d0"
                    ></path>
                    <!-- checkmark -->
                    <polyline
                      points="7.5,11 10,13.5 15,8.5"
                      stroke="#15803d"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      fill="none"></polyline>
                  </svg>
                </div>
                <h5 style="color:#15803d;">a. Essential Cookies</h5>
                <p>These are necessary for the website to function properly.</p>
                <ul>
                  <li>Session management</li>
                  <li>Login/authentication</li>
                  <li>Security</li>
                </ul>
              </div>

              <!-- b. Analytics — blue building/temple columns icon -->
              <div class="c-type-card" style="background:#eff6ff; border:1.5px solid #bfdbfe;">
                <div class="c-card-ico" style="background:#dbeafe;">
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- roof/pediment top -->
                    <path
                      d="M2.5 8.5L11 3.5L19.5 8.5H2.5z"
                      fill="#93c5fd"
                      stroke="#2563eb"
                      stroke-width="1.4"
                      stroke-linejoin="round"></path>
                    <!-- left column -->
                    <rect x="4" y="9" width="3" height="9" rx="0.5" fill="#bfdbfe" stroke="#2563eb" stroke-width="1.2"
                    ></rect>
                    <!-- right column -->
                    <rect x="15" y="9" width="3" height="9" rx="0.5" fill="#bfdbfe" stroke="#2563eb" stroke-width="1.2"
                    ></rect>
                    <!-- middle column -->
                    <rect x="9.5" y="9" width="3" height="9" rx="0.5" fill="#93c5fd" stroke="#2563eb" stroke-width="1.2"
                    ></rect>
                    <!-- base platform -->
                    <rect
                      x="2.5"
                      y="18"
                      width="17"
                      height="2"
                      rx="0.5"
                      fill="#3b82f6"
                      stroke="#1d4ed8"
                      stroke-width="1.2"></rect>
                  </svg>
                </div>
                <h5 style="color:#1d4ed8;">b. Analytics Cookies</h5>
                <p>Used to collect anonymous usage data to improve our website.</p>
                <ul>
                  <li>Page views, clicks, and user flow</li>
                  <li>Device/browser info</li>
                </ul>
              </div>

              <!-- c. Preference — orange hub-and-spoke connected nodes icon -->
              <div class="c-type-card" style="background:#fefce8; border:1.5px solid #fde68a;">
                <div class="c-card-ico" style="background:#fef3c7;">
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- center node -->
                    <circle cx="11" cy="11" r="3.2" fill="#fbbf24" stroke="#d97706" stroke-width="1.8"></circle>
                    <!-- top-left node -->
                    <circle cx="4.5" cy="5.5" r="2.2" fill="#fed7aa" stroke="#d97706" stroke-width="1.6"></circle>
                    <!-- top-right node -->
                    <circle cx="17.5" cy="5.5" r="2.2" fill="#fed7aa" stroke="#d97706" stroke-width="1.6"></circle>
                    <!-- bottom node -->
                    <circle cx="11" cy="18.5" r="2.2" fill="#fed7aa" stroke="#d97706" stroke-width="1.6"></circle>
                    <!-- connecting lines -->
                    <line x1="6.3" y1="7" x2="9.2" y2="9.3" stroke="#d97706" stroke-width="1.5" stroke-linecap="round"
                    ></line>
                    <line x1="15.7" y1="7" x2="12.8" y2="9.3" stroke="#d97706" stroke-width="1.5" stroke-linecap="round"
                    ></line>
                    <line x1="11" y1="14.2" x2="11" y2="16.3" stroke="#d97706" stroke-width="1.5" stroke-linecap="round"
                    ></line>
                  </svg>
                </div>
                <h5 style="color:#b45309;">c. Preference Cookies</h5>
                <p>Remember your choices, such as:</p>
                <ul>
                  <li>Language selection</li>
                  <li>Theme (light/dark mode)</li>
                </ul>
              </div>

              <!-- d. Marketing — red megaphone with small flag/pennant -->
              <div class="c-type-card" style="background:#fdf2f8; border:1.5px solid #f9a8d4;">
                <div class="c-card-ico" style="background:#fce7f3;">
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- megaphone cone body -->
                    <path
                      d="M14.5 5L7 8.5H4a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h3l7.5 3.5V5z"
                      fill="#fda4af"
                      stroke="#e11d48"
                      stroke-width="1.6"
                      stroke-linejoin="round"></path>
                    <!-- small pennant/flag at top-right -->
                    <path d="M14.5 5 L19 3.5 L18 7 Z" fill="#e11d48"></path>
                    <!-- small sound dot -->
                    <circle cx="17" cy="11" r="1.2" fill="#e11d48" opacity="0.7"></circle>
                  </svg>
                </div>
                <h5 style="color:#be185d;">d. Marketing/ Third-Party Cookies</h5>
                <p>Used to deliver personalized ads or integrate third-party tools.</p>
                <ul>
                  <li>Google Ads</li>
                  <li>Social media embeds (YouTube, etc.)</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- 3. How You Can Control Cookies -->
        <div class="c-section" id="c2">
          <div class="c-sec-head">
            <!-- Green gear/settings cog — matches image -->
            <div class="c-ico" style="background:#dcfce7;">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- gear teeth -->
                <path
                  d="M13 3v2M13 21v2M3 13h2M21 13h2M5.64 5.64l1.42 1.42M19.95 19.95l1.42 1.42M19.95 6.05l-1.42 1.42M7.06 19.36l-1.42 1.42"
                  stroke="#16a34a"
                  stroke-width="2"
                  stroke-linecap="round"></path>
                <!-- gear outer ring -->
                <path
                  d="M10.5 4.2L9 2.5H7l-1 2.5L4.5 6.2 2 6V8l1.8 1.5-.3 2.5L2 13l1.5 2L2 17l1.8 1 .3 2.5L2 22h2l1 2.5 2.5.5 1.5 1.8 2-.3L13 28l2-1.7 2 .3 1.5-1.8 2.5-.5 1-2.5H26l-1.8-1.5.3-2.5L26 17l-1.5-2 1.5-2-1.8-1-.3-2.5L26 8V6l-2.5.2-1.5-1.5-2.5-.5L18.2 2.5H16.5L15.5 4.2l-2.5-.2-2.5.2z"
                  fill="#bbf7d0"
                  opacity="0.6"></path>
                <!-- simple clean gear shape -->
                <circle cx="13" cy="13" r="9" fill="#dcfce7" stroke="#16a34a" stroke-width="1.8"></circle>
