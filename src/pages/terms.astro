---
import BaseLayout from "@/layouts/Base";

const meta = {
  title: "Terms and Conditions",
  description:
    "Read our terms and conditions to understand the rules and guidelines for using abcdkbd's learning platform."
};
---

<style is:inline>
  .t-wrap {
    max-width: 1450px;
    width: 100%;
    margin: 0 auto;
    padding: 30px 40px 60px;
  }

  /* ── HERO ── */
  .terms-hero-image {
    display: block;
    margin-bottom: 30px;
    width: 100%;
  }
  .terms-hero-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── BODY GRID ── */
  .t-body {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ── SIDEBAR ── */
  .t-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .t-box {
    background: #fff;
    border: 1.5px solid #ede9fc;
    border-radius: 18px;
    padding: 1.3rem 1.4rem;
    box-shadow: 0 2px 12px rgba(124, 92, 191, 0.06);
  }

  .t-box-title {
    font-size: 11px;
    font-weight: 800;
    color: #a78bfa;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.85rem;
    display: block;
  }

  /* TOC */
  .t-toc {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .t-toc li {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 8px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .t-toc li:hover {
    background: #f5f3ff;
  }
  .t-toc li span.lbl {
    font-size: 15px;
    font-weight: 700;
    color: #374151;
  }

  .n {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    flex-shrink: 0;
  }
  .n1 {
    background: #ede9fe;
    color: #7c3aed;
  }
  .n2 {
    background: #dbeafe;
    color: #1d4ed8;
  }
  .n3 {
    background: #dcfce7;
    color: #15803d;
  }
  .n4 {
    background: #fef3c7;
    color: #b45309;
  }
  .n5 {
    background: #fce7f3;
    color: #be185d;
  }
  .n6 {
    background: #e0f2fe;
    color: #0369a1;
  }
  .n7 {
    background: #f0fdf4;
    color: #166534;
  }
  .n8 {
    background: #fff7ed;
    color: #c2410c;
  }
  .n9 {
    background: #f5f3ff;
    color: #6d28d9;
  }
  .n10 {
    background: #fef2f2;
    color: #b91c1c;
  }
  .n11 {
    background: #ecfdf5;
    color: #065f46;
  }
  .n12 {
    background: #eff6ff;
    color: #1e40af;
  }

  /* ── HELP BOX ── */
  .t-box.help {
    text-align: center;
    padding: 1.4rem 1.3rem 1.5rem;
  }
  .t-help-bubble {
    position: relative;
    width: 58px;
    height: 52px;
    margin: 0 auto 0.7rem;
  }
  .t-help-bubble .bubble {
    width: 58px;
    height: 52px;
    background: #7c5cbf;
    border-radius: 50% 50% 50% 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .t-help-bubble .bubble svg {
    display: block;
  }
  .t-box.help h4 {
    font-size: 15px;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 4px;
  }
  .t-box.help p {
    font-size: 13px;
    color: #6b7280;
    margin: 0 0 0.9rem;
  }

  .t-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #7c5cbf;
    color: #fff;
    border-radius: 999px;
    padding: 9px 22px;
    font-size: 13.5px;
    font-weight: 800;
    text-decoration: none;
    transition:
      background 0.15s,
      transform 0.1s;
    letter-spacing: 0.01em;
  }
  .t-btn:hover {
    background: #6344a8;
    transform: translateY(-1px);
  }
  .t-btn .arr {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    font-size: 12px;
    line-height: 1;
  }

  /* ── SAFE & TRUSTED ── */
  .t-box.safe {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .t-safe-icon {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .t-box.safe h4 {
    font-size: 14px;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 4px;
  }
  .t-box.safe p {
    font-size: 12.5px;
    color: #6b7280;
    line-height: 1.55;
    margin: 0;
  }

  /* ── CONTENT AREA ── */
  .t-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  /* Welcome banner */
  .t-welcome {
    background: #fff;
    border: 1.5px solid #ede9fc;
    border-radius: 18px;
    padding: 1.1rem 1.3rem;
    display: flex;
    gap: 14px;
    align-items: flex-start;
    box-shadow: 0 2px 12px rgba(124, 92, 191, 0.06);
  }
  .t-star {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #9b72e6 0%, #7c5cbf 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #fff;
    font-size: 18px;
    box-shadow: 0 2px 8px rgba(124, 92, 191, 0.3);
    margin-top: 2px;
  }
  .t-welcome-body {
    flex: 1;
  }
  .t-welcome p {
    font-size: 13.5px;
    font-weight: 600;
    color: #374151;
    line-height: 1.65;
    margin: 0 0 10px;
  }

  /* ── DOWNLOAD BUTTON ── */
  .pp-dl-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #fff;
    color: #7c5cbf;
    border: 1.5px solid #c4b5fd;
    border-radius: 999px;
    padding: 7px 18px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s,
      border-color 0.15s;
  }
  .pp-dl-btn:hover {
    background: #7c5cbf;
    color: #fff;
    border-color: #7c5cbf;
  }

  /* ── ACCORDION ── */
  .t-acc {
    background: #fff;
    border: 1.5px solid #ede9fc;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(124, 92, 191, 0.05);
    transition: box-shadow 0.2s;
  }
  .t-acc:hover {
    box-shadow: 0 4px 18px rgba(124, 92, 191, 0.1);
  }
  .t-acc.open {
    box-shadow: 0 4px 18px rgba(124, 92, 191, 0.12);
  }

  .t-acc-h {
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 16px 20px;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
  }
  .t-acc-h:hover {
    background: #faf9ff;
  }

  .t-ico {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .t-acc-info {
    flex: 1;
    min-width: 0;
  }
  .t-acc-info h3 {
    font-size: 15.5px;
    font-weight: 800;
    color: #1a1a2e;
    margin: 0 0 3px;
  }
  .t-acc-info p {
    font-size: 13px;
    font-weight: 600;
    color: #6b7280;
    margin: 0;
  }

  .t-chev {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #f3f0fd;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition:
      transform 0.22s,
      background 0.15s;
  }
  .t-chev svg {
    display: block;
  }
  .t-acc.open .t-chev {
    transform: rotate(180deg);
    background: #7c5cbf;
  }
  .t-acc.open .t-chev svg path {
    stroke: #fff;
  }

  .t-acc-body {
    display: none;
    padding: 4px 20px 18px 73px;
    font-size: 13.5px;
    font-weight: 600;
    color: #4b5563;
    line-height: 1.78;
    border-top: 1.5px solid #f3f0fd;
  }
  .t-acc.open .t-acc-body {
    display: block;
  }
  .t-acc-body a {
    color: #7c5cbf;
    text-decoration: none;
  }
  .t-acc-body a:hover {
    text-decoration: underline;
  }
  .t-acc-body ul {
    padding-left: 20px;
    margin: 6px 0;
  }
  .t-acc-body li {
    margin-bottom: 4px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .t-body {
      grid-template-columns: 1fr;
    }
    .t-wrap {
      padding: 20px 16px 40px;
    }
  }
</style>

<BaseLayout meta={meta}>
  <div class="t-wrap">
    <!-- HERO IMAGE -->
    <div class="terms-hero-image">
      <img src="/assets/images/hero-terms.png" alt="Terms and Conditions" />
    </div>

    <!-- BODY -->
    <div class="t-body">
      <!-- ══ SIDEBAR ══ -->
      <div class="t-sidebar">
        <div class="t-box">
          <span class="t-box-title">On this page</span>
          <ul class="t-toc">
            <li onclick="tGo(0)"><span class="n n1">1</span><span class="lbl">Acceptance of Terms</span></li>
            <li onclick="tGo(1)"><span class="n n2">2</span><span class="lbl">About the Website</span></li>
            <li onclick="tGo(2)"><span class="n n3">3</span><span class="lbl">Eligibility</span></li>
            <li onclick="tGo(3)"><span class="n n4">4</span><span class="lbl">User Conduct</span></li>
            <li onclick="tGo(4)"><span class="n n5">5</span><span class="lbl">Intellectual Property</span></li>
            <li onclick="tGo(5)"><span class="n n6">6</span><span class="lbl">Parental Responsibility</span></li>
            <li onclick="tGo(6)"><span class="n n7">7</span><span class="lbl">External Links</span></li>
            <li onclick="tGo(7)"><span class="n n8">8</span><span class="lbl">Limitation of Liability</span></li>
            <li onclick="tGo(8)"><span class="n n9">9</span><span class="lbl">Modification of Terms</span></li>
            <li onclick="tGo(9)"><span class="n n10">10</span><span class="lbl">Termination</span></li>
            <li onclick="tGo(10)"><span class="n n11">11</span><span class="lbl">Governing Law</span></li>
            <li onclick="tGo(11)"><span class="n n12">12</span><span class="lbl">Contact</span></li>
          </ul>
        </div>

        <div class="t-box help">
          <div class="t-help-bubble">
            <div class="bubble">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="#fbbf24">
                <path
                  d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                ></path>
              </svg>
            </div>
          </div>
          <h4>Have questions?</h4>
          <p>We're here to help you.</p>
          <a href="/contact" class="t-btn">Contact Us <span class="arr">›</span></a>
        </div>

        <div class="t-box safe">
          <svg class="t-safe-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 4L8 11v13c0 10.5 7 20.3 16 23 9-2.7 16-12.5 16-23V11L24 4z" fill="#3b82f6"></path>
            <path d="M24 4L8 11v2l16-7 16 7v-2L24 4z" fill="#60a5fa"></path>
            <path d="M16 24l5.5 5.5L32 19" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
            ></path>
          </svg>
          <div>
            <h4>Safe &amp; Trusted</h4>
            <p>We're committed to providing a safe and friendly learning environment for kids.</p>
          </div>
        </div>
      </div>
      <!-- END SIDEBAR -->

      <!-- ══ MAIN CONTENT ══ -->
      <div class="t-content">
        <!-- Welcome Banner -->
        <div class="t-welcome">
          <div class="t-star">&#9733;</div>
          <div class="t-welcome-body">
            <p>
              Welcome to <strong>abcdkbd.com</strong>! By accessing or using our platform, you agree to comply with and
              be bound by the following Terms and Conditions.<br />Please read them carefully before using the site.
            </p>
            <button onclick="downloadTermsPDF()" class="pp-dl-btn">
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download Terms PDF
            </button>
          </div>
        </div>

        <!-- 1. Acceptance of Terms -->
        <div class="t-acc" id="t0">
          <div class="t-acc-h" onclick="tToggle(0)">
            <div class="t-ico" style="background:#ede9fe">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#7c3aed"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline
                  points="14,2 14,8 20,8"></polyline>
              </svg>
            </div>
            <div class="t-acc-info">
              <h3>1. Acceptance of Terms</h3>
              <p>By accessing or using abcdkbd.com, you agree to these Terms and our Privacy Policy.</p>
            </div>
            <span class="t-chev"
              ><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                ><path
                  d="M6 9l6 6 6-6"
                  stroke="#7c5cbf"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              ></span
            >
          </div>
          <div class="t-acc-body">
            By accessing or using <strong>abcdkbd.com</strong>, you agree to these Terms and our <a
              href="/privacy-policy">Privacy Policy</a
            >. If you do not agree, please discontinue use immediately.
          </div>
        </div>

        <!-- 2. About the Website -->
        <div class="t-acc" id="t1">
          <div class="t-acc-h" onclick="tToggle(1)">
            <div class="t-ico" style="background:#dbeafe">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#1d4ed8"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="3" width="20" height="14" rx="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line
                  x1="12"
                  y1="17"
                  x2="12"
                  y2="21"></line>
              </svg>
            </div>
            <div class="t-acc-info">
              <h3>2. About the Website</h3>
              <p>abcdkbd.com is a free educational platform for children.</p>
            </div>
            <span class="t-chev"
              ><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                ><path
                  d="M6 9l6 6 6-6"
                  stroke="#7c5cbf"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              ></span
            >
          </div>
          <div class="t-acc-body">
            <strong>abcdkbd.com</strong> is a free educational platform designed for children, offering interactive learning
            tools, games, and resources to support early education. We focus on delivering safe, engaging, and age-appropriate
            learning resources. <b>This site is not intended for commercial use or monetization.</b>
          </div>
        </div>

        <!-- 3. Eligibility -->
        <div class="t-acc" id="t2">
          <div class="t-acc-h" onclick="tToggle(2)">
            <div class="t-ico" style="background:#dcfce7">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#15803d"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="8" r="4"></circle><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"></path>
              </svg>
            </div>
            <div class="t-acc-info">
              <h3>3. Eligibility</h3>
              <p>This platform is primarily for children under parental or guardian supervision.</p>
            </div>
            <span class="t-chev"
              ><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                ><path
                  d="M6 9l6 6 6-6"
                  stroke="#7c5cbf"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              ></span
            >
          </div>
          <div class="t-acc-body">
            This platform is primarily intended for <b>children under parental or guardian supervision</b>. Users under
            18 must use the site with guidance. Parents or guardians must consent to any data collection, per Indian
            laws (DPDP Act, 2023).
          </div>
        </div>

        <!-- 4. User Conduct -->
        <div class="t-acc" id="t3">
          <div class="t-acc-h" onclick="tToggle(3)">
            <div class="t-ico" style="background:#fef3c7">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#b45309"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 12l2 2 4-4"></path>
              </svg>
            </div>
            <div class="t-acc-info">
              <h3>4. User Conduct</h3>
              <p>Users must follow rules to ensure a safe and respectful environment for everyone.</p>
            </div>
            <span class="t-chev"
              ><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                ><path
                  d="M6 9l6 6 6-6"
                  stroke="#7c5cbf"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              ></span
            >
          </div>
          <div class="t-acc-body">
            Users must behave respectfully and follow all platform guidelines. Users must not:
            <ul>
