---
import Back from "@/components/BackButton.astro";
import Help from "@/components/Help.astro";
import MathPractice from "@/components/MathPractice.astro";
import SharePopover from "@/components/ShareButton.astro";
import BaseLayout from "@/layouts/Base";

const meta = {
  title: "Maths",
  description: "Practice basic math arithmetic operations like addition, subtraction, and multiplication."
};
---

<BaseLayout meta={meta}>
  <Back />

  <Fragment slot="header-right">
    <div class="math-header-actions">
      <SharePopover />

      <Help
        title="Basic Arithmetic"
        description="Practice basic math operations like addition, subtraction, and multiplication."
      />
    </div>
  </Fragment>

  <MathPractice />
</BaseLayout>
<style>
  .math-header-actions {
    display: flex;
    align-items: center;
    gap: 4px;
    transform: scale(0.72);
    transform-origin: right center;
  }
</style>
